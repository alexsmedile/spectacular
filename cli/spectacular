# ── cmd_show (canonical doc dump) ────────────────────────────────────────────
cmd_show() {
  local doctype="" section="" json=false
  while (( $# > 0 )); do
    case "$1" in
      --section) require_value "--section" "${2:-}"; section="$2"; shift 2 ;;
      --json)    json=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular show <doctype> [--section <name>] [--json]

Dump a canonical document. Doctype is one of:
  prd | spec | principles | architecture | roadmap | stack | agents
  decisions | memory | sessions | personas

Options:
  --section <name>   Print only the H2 section matching <name>
  --json             JSON output: {path, content}
EOF
        exit 0 ;;
      -*) die "Unknown flag for show: $1" ;;
      *)
        [[ -n "$doctype" ]] && die "show: only one <doctype> argument allowed"
        doctype="$1"; shift ;;
    esac
  done

  [[ -z "$doctype" ]] && die "show: <doctype> argument required"
  [[ -d ".spectacular" ]] || die "show: not inside a Spectacular workspace"

  local path
  case "$doctype" in
    prd)          path=".spectacular/PRD.md" ;;
    spec)         path=".spectacular/SPEC.md" ;;
    principles)   path=".spectacular/PRINCIPLES.md" ;;
    policy)       path=".spectacular/POLICY.md" ;;
    architecture) path=".spectacular/ARCHITECTURE.md" ;;
    roadmap)      path=".spectacular/ROADMAP.md" ;;
    stack)        path=".spectacular/STACK.md" ;;
    agents)       path=".spectacular/AGENTS.md" ;;
    decisions)    path=".spectacular/DECISIONS.md" ;;
    memory)       path=".spectacular/MEMORY.md" ;;
    sessions)     path=".spectacular/SESSIONS.md" ;;
    personas)     path=".spectacular/PERSONAS.md" ;;
    *) die "show: unknown doctype '$doctype'. Run 'spectacular show --help' for the list." ;;
  esac

  [[ -f "$path" ]] || die "show: '$path' not found (doctype '$doctype' not scaffolded)"

  local content
  if [[ -n "$section" ]]; then
    content=$(awk -v s="$section" '
      /^## / {
        if (in_section) exit
        if (index(tolower($0), tolower(s)) > 0) { in_section=1 }
      }
      in_section { print }
    ' "$path")
    [[ -z "$content" ]] && die "show: section '$section' not found in $path"
  else
    content=$(cat "$path")
  fi

  if $json; then
    printf '{"path":"%s","content":"%s"}\n' \
      "$(_json_escape "$path")" "$(_json_escape "$content")"
  else
    printf '%s\n' "$content"
  fi
}

# ── ascii-render helpers (v1.15.0+) ──────────────────────────────────────────
# Shared rendering primitives used by progress, summary, roadmap, and any
# future surface that needs a visual layer. All functions degrade cleanly:
# - _ascii_color_enabled: returns 0 (true) only when stdout is a TTY and
#   NO_COLOR is unset/empty. Call once and branch; never inline the test.
# - _ascii_bar: renders a filled/empty bar + percentage, NO_COLOR-aware.
# - _ascii_box: wraps lines in a light box, NO_COLOR-aware (plain lines fallback).

_ascii_color_enabled() {
  [[ -z "${NO_COLOR:-}" ]] && [[ -t 1 ]]
}

# _ascii_bar <done> <total> [<width>]
# Prints "███░░░ 60%"  (block chars on TTY/color) or "[###...] 60%" (plain).
# Width defaults to 20 fill chars. Clamps done to [0,total].
_ascii_bar() {
  local done="$1" total="$2" width="${3:-20}"
  (( done < 0 ))     && done=0
  (( done > total )) && done=$total
  local pct=0
  (( total > 0 )) && pct=$(( done * 100 / total ))
  local filled=$(( total > 0 ? done * width / total : 0 ))
  local empty=$(( width - filled ))
  if _ascii_color_enabled; then
    local bar=""
    local i
    for (( i=0; i<filled; i++ )); do bar+="█"; done
    for (( i=0; i<empty;  i++ )); do bar+="░"; done
    printf "%s %d%%" "$bar" "$pct"
  else
    local bar="["
    local i
    for (( i=0; i<filled; i++ )); do bar+="#"; done
    for (( i=0; i<empty;  i++ )); do bar+="."; done
    bar+="]"
    printf "%s %d%%" "$bar" "$pct"
  fi
}

# _ascii_box <title> [line...]
# Prints a left-border box: ┌─ title / │ line / └─
# Falls back to plain "=== title / line / ===" when color disabled.
_ascii_box() {
  local title="$1"; shift
  if _ascii_color_enabled; then
    echo "┌─ $title"
    while (( $# > 0 )); do echo "│ $1"; shift; done
    echo "└─"
  else
    echo "=== $title ==="
    while (( $# > 0 )); do echo "  $1"; shift; done
    echo "==="
  fi
}

# ── cmd_progress (TASKS milestone tick rate) ─────────────────────────────────
_progress_text() {
  local tasks="$1"
  [[ -f "$tasks" ]] || { echo "(TASKS.md not found)"; return 1; }

  # Parse milestones into parallel arrays via awk, then render with _ascii_bar.
  local -a names dones totals
  while IFS='|' read -r name done total; do
    names+=("$name")
    dones+=("$done")
    totals+=("$total")
  done < <(awk '
    /^#{2,3} M[0-9]+/ {
      if (milestone != "") printf "%s|%d|%d\n", milestone, done, (done+todo)
      milestone = $0
      sub(/^#{2,3} /, "", milestone)
      done = 0; todo = 0
      next
    }
    /^- \[x\]/ { done++ }
    /^- \[ \]/ { todo++ }
    END {
      if (milestone != "") printf "%s|%d|%d\n", milestone, done, (done+todo)
    }
  ' "$tasks")

  local total_done=0 total_items=0
  local i
  for (( i=0; i<${#names[@]}; i++ )); do
    total_done=$(( total_done + dones[i] ))
    total_items=$(( total_items + totals[i] ))
    local bar
    bar=$(_ascii_bar "${dones[$i]}" "${totals[$i]}" 16)
    if (( totals[i] > 0 && dones[i] == totals[i] )); then
      printf "  %-38s %s ✓\n" "${names[$i]}" "$bar"
    else
      printf "  %-38s %s  %d/%d\n" "${names[$i]}" "$bar" "${dones[$i]}" "${totals[$i]}"
    fi
  done

  if (( ${#names[@]} > 1 )); then
    echo ""
    local rollup
    rollup=$(_ascii_bar "$total_done" "$total_items" 20)
    printf "  %-38s %s\n" "overall" "$rollup"
  fi
}

_progress_json() {
  local tasks="$1"
  [[ -f "$tasks" ]] || { echo "null"; return 1; }
  awk '
    BEGIN { printf "[" }
    /^#{2,3} M[0-9]+/ {
      if (milestone != "") {
        if (started) printf ","
        printf "{\"milestone\":\"%s\",\"done\":%d,\"total\":%d}", milestone, done, (done+todo)
        started = 1
      }
      milestone = $0
      sub(/^#{2,3} /, "", milestone)
      gsub(/"/, "\\\"", milestone)
      done = 0; todo = 0
      next
    }
    /^- \[x\]/ { done++ }
    /^- \[ \]/ { todo++ }
    END {
      if (milestone != "") {
        if (started) printf ","
        printf "{\"milestone\":\"%s\",\"done\":%d,\"total\":%d}", milestone, done, (done+todo)
      }
      printf "]"
    }
  ' "$tasks"
}

