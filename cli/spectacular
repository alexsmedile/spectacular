#!/usr/bin/env bash
set -euo pipefail

# ── constants ────────────────────────────────────────────────────────────────
SPECTACULAR_VERSION="1.17.2"
# Resolve symlinks so SCRIPT_DIR points at the real cli/ dir even when the
# binary is invoked via a symlink (e.g. ~/.local/bin/spectacular → …/cli/spectacular).
# Without this, template resolution (_resolve_template Path 3) breaks for the
# canonical symlinked install.
_SPEC_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$_SPEC_SOURCE" ]]; do
  _SPEC_DIR="$(cd -P "$(dirname "$_SPEC_SOURCE")" && pwd)"
  _SPEC_SOURCE="$(readlink "$_SPEC_SOURCE")"
  [[ "$_SPEC_SOURCE" != /* ]] && _SPEC_SOURCE="$_SPEC_DIR/$_SPEC_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_SPEC_SOURCE")" && pwd)"
unset _SPEC_SOURCE _SPEC_DIR
GITHUB_REPO="alexsmedile/spectacular"
GITHUB_RELEASES_API="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"
GITHUB_TAGS_API="https://api.github.com/repos/${GITHUB_REPO}/tags"
GITHUB_MAIN_TARBALL="https://github.com/${GITHUB_REPO}/archive/refs/heads/main.tar.gz"
SKILL_PATH_IN_TARBALL="skills/spectacular"
TODAY="$(date +%Y-%m-%d)"

# Workspace schema version — bumped only when .spectacular/ structure changes.
# Decoupled from CLI/skill version. Migrations advance workspace_schema through
# the chain (v0.4 → v0.5 → v0.6 → ...). See requests/workspace-migrations/PLAN.md.
CURRENT_SCHEMA="0.6"

# ── defaults ─────────────────────────────────────────────────────────────────
OPT_NAME=""
OPT_SUMMARY=""
OPT_AGENTS_FILE="AGENTS.md"
OPT_GLOBAL=false
OPT_UPDATE=false
OPT_INTERACTIVE=false
OPT_KIT="blank"
OPT_WITH=""
OPT_MINIMAL=false
# Skill install scope: project (./.agents) | global (~/.agents) | none (scaffold only).
# Empty = unset → resolved at init time (auto: skip if already installed, else project).
OPT_SKILL_SCOPE=""

# Always-set: scaffolded regardless of kit. The 6-file minimum.
#   PRD.md, SPEC.md, config.yaml, AGENTS.md (file name varies per --agents-file), requests/, specs/
ALWAYS_SET="prd spec config agents policy"

# Known doc IDs (kit triggers-docs entries and --with values must match these)
KNOWN_DOCS="prd spec principles policy architecture roadmap stack decisions memory sessions agents config personas plan tasks vision"

# Bundled kits (must exist as templates/prd/kits/<id>.md in installed skill)
KNOWN_KITS="blank coding content product research"

# ── helpers ──────────────────────────────────────────────────────────────────
die()  { echo "Error: $*" >&2; exit 1; }
# die_recover: a mutator failure that points at the manual equivalent so a
# broken/deterministic verb is never a dead end. First arg = error message,
# remaining args = recovery hint lines (printed under "→ Manual recovery:").
die_recover() {
  local msg="$1"; shift
  echo "Error: $msg" >&2
  if (( $# > 0 )); then
    echo "  → Manual recovery:" >&2
    local line
    for line in "$@"; do echo "      $line" >&2; done
  fi
  exit 1
}
info() { echo "$*"; }
skip() { echo "  ⊘  $*"; }
created() { echo "  ✓  $*"; }
filled() { echo "  ✓  $* (filled empty stub)"; }
diag()  { echo "  ⊘  $* (issues detected — run \`spectacular doctor frontmatter\` for details)"; }

# Validate that a flag has a usable value (non-empty, not another flag).
# Usage: require_value "$flag_name" "${2:-}"
require_value() {
  local flag="$1"
  local val="${2:-}"
  [[ -n "$val" ]] || die "$flag requires a value"
  [[ "$val" != -* ]] || die "$flag requires a value (got '$val' — looks like another flag)"
}

# Replace an existing claude_dir entry (symlink or directory) with a fresh symlink.
# Refuses to clobber a non-empty real directory — that's likely user content, not our managed link.
reset_claude_symlink() {
  local claude_dir="$1"
  local target="$2"
  if [[ -L "$claude_dir" ]]; then
    rm -f "$claude_dir"
  elif [[ -d "$claude_dir" ]]; then
    if [[ -z "$(ls -A "$claude_dir" 2>/dev/null)" ]]; then
      rmdir "$claude_dir"
    else
      die "Refusing to replace non-empty directory: $claude_dir (expected a symlink). Move it aside and retry."
    fi
  elif [[ -e "$claude_dir" ]]; then
    rm -f "$claude_dir"
  fi
  mkdir -p "$(dirname "$claude_dir")"
  ln -s "$target" "$claude_dir"
}

# Returns 0 if file is "effectively empty" (0 bytes or only whitespace)
is_empty_file() {
  local path="$1"
  [[ ! -s "$path" ]] && return 0
  ! grep -q '[^[:space:]]' "$path" 2>/dev/null
}

# Returns 0 if `needle` (whitespace-trimmed) appears in space-separated `haystack`
# IFS is explicitly reset so callers using comma-IFS don't break the split.
in_list() {
  local needle="$1" haystack="$2"
  local IFS=$' \t\n'
  for item in $haystack; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

slug_from_dir() {
  basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//'
}

write_if_missing() {
  local path="$1"; shift
  if [[ -e "$path" ]]; then
    if is_empty_file "$path"; then
      printf '%s' "$*" > "$path"
      filled "$path"
    else
      # Cheap heuristic: file looks malformed if it has no frontmatter delimiter
      # and the doc is supposed to have frontmatter
      if [[ "$path" == *.md ]] && ! head -1 "$path" | grep -q '^---$'; then
        diag "$path"
      else
        skip "$path"
      fi
    fi
  else
    mkdir -p "$(dirname "$path")"
    printf '%s' "$*" > "$path"
    created "$path"
  fi
}

# ── usage ────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
Usage: spectacular init [options]

Bootstrap a new project with the Spectacular workspace scaffold.

Options:
  -i, --interactive         Prompt for all foundational settings (incl. kit + suggested docs)
      --name <slug>         Project name (default: current folder slug)
      --summary <text>      Project summary (default: empty)
      --agents-file <file>  Primary agents file (default: AGENTS.md)
      --kit <name>          Kit identity for the PRD + extra docs (default: blank)
                            One of: blank, coding, content, product, research
      --with <a,b,c>        Comma-separated extra root docs to scaffold beyond always-set
                            Doc IDs: principles, architecture, roadmap, stack, decisions
      --minimal             Scaffold the 6-file always-set only; ignore kit triggers-docs
      --skill-scope <s>     Where to install the skill: project | global | none
                            project = ./.agents + ./.claude (default)
                            global   = ~/.agents + ~/.claude
