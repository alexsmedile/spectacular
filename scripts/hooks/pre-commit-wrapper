#!/usr/bin/env bash
# pre-commit-wrapper — local pre-commit that runs project guards, then delegates
# to the git-guard-managed `pre-commit` (version consistency).
#
# Why a wrapper: `scripts/hooks/pre-commit` is generated by the git-guard skill and
# carries a "do not edit" header — hand-edits get clobbered on regen. This wrapper
# lives beside it, adds our own checks, and calls it unmodified. Wire git to run
# this file instead of `pre-commit`:
#
#   git config core.hooksPath scripts/hooks/.active
#   ln -sf ../pre-commit-wrapper scripts/hooks/.active/pre-commit
#
# (See scripts/hooks/README.md § Install.)

set -uo pipefail
ROOT="$(git rev-parse --show-toplevel)"

# ── guard: SKILL.md description length (Codex 1024-char cap) ──────────────────
# Only check SKILL.md files that are actually staged for this commit.
# (bash 3.2-compatible — no `mapfile`; macOS ships bash 3.2.)
staged_skills=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)SKILL\.md$' || true)
if [[ -n "$staged_skills" ]]; then
  echo ""
  echo "skill description check"
  echo "─────────────────────────────────────────────────"
  # Resolve staged paths to repo-absolute for the helper.
  abs=()
  while IFS= read -r f; do
    [[ -n "$f" ]] && abs+=("$ROOT/$f")
  done <<< "$staged_skills"
  if ! bash "$ROOT/scripts/check-skill-desc.sh" "${abs[@]}"; then
    echo ""
    echo "  description over Codex's 1024-char cap — commit blocked"
    echo "  trim the \`description\` frontmatter, then commit again"
    echo ""
    exit 1
  fi
  echo ""
fi

# ── delegate to git-guard's version-consistency pre-commit ───────────────────
if [[ -x "$ROOT/scripts/hooks/pre-commit" ]]; then
  exec "$ROOT/scripts/hooks/pre-commit" "$@"
fi
exit 0
