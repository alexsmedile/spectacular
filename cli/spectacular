# ── frontmatter helpers (v0.7.0+) ─────────────────────────────────────────────
# Shared by all mutator verbs (promote, archive, snapshot, new, touch). Each
# helper assumes YAML frontmatter delimited by --- at lines 1 and N.

# Read a top-level scalar frontmatter field. Stdout: value (trimmed, unquoted);
# empty if file missing, no frontmatter, or field absent.
fm_get() {
  local file="$1" field="$2"
  [[ -f "$file" ]] || return 0
  awk -v fld="$field" '
    /^---$/ { fm++; if (fm > 1) exit; next }
    fm == 1 && $0 ~ "^"fld":" {
      val = $0
      sub("^"fld":[[:space:]]*", "", val)
      gsub(/^"|"$/, "", val)
      gsub(/[[:space:]]+$/, "", val)
      print val
      exit
    }
  ' "$file"
}

# Write or replace a top-level scalar frontmatter field. Adds the field if
# missing (inserts just before the closing --- delimiter). Preserves
# surrounding YAML formatting. Quotes value with double quotes if it contains
# special characters.
#
# Usage: fm_set <file> <field> <value>
fm_set() {
  local file="$1" field="$2" value="$3"
  [[ -f "$file" ]] || die "fm_set: file not found: $file"

  # Quote if value contains a colon, leading dash, or wraps in special chars
  local quoted_value="$value"
  if [[ "$value" =~ [\":#] ]] || [[ "$value" =~ ^[[:space:]]*- ]]; then
    quoted_value="\"${value//\"/\\\"}\""
  fi

  local tmp
  tmp=$(mktemp)
  awk -v fld="$field" -v val="$quoted_value" '
    BEGIN { fm=0; replaced=0 }
    /^---$/ {
      fm++
      if (fm == 2 && !replaced) {
        # Insert field just before closing delimiter
        print fld ": " val
      }
      print
      next
    }
    fm == 1 && $0 ~ "^"fld":" {
      print fld ": " val
      replaced=1
      next
    }
    { print }
  ' "$file" > "$tmp" && mv "$tmp" "$file"
}

# Set updated: to today.
fm_touch() {
  fm_set "$1" "updated" "$TODAY"
}

# Append item to a YAML list field. Creates the list (as inline `field: [item]`)
# if absent. Skips silently if item already present in list.
#
# Usage: fm_add_to_list <file> <field> <item>
fm_add_to_list() {
  local file="$1" field="$2" item="$3"
  [[ -f "$file" ]] || die "fm_add_to_list: file not found: $file"

  # Check if item already in list (handles both block and inline styles)
  if awk -v fld="$field" -v itm="$item" '
    /^---$/ { fm++; if (fm > 1) exit; next }
    fm == 1 && $0 ~ "^"fld":" { in_list=1; line=$0 }
    in_list && /- / {
      val = $0
      sub(/^[[:space:]]*-[[:space:]]*/, "", val)
      gsub(/^"|"$/, "", val)
      if (val == itm) { found=1; exit }
    }
    in_list && !/^[[:space:]]/ && !/^---$/ { in_list=0 }
    END { exit (found ? 0 : 1) }
  ' "$file"; then
    return 0  # already present
  fi

  # Detect list style + append. Simple case: block list (one - per line).
  local tmp
  tmp=$(mktemp)
  awk -v fld="$field" -v itm="$item" '
    BEGIN { fm=0; inserted=0; in_list=0 }
    /^---$/ {
      fm++
      if (fm == 2 && !inserted) {
        # Field absent entirely; insert before closing delim
        print fld ":\n  - " itm
        inserted=1
      }
      print
      next
    }
    fm == 1 && $0 ~ "^"fld":" {
      print
      in_list=1
      next
    }
    in_list && /^[[:space:]]*-[[:space:]]+/ {
      print
      next
    }
    in_list && !/^[[:space:]]/ {
      # End of list — insert before this line
      print "  - " itm
      inserted=1
      in_list=0
      print
      next
    }
    { print }
  ' "$file" > "$tmp" && mv "$tmp" "$file"
}

# ── soft-DB helpers (v1.5.0 — decide / remember / session) ──────────────────

# Derive a kebab-case slug from arbitrary text. Takes first ~6 words.
# Usage: _slug_from_text "use bash for the cli implementation"
#        → use-bash-for-the-cli-implementation
_slug_from_text() {
  local text="$1"
  local words
  words=$(echo "$text" | awk '{ for (i=1;i<=NF && i<=6;i++) printf "%s ", $i; print "" }')
  echo "$words" | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9 ]+/ /g; s/[[:space:]]+/-/g; s/-+/-/g; s/^-//; s/-$//' \
    | cut -c1-64
}

# Resolve slug collisions by appending -2, -3, etc. Warns on collision.
# Usage: _resolve_slug_collision <dir> <base-slug> <ext>
#        echoes the final slug (no extension)
_resolve_slug_collision() {
  local dir="$1" base="$2" ext="$3"
  local candidate="$base" n=2
  while [[ -e "$dir/$candidate.$ext" ]]; do
    candidate="${base}-${n}"
    n=$((n + 1))
  done
  if [[ "$candidate" != "$base" ]]; then
    echo "  ⚠  slug collision: '$base' → '$candidate'" >&2
  fi
  echo "$candidate"
}

# Derive a 1-line summary from the first sentence of text.
# Usage: _summary_from_text "long text. with multiple sentences."
# Note: uses sed (multibyte-safe) instead of awk char-iteration which chokes
# on em-dashes and other 3-byte UTF-8 chars on macOS.
_summary_from_text() {
  local text="$1"
  # Replace newlines with spaces, take first sentence (split on period/!/? + space),
  # strip trailing punctuation, trim, cap at 120 chars.
  local summary
  summary=$(printf '%s' "$text" \
    | tr '\n' ' ' \
    | sed -E 's/([.!?])[[:space:]].*$/\1/' \
    | sed -E 's/[[:space:]]+/ /g; s/^[[:space:]]+|[[:space:]]+$//g; s/[.!?]+$//' \
    | cut -c1-120)
  echo "$summary"
}

# Return the slug of the currently-open session, or empty if none.
# Scans .spectacular/sessions/*.md for status: open.
_active_session_slug() {
  local sessions_dir=".spectacular/sessions"
  [[ -d "$sessions_dir" ]] || return 0
  local file status
  for file in "$sessions_dir"/*.md; do
    [[ -f "$file" ]] || continue
    status=$(fm_get "$file" "status")
    if [[ "$status" == "open" ]]; then
      basename "$file" .md
      return 0
    fi
  done
}

# Resolve a template path. Looks in project-local override first, then bundled.
# Usage: _resolve_template <relative-path-under-templates>
#        e.g. "memory/entry.md" → /path/to/templates/memory/entry.md
_resolve_template() {
  local rel="$1"
  local project_override=".spectacular/templates/$rel"
  if [[ -f "$project_override" ]]; then
    echo "$project_override"; return 0
  fi
  local bundled
  bundled="$(agents_skill_dir)/templates/$rel"
  if [[ -f "$bundled" ]]; then
    echo "$bundled"; return 0
  fi
  # Scope-independent global install fallback: a workspace may use a globally
  # installed skill regardless of OPT_SKILL_SCOPE (which is only "global" at
  # init time). Check the canonical global skill dir directly.
  bundled="$HOME/.agents/skills/spectacular/templates/$rel"
  if [[ -f "$bundled" ]]; then
    echo "$bundled"; return 0
  fi
  bundled="${SCRIPT_DIR}/../skills/spectacular/templates/$rel"
  if [[ -f "$bundled" ]]; then
    echo "$bundled"; return 0
  fi
  return 1
}

# Render a template by substituting <PLACEHOLDER> tokens.
# Usage: _render_template <template-path> <KEY1> <VAL1> <KEY2> <VAL2> ...
#        Emits rendered content to stdout.
_render_template() {
  local template="$1"; shift
  local content
  content=$(cat "$template")
  # Strip leading <!-- ... --> comment block (template hints not meant for output)
  content=$(echo "$content" | awk 'BEGIN{skip=0} /^<!--$/||/^<!--/{skip=1} skip && /-->$/{skip=0;next} !skip{print}')
  # Trim leading blank lines
  content=$(echo "$content" | awk 'BEGIN{started=0} /./{started=1} started{print}')
  while (( $# >= 2 )); do
    local key="$1" val="$2"; shift 2
    # Escape forward slashes + ampersands for sed replacement
    local esc_val
    esc_val=$(printf '%s' "$val" | sed 's/[\/&]/\\&/g')
    content=$(echo "$content" | sed "s/<${key}>/${esc_val}/g")
  done
  echo "$content"
}

# Regenerate MEMORY.md index from .spectacular/memory/*.md entries.
# Newest first by date in frontmatter.
_regen_memory_index() {
  local index=".spectacular/MEMORY.md"
  local entries_dir=".spectacular/memory"
  [[ -d "$entries_dir" ]] || return 0

  {
    cat <<EOF
---
type: index
doc: memory
version: 1.0
updated: $TODAY
summary: "Operational memory index — auto-regenerated by spectacular remember"
---

# Memory

| Date | Slug | Tags | Summary |
|------|------|------|---------|
EOF
    # Collect rows: date<TAB>slug<TAB>tags<TAB>summary, sort by date desc
    local file slug date tags summary tags_inline
    for file in "$entries_dir"/*.md; do
      [[ -f "$file" ]] || continue
      slug=$(basename "$file" .md)
      date=$(fm_get "$file" "date")
      summary=$(fm_get "$file" "summary")
      # tags: read inline list; fall back to empty
      tags_inline=$(awk '/^---$/{fm++;if(fm>1)exit;next} fm==1 && /^tags:/{
        val=$0; sub(/^tags:[[:space:]]*/,"",val); print val; exit }' "$file")
      tags="${tags_inline:-[]}"
      printf '%s\t%s\t%s\t%s\n' "${date:-0000-00-00}" "$slug" "$tags" "$summary"
    done | sort -r | awk -F'\t' '{printf "| %s | [[memory/%s]] | %s | %s |\n", $1, $2, $3, $4}'
  } > "$index"
}

# Regenerate SESSIONS.md index from .spectacular/sessions/*.md entries.
# Newest first by start_date. Status column shows open|closed.
_regen_sessions_index() {
  local index=".spectacular/SESSIONS.md"
  local entries_dir=".spectacular/sessions"
  [[ -d "$entries_dir" ]] || return 0

  {
    cat <<EOF
---
type: index
doc: sessions
version: 1.0
updated: $TODAY
summary: "Sessions index — auto-regenerated by spectacular session start|end"
---

# Sessions

| Start | Slug | Status | Decisions | Memories | Tags |
|-------|------|--------|-----------|----------|------|
EOF
    local file slug start status dcount mcount tags_inline
    for file in "$entries_dir"/*.md; do
      [[ -f "$file" ]] || continue
      slug=$(basename "$file" .md)
      start=$(fm_get "$file" "start_date")
      status=$(fm_get "$file" "status")
      dcount=$(fm_get "$file" "decisions_count")
      mcount=$(fm_get "$file" "memories_count")
      tags_inline=$(awk '/^---$/{fm++;if(fm>1)exit;next} fm==1 && /^tags:/{
        val=$0; sub(/^tags:[[:space:]]*/,"",val); print val; exit }' "$file")
      printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
        "${start:-0000-00-00}" "$slug" "${status:-?}" "${dcount:-0}" "${mcount:-0}" "${tags_inline:-[]}"
    done | sort -r | awk -F'\t' '{printf "| %s | [[sessions/%s]] | %s | %s | %s | %s |\n", $1, $2, $3, $4, $5, $6}'
  } > "$index"
}

# ── cmd_remember: spectacular remember "<text>" [--tag a,b] ─────────────────
cmd_remember() {
  local text="" tags_csv="" dry_run=false
  while (( $# > 0 )); do
    case "$1" in
      --tag|--tags) require_value "--tag" "${2:-}"; tags_csv="$2"; shift 2 ;;
      --dry-run)    dry_run=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular remember "<text>" [--tag a,b] [--dry-run]

Write one memory entry to .spectacular/memory/<slug>.md and regenerate
MEMORY.md index. Auto-derives slug + summary. If a session is open,
the entry links to it via frontmatter session: field.
EOF
        exit 0 ;;
      -*) die "Unknown flag for remember: $1" ;;
      *)
        [[ -n "$text" ]] && die "remember: only one <text> argument allowed"
        text="$1"; shift ;;
    esac
  done

  [[ -z "$text" ]] && die "remember: <text> argument required. See: spectacular remember --help"
  [[ -d ".spectacular" ]] || die "remember: not inside a Spectacular workspace"

  local base_slug slug entry_dir entry_path summary tags_yaml session
  base_slug=$(_slug_from_text "$text")
  [[ -z "$base_slug" ]] && die "remember: could not derive slug from text"
  entry_dir=".spectacular/memory"
  mkdir -p "$entry_dir"
  slug=$(_resolve_slug_collision "$entry_dir" "$base_slug" "md")
  entry_path="$entry_dir/$slug.md"
  summary=$(_summary_from_text "$text")

  # Build tags YAML inline list
  if [[ -n "$tags_csv" ]]; then
    tags_yaml="[$(echo "$tags_csv" | sed 's/,/, /g')]"
  else
    tags_yaml="[]"
  fi

  session=$(_active_session_slug)
  local session_yaml="null"
  [[ -n "$session" ]] && session_yaml="$session"

  local template rendered
  template=$(_resolve_template "memory/entry.md") || die_recover \
    "remember: memory entry template not found" \
    "Create .spectacular/memory/${base_slug}.md with frontmatter:" \
    "  type: memory / date: $TODAY / tags: [...] / summary: \"...\" / session: null" \
    "then add the body text below the frontmatter." \
    "It will appear in MEMORY.md on the next successful 'spectacular remember'."
  rendered=$(_render_template "$template" \
    DATE "$TODAY" \
    TAGS "$tags_yaml" \
    SUMMARY "$summary" \
    SESSION "$session_yaml" \
    TEXT "$text")

  if $dry_run; then
    echo "── would write $entry_path ──"
    echo "$rendered"
    echo "── would regenerate MEMORY.md ──"
    return 0
  fi

  echo "$rendered" > "$entry_path"
  created "$entry_path"
  _regen_memory_index
  info "  ✓  MEMORY.md regenerated"
  if [[ -n "$session" ]]; then
    info "  ↳ linked to session: $session"
  fi
}

# ── cmd_decide: spectacular decide "<text>" ─────────────────────────────────
# v1.5.0: appends to flat DECISIONS.md.
# v1.17.0: detects index mode (decisions/ folder) and writes per-entry file instead.
cmd_decide() {
  local text="" context="" consequences="" dry_run=false
  while (( $# > 0 )); do
    case "$1" in
      --dry-run) dry_run=true; shift ;;
      --context)      require_value "--context" "${2:-}";      context="$2";      shift 2 ;;
      --consequences) require_value "--consequences" "${2:-}"; consequences="$2"; shift 2 ;;
      --help|-h)
        cat <<EOF
Usage: spectacular decide "<decision>" [--context "..."] [--consequences "..."] [--dry-run]

Append one ADR-style entry to .spectacular/DECISIONS.md (Context / Decision /
Consequences). The positional argument fills **Decision:**. Auto-derives a
title from the first ~6 words of the decision. If a session is open, the entry
includes a Session: link to the active session.

In index mode (detected by presence of .spectacular/decisions/), writes full
ADR prose to decisions/D<N>.md and appends one index line to DECISIONS.md.
In flat mode, appends the full block directly to DECISIONS.md.

  --context "..."        fill the **Context:** section (situation forcing the decision)
  --consequences "..."   fill the **Consequences:** section (what it enables/forecloses)

Sections left without a flag are emitted as empty headers to fill in later.
EOF
        exit 0 ;;
      -*) die "Unknown flag for decide: $1" ;;
      *)
        [[ -n "$text" ]] && die "decide: only one <decision> argument allowed"
        text="$1"; shift ;;
    esac
  done

  [[ -z "$text" ]] && die "decide: <decision> argument required. See: spectacular decide --help"
  [[ -d ".spectacular" ]] || die "decide: not inside a Spectacular workspace"

  local title session
  title=$(_summary_from_text "$text")
  session=$(_active_session_slug)

  local decisions=".spectacular/DECISIONS.md"
  local decisions_dir=".spectacular/decisions"

  # ── Index mode ──────────────────────────────────────────────────────────────
  if [[ -d "$decisions_dir" ]]; then
    # Auto-number: find highest D<N> in decisions/ dir
    local next_n=1
    local f num
    for f in "$decisions_dir"/D*.md; do
      [[ -f "$f" ]] || continue
      num=$(basename "$f" .md)
      num="${num#D}"
      [[ "$num" =~ ^[0-9]+$ ]] && (( num >= next_n )) && next_n=$(( num + 1 ))
    done

    local dnum="D${next_n}"
    local entry_path="${decisions_dir}/${dnum}.md"

    # Build the index line: - **D<N>** — Title — one-sentence rationale
    # Title comes from the decision text; rationale from consequences if provided.
    local rationale="${consequences:-${context:-}}"
    local index_line
    if [[ -n "$rationale" ]]; then
      index_line="- **${dnum}** — ${title} — ${rationale}"
    else
      index_line="- **${dnum}** — ${title}"
    fi

    # Build full ADR prose for the per-entry file
    local prose
    prose=$(printf '# %s — %s\n\n**Context:**\n%s\n\n**Decision:**\n%s\n\n**Consequences:**\n%s\n' \
      "$dnum" "$title" "$context" "$text" "$consequences")
    if [[ -n "$session" ]]; then
      prose+="$(printf '\n**Session:** [[sessions/%s]]\n' "$session")"
    fi

    if $dry_run; then
      echo "── would write ${entry_path} ──"
      echo "$prose"
      echo ""
      echo "── would append to ${decisions} (index line) ──"
      echo "$index_line"
      return 0
    fi

    # Ensure DECISIONS.md exists (bootstrap if absent in an index-mode workspace)
    if [[ ! -f "$decisions" ]]; then
      cat > "$decisions" <<EOF
---
type: decisions
doc: decisions
updated: $TODAY
---

# Decisions

EOF
      created "$decisions"
    fi

    printf '%s\n' "$prose" > "$entry_path"
    created "$entry_path"
    printf '%s\n' "$index_line" >> "$decisions"
    fm_touch "$decisions"
    info "  ✓  decision ${dnum}: $title"
    [[ -n "$session" ]] && info "  ↳ linked to session: $session"
    return 0
  fi

  # ── Flat mode (original behavior) ───────────────────────────────────────────
  local entry
  entry=$(printf '\n## %s — %s\n\n**Context:**\n%s\n\n**Decision:**\n%s\n\n**Consequences:**\n%s\n' \
    "$TODAY" "$title" "$context" "$text" "$consequences")
  if [[ -n "$session" ]]; then
    entry+="$(printf '\n**Session:** [[sessions/%s]]\n' "$session")"
  fi

  if $dry_run; then
    [[ -f "$decisions" ]] || echo "── would create $decisions ──"
    echo "── would append to $decisions ──"
    echo "$entry"
    return 0
  fi

  # Bootstrap DECISIONS.md if absent
  if [[ ! -f "$decisions" ]]; then
    cat > "$decisions" <<EOF
---
type: decisions
doc: decisions
updated: $TODAY
---

# Decisions

EOF
    created "$decisions"
  fi

  printf '%s' "$entry" >> "$decisions"
  fm_touch "$decisions"
  info "  ✓  appended decision: $title"
  [[ -n "$session" ]] && info "  ↳ linked to session: $session"
}

# ── cmd_decisions_migrate: spectacular decisions migrate ─────────────────────
# v1.17.0: split flat DECISIONS.md into index mode.
cmd_decisions_migrate() {
  local dry_run=false
  while (( $# > 0 )); do
    case "$1" in
      --dry-run) dry_run=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular decisions migrate [--dry-run]

Split a flat .spectacular/DECISIONS.md into index mode:
  - Extracts each "## YYYY-MM-DD — Title" block into decisions/D<N>.md
  - Rewrites DECISIONS.md as a one-liner index (one line per decision)

Safe: per-entry files are written before DECISIONS.md is rewritten.
Idempotent: exits 0 if decisions/ already exists.

  --dry-run   Preview would-write paths and index; write nothing.
EOF
        exit 0 ;;
      *) die "Unknown flag for decisions migrate: $1" ;;
    esac
  done

  [[ -d ".spectacular" ]] || die "decisions migrate: not inside a Spectacular workspace"

  local decisions=".spectacular/DECISIONS.md"
  local decisions_dir=".spectacular/decisions"

  # Idempotent: already migrated
  if [[ -d "$decisions_dir" ]]; then
    info "  ✓  already in index mode ($decisions_dir exists) — nothing to do"
    return 0
  fi

  [[ -f "$decisions" ]] || die "decisions migrate: $decisions not found — nothing to migrate"

  # Parse flat DECISIONS.md: split on "## YYYY-MM-DD —" heading lines.
  # Accumulate blocks, write D<N>.md per block.
  # Skip the YAML frontmatter (first --- ... --- block) then parse entries.
  local block_title="" block_lines=""
  local -a titles=() blocks=()

  # Strip frontmatter first (awk: skip from line 1 "---" to the closing "---")
  local body
  if head -1 "$decisions" | grep -q '^---$'; then
    body=$(awk 'NR==1{next} /^---$/ && NR>1 {found=1; next} found{print}' "$decisions")
  else
    body=$(cat "$decisions")
  fi

  local line
  while IFS= read -r line; do
    # Detect a new decision block heading: ## YYYY-MM-DD — ... or ## YYYY-MM-DD
    if [[ "$line" =~ ^##[[:space:]]+[0-9]{4}-[0-9]{2}-[0-9]{2} ]]; then
      # Save previous block if any
      if [[ -n "$block_title" ]]; then
        titles+=("$block_title")
        blocks+=("$block_lines")
      fi
      # Extract title: everything after "## YYYY-MM-DD — " (or just the date)
      local heading="${line#\#\# }"
      if [[ "$heading" =~ [[:space:]]—[[:space:]] ]]; then
        block_title="${heading#*— }"
      else
        block_title="$heading"
      fi
      block_lines=""
      continue
    fi

    # Skip the top-level "# Decisions" heading
    [[ "$line" =~ ^#[[:space:]] && -z "$block_title" ]] && continue

    # Accumulate body lines for the current block
    if [[ -n "$block_title" ]]; then
      block_lines+="${line}"$'\n'
    fi
  done <<< "$body"

  # Flush final block
  if [[ -n "$block_title" ]]; then
    titles+=("$block_title")
    blocks+=("$block_lines")
  fi

  local total=${#titles[@]}
  if [[ $total -eq 0 ]]; then
    die "decisions migrate: no '## YYYY-MM-DD' blocks found in $decisions — nothing to migrate"
  fi

  if $dry_run; then
    echo "── dry-run: would create $decisions_dir/ with $total entries ──"
    local i
    for ((i=0; i<total; i++)); do
      local dnum="D$((i+1))"
      echo "  would write: ${decisions_dir}/${dnum}.md  (${titles[$i]})"
    done
    echo ""
    echo "── dry-run: would rewrite $decisions as index ──"
    for ((i=0; i<total; i++)); do
      local dnum="D$((i+1))"
      echo "- **${dnum}** — ${titles[$i]}"
    done
    return 0
  fi

  # Write per-entry files (all before touching DECISIONS.md — no data loss on partial run)
  mkdir -p "$decisions_dir"
  local i
  for ((i=0; i<total; i++)); do
    local dnum="D$((i+1))"
    local entry_path="${decisions_dir}/${dnum}.md"
    local body="${blocks[$i]}"
    # Strip leading/trailing blank lines from body
    body=$(printf '%s' "$body" | sed -e '/./,$!d' -e 's/[[:space:]]*$//')
    printf '# %s — %s\n\n%s\n' "$dnum" "${titles[$i]}" "$body" > "$entry_path"
    created "$entry_path"
  done

  # Now rewrite DECISIONS.md as index
  {
    cat <<FM
---
type: decisions
doc: decisions
mode: index
updated: $TODAY
---

FM
    echo "# Decisions"
    echo ""
    for ((i=0; i<total; i++)); do
      local dnum="D$((i+1))"
      echo "- **${dnum}** — ${titles[$i]}"
    done
  } > "${decisions}.tmp.$$" && mv "${decisions}.tmp.$$" "$decisions"

  fm_touch "$decisions"
  info "  ✓  migrated $total decisions to index mode"
  info "  ↳  full entries in: $decisions_dir/"
  info "  ↳  index: $decisions"
}

# ── cmd_session: spectacular session start|end ──────────────────────────────
cmd_session() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    start) cmd_session_start "$@" ;;
    end)   cmd_session_end "$@" ;;
    ""|--help|-h)
      cat <<EOF
Usage: spectacular session <subcommand> [options]

Subcommands:
  start [--tag a,b]    Open a new session entry in .spectacular/sessions/
  end                  Close the currently-open session; recompute linked counts

At most one session can be open at a time.
EOF
      [[ -z "$sub" ]] && exit 1 || exit 0 ;;
    *) die "session: unknown subcommand '$sub'. Use: start | end" ;;
  esac
}

cmd_session_start() {
  local tags_csv="" dry_run=false notes=""
  while (( $# > 0 )); do
    case "$1" in
      --tag|--tags) require_value "--tag" "${2:-}"; tags_csv="$2"; shift 2 ;;
      --notes)      require_value "--notes" "${2:-}"; notes="$2"; shift 2 ;;
      --dry-run)    dry_run=true; shift ;;
      *) die "Unknown flag for session start: $1" ;;
    esac
  done

  [[ -d ".spectacular" ]] || die "session start: not inside a Spectacular workspace"

  local existing
  existing=$(_active_session_slug)
  if [[ -n "$existing" ]]; then
    die "session start: a session is already open ($existing). Run 'spectacular session end' first."
  fi

  local first_tag base_slug slug entry_dir entry_path
  first_tag=$(echo "$tags_csv" | cut -d',' -f1 | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')
  base_slug="${TODAY}-${first_tag:-work}"
  # Sanitize the tag part
  base_slug=$(echo "$base_slug" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9-]+/-/g; s/-+/-/g; s/-$//')
  entry_dir=".spectacular/sessions"
  mkdir -p "$entry_dir"
  slug=$(_resolve_slug_collision "$entry_dir" "$base_slug" "md")
  entry_path="$entry_dir/$slug.md"

  local tags_yaml="[]"
  [[ -n "$tags_csv" ]] && tags_yaml="[$(echo "$tags_csv" | sed 's/,/, /g')]"

  local start_ts summary
  start_ts=$(date +%Y-%m-%dT%H:%M:%S)
  summary="${notes:-Session $slug}"

  local template rendered
  template=$(_resolve_template "sessions/entry.md") || die_recover \
    "session start: template not found" \
    "Create .spectacular/sessions/<YYYY-MM-DD-slug>.md with frontmatter:" \
    "  type: session / status: open / started: $TODAY" \
    "then 'spectacular session end' will close it as usual."
  rendered=$(_render_template "$template" \
    START_DATE "$start_ts" \
    TAGS "$tags_yaml" \
    SUMMARY "$summary" \
    SLUG "$slug" \
    NOTES "${notes:-_(session in progress)_}")

  if $dry_run; then
    echo "── would write $entry_path ──"
    echo "$rendered"
    return 0
  fi

  echo "$rendered" > "$entry_path"
  created "$entry_path"
  _regen_sessions_index
  info "  ✓  SESSIONS.md regenerated"
  info "  → session open: $slug"
}

cmd_session_end() {
  local dry_run=false
  while (( $# > 0 )); do
    case "$1" in
      --dry-run) dry_run=true; shift ;;
      *) die "Unknown flag for session end: $1" ;;
    esac
  done

  [[ -d ".spectacular" ]] || die "session end: not inside a Spectacular workspace"

  local slug entry_path
  slug=$(_active_session_slug)
  [[ -z "$slug" ]] && die "session end: no open session found"
  entry_path=".spectacular/sessions/$slug.md"

  # Count linked decisions: scan flat DECISIONS.md for matching session reference
  # (v1.5.0 — flat decisions; folder shape lands in v1.6.x)
  local decisions_count=0
  if [[ -f ".spectacular/DECISIONS.md" ]]; then
    decisions_count=$(grep -c "\[\[sessions/$slug\]\]" .spectacular/DECISIONS.md || true)
  fi

  # Count linked memories: scan memory/*.md frontmatter for session: $slug
  local memories_count=0
  local mfile msession
  if [[ -d ".spectacular/memory" ]]; then
    for mfile in .spectacular/memory/*.md; do
      [[ -f "$mfile" ]] || continue
      msession=$(fm_get "$mfile" "session")
      [[ "$msession" == "$slug" ]] && memories_count=$((memories_count + 1))
    done
  fi

  local end_ts
  end_ts=$(date +%Y-%m-%dT%H:%M:%S)

  if $dry_run; then
    echo "── would close $entry_path ──"
    echo "   status: open → closed"
    echo "   end_date: $end_ts"
    echo "   decisions_count: $decisions_count"
    echo "   memories_count: $memories_count"
    return 0
  fi

  fm_set "$entry_path" "status" "closed"
  fm_set "$entry_path" "end_date" "$end_ts"
  fm_set "$entry_path" "decisions_count" "$decisions_count"
  fm_set "$entry_path" "memories_count" "$memories_count"

  # Append "Linked decisions" + "Linked memories" lists to the body.
  # grep pipelines are wrapped with `|| true` so empty matches don't trip pipefail.
  {
    echo ""
    echo "## Linked decisions"
    echo ""
    if [[ $decisions_count -gt 0 ]]; then
      # Scan DECISIONS.md for ADR blocks (## headers) containing the session
      # reference anywhere in their body, emit each matched title as a bullet.
      awk -v slug="$slug" '
        /^## / {
          if (matched && title != "") print "- " title
          title = $0
          sub(/^## /, "", title)
          matched = 0
          next
        }
        index($0, "[[sessions/" slug "]]") { matched = 1 }
        END { if (matched && title != "") print "- " title }
      ' .spectacular/DECISIONS.md
    else
      echo "_(none)_"
    fi
    echo ""
    echo "## Linked memories"
    echo ""
    if [[ $memories_count -gt 0 ]]; then
      for mfile in .spectacular/memory/*.md; do
        [[ -f "$mfile" ]] || continue
        msession=$(fm_get "$mfile" "session")
        [[ "$msession" == "$slug" ]] || continue
        echo "- [[memory/$(basename "$mfile" .md)]]"
      done
    else
      echo "_(none)_"
    fi
  } >> "$entry_path"

  _regen_sessions_index
  info "  ✓  session closed: $slug (${decisions_count} decisions, ${memories_count} memories)"
}

# Return 0 if file is a registered canonical doc (eligible for snapshot).
# Per ARCHITECTURE.md § Versioning + versioning.md.
is_canonical_doc() {
  local file="$1"
  local base
  base=$(basename "$file")
  case "$base" in
    PRD.md|SPEC.md|ARCHITECTURE.md|PRINCIPLES.md|ROADMAP.md|STACK.md|DECISIONS.md|AGENTS.md|config.yaml)
      [[ "$file" == ".spectacular/$base" ]] || [[ "$file" == "./.spectacular/$base" ]]
      ;;
    SPEC.md)
      # specs/<capability>/SPEC.md is also canonical
      [[ "$file" == .spectacular/specs/*/SPEC.md ]] || [[ "$file" == ./.spectacular/specs/*/SPEC.md ]]
      ;;
    *) return 1 ;;
  esac
}

# ── config.yaml parsers ───────────────────────────────────────────────────────
# Read workspace_schema: top-level key from .spectacular/config.yaml.
# Stdout: declared schema (e.g. "0.6"); defaults to "0.4" if field absent
# (that's the schema before the first registered migration).
config_workspace_schema() {
  local cfg=".spectacular/config.yaml"
  [[ -f "$cfg" ]] || { echo "0.4"; return 0; }
  local schema
  schema=$(awk -F: '
    /^workspace_schema:/ {
      val=$2
      gsub(/^[[:space:]]*"?/, "", val)
      gsub(/"?[[:space:]]*$/, "", val)
      print val
      exit
    }
  ' "$cfg")
  echo "${schema:-0.4}"
}

# ── feedback-loop (v1.6.0+) ──────────────────────────────────────────────────
# `spectacular feedback-loop <subverb> ...` — prototyping-mode human-feedback
# acquisition. NOT a benchmark/eval harness. See references/feedback-loop.md.
#
# Subverbs:
#   new <target>           Scaffold a new feedback entry (status: open)
#   list [--status <s>]    List entries (default: all)
#   resolve <slug>         Close an entry with a decision
#   archive <slug>         Move entry to .spectacular/archive/feedback/<year>/
#
# Hidden aliases (top-level dispatch routes them here): iterate, experiment,
# test, probe, try. Not documented in --help.
cmd_feedback_loop() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    new)     cmd_feedback_loop_new "$@" ;;
    list)    cmd_feedback_loop_list "$@" ;;
    resolve) cmd_feedback_loop_resolve "$@" ;;
    archive) cmd_feedback_loop_archive "$@" ;;
    ""|--help|-h)
      cat <<EOF
Usage: spectacular feedback-loop <subcommand> [options]

Subcommands:
  new <target>              Scaffold a feedback entry (status: open). Optional:
                              --request <slug>   Scope to a request
                              --scope <s>        skill|substrate|convention|doc-type|request
                              --proposal <text>  One-line proposal summary
  list [--status <s>]       List feedback entries (open|resolved|parked|all)
  resolve <slug>            Close entry. Options:
                              --next-action <a>  ship-as-is|new-request:<slug>|park|memory:<entry>
                              --promote-hint     Print the `spectacular remember` command to promote
  archive <slug>            Move entry to .spectacular/archive/feedback/<year>/

Feedback files live at:
  .spectacular/feedback/<YYYY-MM-DD>-<slug>.md          (system-level)
  .spectacular/requests/<slug>/feedback/<...>.md        (request-scoped, when --request used)

This is a prototyping-mode feedback loop — not a benchmark or verification pass.
See references/feedback-loop.md for the full mode spec.
EOF
      [[ -z "$sub" ]] && exit 1 || exit 0 ;;
    *) die "feedback-loop: unknown subcommand '$sub'. Use: new | list | resolve | archive" ;;
  esac
}

# Resolve the feedback directory for a given (optional) request slug
_feedback_dir() {
  local request="${1:-}"
  if [[ -n "$request" ]]; then
    echo ".spectacular/requests/$request/feedback"
  else
    echo ".spectacular/feedback"
  fi
}

# Walk all feedback locations and emit one path per line
_feedback_iter_all() {
  local f
  if [[ -d ".spectacular/feedback" ]]; then
    for f in .spectacular/feedback/*.md; do
      [[ -f "$f" ]] && echo "$f"
    done
  fi
  if [[ -d ".spectacular/requests" ]]; then
    local d
    for d in .spectacular/requests/*/feedback; do
      [[ -d "$d" ]] || continue
      for f in "$d"/*.md; do
        [[ -f "$f" ]] && echo "$f"
      done
    done
  fi
}

# Find a feedback entry by slug across all locations. Echoes path or empty.
_feedback_find() {
  local slug="$1" f
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if [[ "$(basename "$f" .md)" == "$slug" ]]; then
      echo "$f"
      return 0
    fi
  done < <(_feedback_iter_all)
  return 1
}

cmd_feedback_loop_new() {
  local target="" request="" scope="skill" proposal="" dry_run=false
  while (( $# > 0 )); do
    case "$1" in
      --request)  require_value "--request" "${2:-}"; request="$2"; shift 2 ;;
      --scope)    require_value "--scope" "${2:-}"; scope="$2"; shift 2 ;;
      --proposal) require_value "--proposal" "${2:-}"; proposal="$2"; shift 2 ;;
      --dry-run)  dry_run=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular feedback-loop new <target> [options]

Options:
  --request <slug>     Scope to a request (file lands under requests/<slug>/feedback/)
  --scope <s>          skill|substrate|convention|doc-type|request  (default: skill)
  --proposal <text>    One-line proposal summary (frontmatter)
  --dry-run            Print the rendered entry, don't write
EOF
        exit 0 ;;
      -*) die "Unknown flag for feedback-loop new: $1" ;;
      *)
        if [[ -z "$target" ]]; then target="$1"
        else target="$target $1"
        fi
        shift ;;
    esac
  done

  [[ -z "$target" ]] && die "feedback-loop new: <target> argument required"
  [[ -d ".spectacular" ]] || die "feedback-loop new: not inside a Spectacular workspace"

  if [[ -n "$request" ]]; then
    [[ -d ".spectacular/requests/$request" ]] || die "feedback-loop new: request '$request' not found"
  fi

  local valid_scopes="skill substrate convention doc-type request"
  in_list "$scope" "$valid_scopes" || die "feedback-loop new: invalid scope '$scope'. Use: $valid_scopes"

  local entry_dir base_slug slug entry_path
  entry_dir=$(_feedback_dir "$request")
  mkdir -p "$entry_dir"

  local target_slug
  target_slug=$(_slug_from_text "$target")
  [[ -z "$target_slug" ]] && die "feedback-loop new: could not derive slug from target"
  base_slug="${TODAY}-${target_slug}"
  slug=$(_resolve_slug_collision "$entry_dir" "$base_slug" "md")
  entry_path="$entry_dir/$slug.md"

  local request_yaml="null"
  [[ -n "$request" ]] && request_yaml="$request"

  local proposal_text="${proposal:-<one-line summary of the proposal shown to the user>}"

  local template rendered
  template=$(_resolve_template "feedback/entry.md") || die_recover \
    "feedback-loop new: feedback entry template not found" \
    "Create the entry under .spectacular/feedback/ by hand using an existing" \
    "entry as a shape reference, then re-run subsequent feedback-loop steps."
  rendered=$(_render_template "$template" \
    TARGET "$target" \
    SCOPE "$scope" \
    DATE "$TODAY" \
    PROPOSAL_SUMMARY "$proposal_text" \
    REQUEST "$request_yaml" \
    HUNCH "_(starting hypothesis — fill during loop)_" \
    PROPOSAL "_(scenario, variants, artifacts shown to user — fill during loop)_" \
    QUESTION "_(exact question put to user — fill during loop)_" \
    RESPONSE "_(verbatim or tight paraphrase — fill during loop)_" \
    INSIGHT "_(durable lesson — fill during loop)_" \
    DECISION "_(next_action explained — fill during loop)_")

  if $dry_run; then
    echo "── would write $entry_path ──"
    echo "$rendered"
    return 0
  fi

  echo "$rendered" > "$entry_path"
  created "$entry_path"
  info "  → status: open"
  [[ -n "$request" ]] && info "  → scoped to request: $request"
  info "  ↳ run the 5-step loop in /spectacular, then 'spectacular feedback-loop resolve $slug'"
}

cmd_feedback_loop_list() {
  local status_filter="all"
  while (( $# > 0 )); do
    case "$1" in
      --status) require_value "--status" "${2:-}"; status_filter="$2"; shift 2 ;;
      --help|-h)
        cat <<EOF
Usage: spectacular feedback-loop list [--status open|resolved|parked|all]

Lists all feedback entries across .spectacular/feedback/ and
.spectacular/requests/*/feedback/.
EOF
        exit 0 ;;
      *) die "Unknown flag for feedback-loop list: $1" ;;
    esac
  done

  [[ -d ".spectacular" ]] || die "feedback-loop list: not inside a Spectacular workspace"

  # Slug carries the date prefix; we drop the DATE column to avoid duplication.
  # Slugs over 32 chars truncate to 29 + "..." to keep columns aligned.
  local count=0 f status target request
  printf "%-32s  %-9s  %-10s  %s\n" "SLUG" "STATUS" "SCOPE" "TARGET"
  printf "%-32s  %-9s  %-10s  %s\n" "----" "------" "-----" "------"

  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    status=$(fm_get "$f" "status")
    [[ -z "$status" ]] && status="?"
    if [[ "$status_filter" != "all" && "$status" != "$status_filter" ]]; then
      continue
    fi
    target=$(fm_get "$f" "target")
    local scope_val
    scope_val=$(fm_get "$f" "scope")
    local slug slug_display
    slug=$(basename "$f" .md)
    if (( ${#slug} > 32 )); then
      slug_display="${slug:0:29}..."
    else
      slug_display="$slug"
    fi
    request=$(fm_get "$f" "request")
    local loc_marker=""
    [[ "$request" != "null" && -n "$request" ]] && loc_marker=" [req:$request]"
    printf "%-32s  %-9s  %-10s  %s%s\n" "$slug_display" "$status" "${scope_val:-?}" "${target:-?}" "$loc_marker"
    count=$((count + 1))
  done < <(_feedback_iter_all)

  if [[ $count -eq 0 ]]; then
    if [[ "$status_filter" == "all" ]]; then
      info "(no feedback entries yet — start one with 'spectacular feedback-loop new <target>')"
    else
      info "(no feedback entries with status: $status_filter)"
    fi
  fi
}

cmd_feedback_loop_resolve() {
  local slug="" next_action="" promote_hint=false
  while (( $# > 0 )); do
    case "$1" in
      --next-action) require_value "--next-action" "${2:-}"; next_action="$2"; shift 2 ;;
      --promote-hint) promote_hint=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular feedback-loop resolve <slug> [options]

Options:
  --next-action <a>    ship-as-is | new-request:<slug> | park | memory:<entry>
  --promote-hint       Print the `spectacular remember` command to promote this
                       resolution to memory. Does NOT auto-write — promotion is
                       a judgment call that requires user-confirmed text. Run
                       the printed command manually after confirming.
EOF
        exit 0 ;;
      -*) die "Unknown flag for feedback-loop resolve: $1" ;;
      *)
        [[ -n "$slug" ]] && die "feedback-loop resolve: only one <slug> argument allowed"
        slug="$1"; shift ;;
    esac
  done

  [[ -z "$slug" ]] && die "feedback-loop resolve: <slug> argument required"
  [[ -z "$next_action" ]] && die "feedback-loop resolve: --next-action required (ship-as-is | new-request:<slug> | park | memory:<entry>)
Resolving without an explicit decision leaves next_action: tbd — that's a smell.
Use 'feedback-loop list' to inspect, or set --next-action park to defer."
  [[ -d ".spectacular" ]] || die "feedback-loop resolve: not inside a Spectacular workspace"

  local entry_path
  entry_path=$(_feedback_find "$slug") || die "feedback-loop resolve: feedback entry '$slug' not found"

  local current_status
  current_status=$(fm_get "$entry_path" "status")
  [[ "$current_status" == "resolved" ]] && info "  ℹ already resolved — updating frontmatter anyway"

  fm_set "$entry_path" "status" "resolved"
  fm_set "$entry_path" "resolved" "$TODAY"
  fm_set "$entry_path" "next_action" "$next_action"

  created "$entry_path"
  info "  → status: resolved"
  info "  → next_action: $next_action"

  if $promote_hint; then
    info "  ↳ memory promotion: distill the preference and run:"
    info "      spectacular remember \"<preference>\" --tag feedback,$(fm_get "$entry_path" "scope")"
    info "      then: fm_set $entry_path promoted_to memory/<slug>.md"
    # We deliberately do NOT auto-write memory here — promotion requires explicit
    # user-confirmed text per the contract in PRINCIPLES.md § 9.
  fi
}

cmd_feedback_loop_archive() {
  local slug=""
  while (( $# > 0 )); do
    case "$1" in
      --help|-h)
        cat <<EOF
Usage: spectacular feedback-loop archive <slug>

Move a feedback entry to .spectacular/archive/feedback/<year>/<slug>.md.
Use when an entry is no longer actively relevant. Resolved entries do NOT
auto-archive — this is a manual curation verb.
EOF
        exit 0 ;;
      -*) die "Unknown flag for feedback-loop archive: $1" ;;
      *)
        [[ -n "$slug" ]] && die "feedback-loop archive: only one <slug> argument allowed"
        slug="$1"; shift ;;
    esac
  done

  [[ -z "$slug" ]] && die "feedback-loop archive: <slug> argument required"
  [[ -d ".spectacular" ]] || die "feedback-loop archive: not inside a Spectacular workspace"

  local src
  src=$(_feedback_find "$slug") || die "feedback-loop archive: feedback entry '$slug' not found"

  local year archive_dir target
  year=$(date +%Y)
  archive_dir=".spectacular/archive/feedback/$year"
  mkdir -p "$archive_dir"
  target="$archive_dir/$(basename "$src")"

  if [[ -e "$target" ]]; then
    die "feedback-loop archive: target already exists: $target"
  fi

  mv "$src" "$target"
  created "$target"
  info "  → archived from $src"
}

# ── idea (v1.7.0+) ───────────────────────────────────────────────────────────
# `spectacular idea new|list|promote <slug>`
# Thinking-scratchpad soft-folder DB. See references/idea-rules.md for spec.
cmd_idea() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    new)     cmd_idea_new "$@" ;;
    list)    cmd_idea_list "$@" ;;
    promote) cmd_idea_promote "$@" ;;
    ""|--help|-h)
      cat <<EOF
Usage: spectacular idea <subcommand> [options]

Subcommands:
  new <slug>                  Scaffold an idea entry at .spectacular/ideas/<slug>.md
                                (status: parked). Optional:
                                  --hypothesis <text>   One-line hypothesis
                                  --origin <text>       Where it came from
                                  --priority <level>    low|medium|high (default: medium)
  list [--status <s>]         List idea entries (parked|exploring|promoted|all)
  promote <slug>              Scaffold a request from the idea and move source
                                to archive/ideas/. Options:
                                  --request-slug <s>    Override request slug
                                                        (default: idea's slug)
                                  --target-version <v>  Target version for PLAN

Idea files live at:
  .spectacular/ideas/<slug>.md

Ideas are a thinking scratchpad — nothing in ideas/ is acted on automatically.
Promotion to a request is explicit and one-way. See references/idea-rules.md.
EOF
      [[ -z "$sub" ]] && exit 1 || exit 0 ;;
    *) die "idea: unknown subcommand '$sub'. Use: new | list | promote" ;;
  esac
}

# Walk all idea entries in .spectacular/ideas/*.md
_idea_iter_all() {
  local f
  [[ -d ".spectacular/ideas" ]] || return 0
  for f in .spectacular/ideas/*.md; do
    [[ -f "$f" ]] && echo "$f"
  done
}

# Find an idea by slug. Echoes path or empty.
_idea_find() {
  local slug="$1" f path
  path=".spectacular/ideas/$slug.md"
  [[ -f "$path" ]] && { echo "$path"; return 0; }
  return 1
}

cmd_idea_new() {
  local slug="" hypothesis="" origin="" priority="medium" dry_run=false
  while (( $# > 0 )); do
    case "$1" in
      --hypothesis) require_value "--hypothesis" "${2:-}"; hypothesis="$2"; shift 2 ;;
      --origin)     require_value "--origin"     "${2:-}"; origin="$2"; shift 2 ;;
      --priority)   require_value "--priority"   "${2:-}"; priority="$2"; shift 2 ;;
      --dry-run)    dry_run=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular idea new <slug> [options]

Options:
  --hypothesis <text>  One-line hypothesis (body of idea)
  --origin <text>      Free text — where the idea came from
  --priority <level>   low|medium|high (default: medium)
  --dry-run            Print the rendered entry, don't write
EOF
        exit 0 ;;
      -*) die "Unknown flag for idea new: $1" ;;
      *)
        [[ -n "$slug" ]] && die "idea new: only one <slug> argument allowed"
        slug="$1"; shift ;;
    esac
  done

  [[ -z "$slug" ]] && die "idea new: <slug> argument required"
  [[ -d ".spectacular" ]] || die "idea new: not inside a Spectacular workspace"

  # Validate slug shape (same as cmd_new)
  if [[ ! "$slug" =~ ^[a-z0-9][a-z0-9-]{0,63}$ ]]; then
    die "idea new: invalid slug '$slug'. Must be kebab-case, lowercase alnum + hyphens, max 64 chars."
  fi

  case "$priority" in
    low|medium|high) ;;
    *) die "idea new: invalid --priority '$priority'. Must be: low | medium | high" ;;
  esac

  local entries_dir=".spectacular/ideas"
  mkdir -p "$entries_dir"

  local entry_path="$entries_dir/$slug.md"
  [[ -e "$entry_path" ]] && die "idea new: '$slug' already exists at $entry_path"

  # Also refuse if already in archive (don't shadow promoted ideas)
  if [[ -f ".spectacular/archive/ideas/$slug.md" ]]; then
    die "idea new: '$slug' exists in archive (.spectacular/archive/ideas/$slug.md). Pick a different slug."
  fi

  local owner=""
  if [[ -f ".spectacular/config.yaml" ]]; then
    owner=$(awk '/^  owner:/ { sub(/^  owner:[[:space:]]*/, ""); print; exit }' .spectacular/config.yaml)
  fi
  [[ -z "$owner" ]] && owner="$(whoami 2>/dev/null || echo unknown)"

  local origin_text="${origin:-(captured)}"
  local hyp_text="${hypothesis:-_(fill in)_}"

  local template rendered
  template=$(_resolve_template "idea/base.md") || die_recover \
    "idea new: idea template not found" \
    "Create .spectacular/ideas/<slug>.md by hand with frontmatter:" \
    "  type: idea / status: exploring / owner: <you> / created: $TODAY" \
    "then add the idea body below the frontmatter."
  rendered=$(_render_template "$template" \
    OWNER "$owner" \
    ORIGIN "$origin_text" \
    DATE "$TODAY" \
    SLUG "$slug" \
    HYPOTHESIS "$hyp_text" \
    CONTEXT "_(fill in)_" \
    QUESTION "_(fill in)_")

  # Set priority via fm_set if not the default
  if $dry_run; then
    echo "── would write $entry_path ──"
    echo "$rendered"
    return 0
  fi

  echo "$rendered" > "$entry_path"
  if [[ "$priority" != "medium" ]]; then
    fm_set "$entry_path" "priority" "$priority"
  fi

  created "$entry_path"
  info "  → status: parked"
  info "  ↳ shape it with: spectacular idea grill $slug"
  info "  ↳ when ready: spectacular idea promote $slug"
}

cmd_idea_list() {
  local status_filter="all"
  while (( $# > 0 )); do
    case "$1" in
      --status) require_value "--status" "${2:-}"; status_filter="$2"; shift 2 ;;
      --help|-h)
        cat <<EOF
Usage: spectacular idea list [--status parked|exploring|promoted|all]

Lists all ideas in .spectacular/ideas/.
EOF
        exit 0 ;;
      *) die "Unknown flag for idea list: $1" ;;
    esac
  done

  [[ -d ".spectacular" ]] || die "idea list: not inside a Spectacular workspace"

  local count=0 f status updated priority slug slug_display
  printf "%-32s  %-10s  %-8s  %-10s  %s\n" "SLUG" "STATUS" "PRIORITY" "UPDATED" "ORIGIN"
  printf "%-32s  %-10s  %-8s  %-10s  %s\n" "----" "------" "--------" "-------" "------"

  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    status=$(fm_get "$f" "status")
    [[ -z "$status" ]] && status="?"
    if [[ "$status_filter" != "all" && "$status" != "$status_filter" ]]; then
      continue
    fi
    priority=$(fm_get "$f" "priority")
    updated=$(fm_get "$f" "updated")
    local origin
    origin=$(fm_get "$f" "origin")
    slug=$(basename "$f" .md)
    if (( ${#slug} > 32 )); then
      slug_display="${slug:0:29}..."
    else
      slug_display="$slug"
    fi
    printf "%-32s  %-10s  %-8s  %-10s  %s\n" "$slug_display" "$status" "${priority:-?}" "${updated:-?}" "${origin:-?}"
    count=$((count + 1))
  done < <(_idea_iter_all)

  if [[ $count -eq 0 ]]; then
    if [[ "$status_filter" == "all" ]]; then
      info "(no ideas yet — start one with 'spectacular idea new <slug>')"
    else
      info "(no ideas with status: $status_filter)"
    fi
  fi
}

cmd_idea_promote() {
  local slug="" request_slug="" target_version=""
  while (( $# > 0 )); do
    case "$1" in
      --request-slug)   require_value "--request-slug"   "${2:-}"; request_slug="$2"; shift 2 ;;
      --target-version) require_value "--target-version" "${2:-}"; target_version="$2"; shift 2 ;;
      --help|-h)
        cat <<EOF
Usage: spectacular idea promote <slug> [options]

Options:
  --request-slug <s>    Override request slug (default: idea's slug)
  --target-version <v>  Target version for PLAN frontmatter

Scaffolds a new request via 'spectacular new', then:
  - Sets the idea's status to 'promoted'
  - Sets the idea's promoted_to: requests/<slug>/
  - Moves the idea file to .spectacular/archive/ideas/<slug>.md
  - Notes the promotion source in the new PLAN.md

This action is one-way. Manual file moves required to revert.
EOF
        exit 0 ;;
      -*) die "Unknown flag for idea promote: $1" ;;
      *)
        [[ -n "$slug" ]] && die "idea promote: only one <slug> argument allowed"
        slug="$1"; shift ;;
    esac
  done

  [[ -z "$slug" ]] && die "idea promote: <slug> argument required"
  [[ -d ".spectacular" ]] || die "idea promote: not inside a Spectacular workspace"

  local idea_path
  idea_path=$(_idea_find "$slug") || die "idea promote: idea '$slug' not found in .spectacular/ideas/"

  [[ -z "$request_slug" ]] && request_slug="$slug"

  # Refuse if request slug already taken
  if [[ -d ".spectacular/requests/$request_slug" ]] || [[ -d ".spectacular/archive/$request_slug" ]]; then
    die "idea promote: request slug '$request_slug' already exists. Use --request-slug <other>."
  fi

  # Read idea metadata for the request scaffold
  local idea_origin idea_priority
  idea_origin=$(fm_get "$idea_path" "origin")
  idea_priority=$(fm_get "$idea_path" "priority")
  [[ -z "$idea_priority" ]] && idea_priority="medium"

  local summary="Promoted from ideas/$slug.md (origin: ${idea_origin:-captured})"

  # Scaffold the request
  local new_args=(--summary "$summary" --priority "$idea_priority")
  [[ -n "$target_version" ]] && new_args+=(--target-version "$target_version")
  cmd_new "${new_args[@]}" "$request_slug" || die "idea promote: 'spectacular new $request_slug' failed"

  # Append a promotion note to the new PLAN.md
  local new_plan=".spectacular/requests/$request_slug/PLAN.md"
  if [[ -f "$new_plan" ]]; then
    # Add a note section just below the title
    cat >> "$new_plan" <<EOF

---

> **Promoted from idea** \`ideas/$slug.md\` (now at \`archive/ideas/$slug.md\`).
> Idea body content is preserved in the archive — review for hypotheses, context, and open questions that should fold into the slots above.
EOF
  fi

  # Update idea frontmatter, then move
  fm_set "$idea_path" "status" "promoted"
  fm_set "$idea_path" "promoted_to" "requests/$request_slug/"
  fm_set "$idea_path" "updated" "$TODAY"

  local archive_dir=".spectacular/archive/ideas"
  mkdir -p "$archive_dir"
  local archived_path="$archive_dir/$slug.md"
  if [[ -e "$archived_path" ]]; then
    die "idea promote: archive target already exists: $archived_path (manual cleanup needed)"
  fi
  mv "$idea_path" "$archived_path"

  created ".spectacular/requests/$request_slug/"
  info "  → idea archived: $archived_path"
  info "  → status: promoted"
  info "  ↳ next: cd into the request and flesh out PLAN slots"
}

# ── vision / imagine (v1.15.0+) ──────────────────────────────────────────────
# `imagine` is the generative-first planning mode. The CLI does the MECHANICAL
# part: scaffold the vision/ soft-folder (spine + typed subfolders) and add
# fragment files. The skill does the AGENTIC part: render artifacts, run the
# react-on-parts loop, derive a draft PLAN. See references/vision-rules.md.

# Echo every fragment file under a request's vision/ subfolders.
_vision_iter_fragments() {
  local vdir="$1" kind f
  for kind in stories ui arch; do
    [[ -d "$vdir/$kind" ]] || continue
    for f in "$vdir/$kind"/*.md; do
      [[ -f "$f" ]] && echo "$f"
    done
  done
}

# Emit the manifest body lines for a vision/ folder (one per fragment, current
# state). Shared by _regen_vision_manifest (writer) and check_vision (drift).
_vision_manifest_lines() {
  local vdir="$1"
  local f kind caption approved subdir any=false
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    any=true
    kind=$(fm_get "$f" "kind")
    caption=$(fm_get "$f" "caption")
    approved=$(fm_get "$f" "approved")
    subdir=$(basename "$(dirname "$f")")
    [[ -z "$kind" ]] && kind="?"
    [[ -z "$caption" ]] && caption="$(basename "$f" .md)"
    [[ -z "$approved" ]] && approved="pending"
    printf -- '- `[%s]` %s — **%s** (`%s/%s`)\n' "$kind" "$caption" "$approved" "$subdir" "$(basename "$f")"
  done < <(_vision_iter_fragments "$vdir")
  $any || printf -- '_No fragments yet. Add one with `spectacular vision add <story|ui|arch> <name>`._\n'
}

# Regenerate the spine VISION.md ## Manifest section from fragment files.
# Rewrites only the manifest block (everything from '## Manifest' to EOF).
_regen_vision_manifest() {
  local vdir="$1"
  local spine="$vdir/VISION.md"
  [[ -f "$spine" ]] || return 0

  # Replace everything from the '## Manifest' heading onward.
  local head
  head=$(awk '/^## Manifest$/{exit} {print}' "$spine")
  {
    printf '%s\n' "$head"
    printf '## Manifest\n\n'
    _vision_manifest_lines "$vdir"
  } > "$spine"
}

# `spectacular imagine <slug>` — scaffold the vision/ folder for a request.
cmd_imagine() {
  local slug=""
  while (( $# > 0 )); do
    case "$1" in
      --help|-h)
        cat <<EOF
Usage: spectacular imagine <slug>

Scaffold the imagination-backed planning folder for an existing request:

  requests/<slug>/vision/
  ├── VISION.md      spine — narrative slots + regenerable manifest
  ├── stories/       one user story per file
  ├── ui/            one ASCII UI/output mockup per file
  └── arch/          one ASCII architecture sketch per file

This is the MECHANICAL scaffold only. The generative render (imagining the
artifacts), the react-on-parts loop, and the draft-PLAN derivation are skill
work — run /spectacular imagine <slug> inside your AI agent.

Add fragments with:  spectacular vision add <story|ui|arch> <name> --slug <slug>
EOF
        exit 0 ;;
      -*) die "Unknown flag for imagine: $1" ;;
      *)
        [[ -n "$slug" ]] && die "imagine: only one <slug> argument allowed"
        slug="$1"; shift ;;
    esac
  done

  [[ -z "$slug" ]] && die "imagine: <slug> argument required"
  [[ -d ".spectacular" ]] || die "imagine: not inside a Spectacular workspace"

  local req_dir=".spectacular/requests/$slug"
  [[ -d "$req_dir" ]] || die "imagine: request '$slug' not found at $req_dir. Create it first with 'spectacular new $slug'."

  local vdir="$req_dir/vision"
  if [[ -d "$vdir" ]]; then
    die "imagine: vision/ already exists at $vdir. Add fragments with 'spectacular vision add'."
  fi

  mkdir -p "$vdir/stories" "$vdir/ui" "$vdir/arch"

  local template rendered spine="$vdir/VISION.md"
  template=$(_resolve_template "vision/spine.md") || die_recover \
    "imagine: vision spine template not found" \
    "Create $spine by hand with a '## End goal', '## Macro dev phases'," \
    "'## Flow walk', and '## Manifest' section."
  rendered=$(_render_template "$template" SLUG "$slug" DATE "$TODAY")
  echo "$rendered" > "$spine"

  created "$vdir/"
  info "  → spine: $spine"
  info "  → fragment folders: stories/ ui/ arch/"
  info "  ↳ generative render is skill work: /spectacular imagine $slug"
  info "  ↳ or add a fragment manually: spectacular vision add ui <name> --slug $slug"
}

# `spectacular vision add <kind> <name> [--slug <slug>] [--caption <text>]`
cmd_vision() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    add) cmd_vision_add "$@" ;;
    --help|-h|"")
      cat <<EOF
Usage: spectacular vision <subcommand>

Subcommands:
  add <kind> <name>     Add a fragment file to a request's vision/ folder.
                          kind = story | ui | arch  (maps to the subfolder)
                          Options: --slug <request-slug>  --caption "<text>"

The vision/ folder is created by 'spectacular imagine <slug>'. Fragments are
ASCII artifacts the skill renders and the human reacts to (approved: frontmatter).
See references/vision-rules.md.
EOF
      [[ "$sub" == "" ]] && exit 1 || exit 0 ;;
    *) die "vision: unknown subcommand '$sub'. Use: add" ;;
  esac
}

cmd_vision_add() {
  local kind="" name="" slug="" caption=""
  while (( $# > 0 )); do
    case "$1" in
      --slug)      require_value "--slug" "${2:-}"; slug="$2"; shift 2 ;;
      --slug=*)    slug="${1#--slug=}"; shift ;;
      # --caption may be free text that legitimately starts with '-' (e.g. a flag
      # name mentioned in the caption). Accept the attached --caption=<text> form
      # to bypass the require_value '-*' guard; keep the spaced form for the common case.
      --caption)   require_value "--caption" "${2:-}"; caption="$2"; shift 2 ;;
      --caption=*) caption="${1#--caption=}"; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular vision add <kind> <name> [options]

  <kind>             story | ui | arch  (selects the subfolder)
  <name>             kebab-case fragment name (becomes <name>.md)

Options:
  --slug <slug>      Request slug (required unless cwd is inside the request)
  --caption "<text>" One-line caption for the spine manifest (default: name).
                     Use --caption="--foo ..." if the caption starts with a dash.

Writes requests/<slug>/vision/<kind>/<name>.md with approved: pending and
regenerates the spine manifest.
EOF
        exit 0 ;;
      -*) die "Unknown flag for vision add: $1" ;;
      *)
        if [[ -z "$kind" ]]; then kind="$1"
        elif [[ -z "$name" ]]; then name="$1"
        else die "vision add: unexpected argument '$1'"; fi
        shift ;;
    esac
  done

  [[ -z "$kind" ]] && die "vision add: <kind> required (story | ui | arch)"
  [[ -z "$name" ]] && die "vision add: <name> required"
  [[ -d ".spectacular" ]] || die "vision add: not inside a Spectacular workspace"

  local subdir tmpl_name
  case "$kind" in
    story) subdir="stories"; tmpl_name="story" ;;
    ui)    subdir="ui";      tmpl_name="ui" ;;
    arch)  subdir="arch";    tmpl_name="arch" ;;
    *) die "vision add: invalid kind '$kind'. Must be: story | ui | arch" ;;
  esac

  if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]{0,63}$ ]]; then
    die "vision add: invalid name '$name'. Must be kebab-case, lowercase alnum + hyphens, max 64 chars."
  fi

  # Resolve the request slug: explicit --slug, else infer from cwd if inside a request.
  if [[ -z "$slug" ]]; then
    die "vision add: --slug <request-slug> required."
  fi

  local vdir=".spectacular/requests/$slug/vision"
  [[ -d "$vdir" ]] || die "vision add: vision/ not found at $vdir. Run 'spectacular imagine $slug' first."

  local frag="$vdir/$subdir/$name.md"
  [[ -e "$frag" ]] && die "vision add: fragment already exists at $frag"

  [[ -z "$caption" ]] && caption="$name"

  local template rendered
  template=$(_resolve_template "vision/$tmpl_name.md") || die "vision add: template vision/$tmpl_name.md not found"
  rendered=$(_render_template "$template" NAME "$name" CAPTION "$caption" DATE "$TODAY")
  echo "$rendered" > "$frag"

  _regen_vision_manifest "$vdir"

  created "$frag"
  info "  → kind: $kind · approved: pending"
  info "  → spine manifest regenerated"
}

# ── archive ──────────────────────────────────────────────────────────────────
# ── read verbs (v1.8.0+) ─────────────────────────────────────────────────────
# Read-only listing + detail + workspace verbs. Collapse multi-step agent
# workflows into single deterministic CLI calls.
#
# Grammar:
#   plural noun       = list (requests, decisions, memories, sessions)
#   singular + slug   = detail (request <slug>, decision <slug>, memory <slug>)
#   show <doctype>    = dump canonical doc
#   summary           = workspace overview
#   progress <slug>   = milestone tick rate for a request
#   paths             = JSON path map
#
# Universal flags: --status, --since, --limit (default 20), --all, --json
# Detail verbs add: --full (bypass skim mode)

# Parse a duration string like "7d", "24h", "2w" → epoch threshold.
# Returns 0 (epoch start) if input is empty or unparseable.
_parse_since() {
  local input="$1"
  [[ -z "$input" ]] && { echo 0; return 0; }
  local num unit seconds
  if [[ "$input" =~ ^([0-9]+)([dhw])$ ]]; then
    num="${BASH_REMATCH[1]}"
    unit="${BASH_REMATCH[2]}"
    case "$unit" in
      h) seconds=$((num * 3600)) ;;
      d) seconds=$((num * 86400)) ;;
      w) seconds=$((num * 604800)) ;;
    esac
    echo $(( $(date +%s) - seconds ))
    return 0
  fi
  die "Invalid --since value: '$input'. Use Nh, Nd, or Nw (e.g. 24h, 7d, 2w)."
}

# Convert a YYYY-MM-DD date string to epoch. Returns 0 on parse failure.
_date_to_epoch() {
  local d="$1"
  [[ -z "$d" ]] && { echo 0; return 0; }
  date -j -f "%Y-%m-%d" "$d" "+%s" 2>/dev/null || echo 0
}

# Escape a string for JSON. Handles backslashes, quotes, newlines, tabs.
_json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\r'/\\r}"
  printf '%s' "$s"
}

# Iterate over all request directories. Emits one path per request (PLAN.md).
_request_iter_all() {
  local d
  [[ -d ".spectacular/requests" ]] || return 0
  for d in .spectacular/requests/*/; do
    [[ -d "$d" ]] || continue
    [[ -f "$d/PLAN.md" ]] && echo "$d/PLAN.md"
  done
}

# Iterate over all decision entries. Emits one path per entry.
_decision_iter_all() {
  local f
  if [[ -d ".spectacular/decisions" ]]; then
    for f in .spectacular/decisions/*.md; do
      [[ -f "$f" ]] && echo "$f"
    done
  fi
}

# Iterate over all memory entries.
_memory_iter_all() {
  local f
  [[ -d ".spectacular/memory" ]] || return 0
  for f in .spectacular/memory/*.md; do
    [[ -f "$f" ]] && echo "$f"
  done
}

# Iterate over all session entries.
_session_iter_all() {
  local f
  [[ -d ".spectacular/sessions" ]] || return 0
  for f in .spectacular/sessions/*.md; do
    [[ -f "$f" ]] && echo "$f"
  done
}

# ── cmd_requests (list) ──────────────────────────────────────────────────────
cmd_requests() {
  local status_filter="all" since="" limit=20 show_all=false json=false
  while (( $# > 0 )); do
    case "$1" in
      --status) require_value "--status" "${2:-}"; status_filter="$2"; shift 2 ;;
      --active) status_filter="active"; shift ;;
      --since)  require_value "--since" "${2:-}"; since="$2"; shift 2 ;;
      --limit)  require_value "--limit" "${2:-}"; limit="$2"; shift 2 ;;
      --all)    show_all=true; shift ;;
      --json)   json=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular requests [options]

List requests with their lifecycle state.

Options:
  --status <s>    planned | active | review | verified | all  (default: all)
  --active        Alias for --status active
  --since <dur>   Filter to requests updated within duration (e.g. 7d, 24h, 2w)
  --limit <n>     Cap output at n rows (default: 20)
  --all           No limit
  --json          JSON output (array of objects)

Examples:
  spectacular requests --active
  spectacular requests --status review --json
  spectacular requests --since 30d
EOF
        exit 0 ;;
      *) die "Unknown flag for requests: $1" ;;
    esac
  done

  [[ -d ".spectacular" ]] || die "requests: not inside a Spectacular workspace"
  [[ "$limit" =~ ^[0-9]+$ ]] || die "requests: --limit must be a positive integer"
  (( limit > 0 )) || die "requests: --limit must be > 0"

  local since_epoch
  since_epoch=$(_parse_since "$since")

  # Collect rows
  local rows=() count=0
  local f slug status priority updated target summary
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    slug=$(basename "$(dirname "$f")")
    status=$(fm_get "$f" "status")
    [[ -z "$status" ]] && status="?"
    if [[ "$status_filter" != "all" && "$status" != "$status_filter" ]]; then
      continue
    fi
    updated=$(fm_get "$f" "updated")
    if (( since_epoch > 0 )); then
      local upd_epoch
      upd_epoch=$(_date_to_epoch "$updated")
      (( upd_epoch < since_epoch )) && continue
    fi
    priority=$(fm_get "$f" "priority")
    target=$(fm_get "$f" "target_version")
    summary=$(fm_get "$f" "summary")
    rows+=("$slug|${status}|${priority:-?}|${target:-—}|${updated:-?}|${summary:-}")
    count=$((count + 1))
  done < <(_request_iter_all)

  # Apply limit unless --all
  local effective_limit=$count
  if ! $show_all && (( count > limit )); then
    effective_limit=$limit
  fi

  if $json; then
    printf '['
    local i=0
    for row in "${rows[@]:0:$effective_limit}"; do
      IFS='|' read -r slug status priority target updated summary <<< "$row"
      (( i > 0 )) && printf ','
      printf '{"slug":"%s","status":"%s","priority":"%s","target_version":"%s","updated":"%s","summary":"%s"}' \
        "$(_json_escape "$slug")" "$(_json_escape "$status")" "$(_json_escape "$priority")" \
        "$(_json_escape "$target")" "$(_json_escape "$updated")" "$(_json_escape "$summary")"
      i=$((i + 1))
    done
    printf ']\n'
    return 0
  fi

  if (( count == 0 )); then
