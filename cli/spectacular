DOC_FINDINGS=""

doc_add() {
  local area="$1" sev="$2" file="$3" msg="$4" fix="${5:-}" ftype="${6:-none}"
  DOC_FINDINGS+="${area}|${sev}|${file}|${msg}|${fix}|${ftype}"$'\n'
}

# ── usage block for doctor ────────────────────────────────────────────────────
doctor_usage() {
  cat <<EOF
Usage: spectacular doctor [<area>] [options]

Run substrate self-check on the current .spectacular/ workspace.

Areas (run all if omitted):
  skill         skill install + symlinks + skills.lock
  workspace     .spectacular/ directory + always-set + config.yaml
  frontmatter   required fields per canonical doc; schema versions
  snapshots     version-sequence continuity (PRD@v1.0 + v1.2 without v1.1)
  links         related: frontmatter targets exist
  lifecycle     request status vs required verification artifacts
  kits          bundled + project-local kit files parse cleanly
  conventions   active convention_pack resolves; gitignore drift in scaffold/enforce modes
  specs         SPEC.md present + parseable; specs/ dir present; legacy current/ migration; SPEC.md drift vs newest archive (v1.18.0+)
  docs          docs.yaml + frontmatter validation across the docs/ tree (v0.6.0+)
  personas      PERSONAS.md frontmatter + persona blocks + stories (v1.3.0+; opt-in)
  memory        MEMORY.md frontmatter + index ↔ entries drift (v1.5.0+; opt-in)
  sessions      SESSIONS.md frontmatter + open-session invariant + 4h stale warning (v1.5.0+; opt-in)
  feedback      feedback/ entries — frontmatter, stale-open (>30d), orphan back-refs (v1.6.0+)
  ideas         ideas/ entries — frontmatter, stale-exploring (>90d), orphan promoted (v1.7.0+)
  decisions     DECISIONS.md index-mode consistency — orphans, stale files, numbering gaps (v1.17.0+)

Options:
  --fix              Apply mechanical fixes (gitignore append, missing dirs,
                     dangling symlinks, missing always-set stubs). Judgment
                     fixes require the skill: /spectacular doctor --fix.
  --format text|json Report format (default: text). JSON suitable for the
                     skill or other tools to consume.
  -h, --help         Show this help

Exit codes: 0 clean, 1 warnings only, 2 errors present.

Examples:
  spectacular doctor
  spectacular doctor frontmatter
  spectacular doctor --fix
  spectacular doctor --format json > .spectacular/.doctor-report.json
EOF
}

doctor_parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fix) DOC_OPT_FIX=true; shift ;;
      --format) require_value "--format" "${2:-}"; DOC_OPT_FORMAT="$2"; shift 2 ;;
      -h|--help) doctor_usage; exit 0 ;;
      skill|workspace|frontmatter|snapshots|links|lifecycle|kits|conventions|specs|docs|personas|memory|sessions|feedback|ideas|policies|vision|decisions)
        if [[ -z "$DOC_OPT_AREA" ]]; then
          DOC_OPT_AREA="$1"
        else
          DOC_OPT_AREA="$DOC_OPT_AREA $1"
        fi
        shift ;;
      *) die "Unknown doctor option: $1. Run 'spectacular doctor --help'." ;;
    esac
  done

  if [[ "$DOC_OPT_FORMAT" != "text" && "$DOC_OPT_FORMAT" != "json" ]]; then
    die "--format must be 'text' or 'json'"
  fi
}

# ── area: skill ───────────────────────────────────────────────────────────────
check_skill() {
  local agents_dir claude_dir lock_ref
  agents_dir="$(agents_skill_dir)"
  claude_dir="$(claude_skill_dir)"

  # Install path
  if [[ -d "$agents_dir" || -L "$agents_dir" ]]; then
    doc_add "skill" "pass" "$agents_dir" "skill installed"
  else
    doc_add "skill" "error" "$agents_dir" "skill not installed at this path" \
      "re-run \`spectacular init\` (or \`spectacular init --update\`)" "judgment"
    return
  fi

  # Symlink validity. Only report a problem when .claude/ exists (user is
  # actively using Claude Code) but the symlink under it is missing/broken.
  # If .claude/ doesn't exist at all, the user isn't using Claude Code here
  # and there's nothing to fix.
  local claude_parent
  claude_parent=$(dirname "$claude_dir")
  if [[ -L "$claude_dir" ]]; then
    if [[ -e "$claude_dir" ]]; then
      doc_add "skill" "pass" "$claude_dir" "symlink resolves"
    else
      doc_add "skill" "error" "$claude_dir" "symlink is dangling (target missing)" \
        "recreate symlink to $agents_dir" "mechanical"
    fi
  elif [[ -d "$claude_parent" ]] && [[ ! -e "$claude_dir" ]]; then
    doc_add "skill" "warning" "$claude_dir" "no symlink found (claude dir exists but skill not symlinked here)" \
      "create symlink from $claude_dir to $agents_dir" "mechanical"
  fi

  # skills.lock present + parseable
  # If running in the spectacular source repo itself (where cli/spectacular lives),
  # missing skills.lock is expected — downgrade warning to info.
  local lock="$(pwd)/.spectacular/skills.lock"
  local is_source_repo=false
  if [[ -f "$(pwd)/cli/spectacular" && -d "$(pwd)/skills/spectacular" ]]; then
    is_source_repo=true
  fi
  if [[ -f "$lock" ]]; then
    if grep -q "^spectacular:" "$lock" 2>/dev/null || grep -q "ref:" "$lock" 2>/dev/null; then
      doc_add "skill" "pass" ".spectacular/skills.lock" "skills.lock present"
    else
      doc_add "skill" "warning" ".spectacular/skills.lock" "skills.lock present but no ref/version detected" "" "judgment"
    fi
  elif $is_source_repo; then
    doc_add "skill" "info" ".spectacular/skills.lock" "absent (this is the spectacular source repo — expected)"
  else
    doc_add "skill" "warning" ".spectacular/skills.lock" "missing (skill may not have been installed via CLI)" "" "judgment"
  fi

  # SKILL.md parseable
  local skill_md="$agents_dir/SKILL.md"
  if [[ -f "$skill_md" ]]; then
    if head -1 "$skill_md" | grep -q '^---$'; then
      doc_add "skill" "pass" "$skill_md" "SKILL.md frontmatter loads"
      # description length vs Codex's 1024-char cap. See scripts/check-skill-desc.sh
      # and .spectacular/decisions/D7.md — Codex measures `description` ALONE and
      # skips any skill over 1024. Claude Code's 1536 cap masks this, so a guard is
      # the only thing that catches it before a release ships.
      check_skill_desc_len "$skill_md"
    else
      doc_add "skill" "error" "$skill_md" "SKILL.md missing frontmatter delimiter" \
        "re-install the skill via \`spectacular init --update\`" "judgment"
    fi
  else
    doc_add "skill" "error" "$skill_md" "SKILL.md missing" \
      "re-install the skill via \`spectacular init --update\`" "judgment"
  fi
}

# Measure a SKILL.md `description` block (chars) and file a doctor finding.
# Thresholds: error > 1024 (Codex skips the skill), warning > 1000 (about to break).
# Kept in lock-step with scripts/check-skill-desc.sh (the pre-commit path).
check_skill_desc_len() {
  local skill_md="$1"
  local n
  n=$(awk '
    /^---$/ { fm = !fm; if (!fm && seen) exit; next }
    fm && /^description:[[:space:]]*\|[[:space:]]*$/ { in_desc=1; seen=1; next }
    fm && /^description:[[:space:]]*[^|[:space:]]/ {
      val = $0; sub(/^description:[[:space:]]*/, "", val); gsub(/^"|"$/, "", val)
      total += length(val); seen=1; exit
    }
    in_desc {
      if ($0 ~ /^[^[:space:]]/ || $0 ~ /^---$/) { exit }
      line = $0; sub(/^[[:space:]]+/, "", line)
      if (started) total += 1
      total += length(line); started=1
    }
    END { print total + 0 }
  ' "$skill_md")
  if (( n > 1024 )); then
    doc_add "skill" "error" "$skill_md" "description is $n chars — over Codex's 1024 cap (Codex will skip this skill)" \
      "trim the \`description\` frontmatter below 1024 chars" "judgment"
  elif (( n > 1000 )); then
    doc_add "skill" "warning" "$skill_md" "description is $n chars — $((1024 - n)) under the 1024 cap; trim soon" \
      "trim the \`description\` frontmatter to give more headroom" "judgment"
  else
    doc_add "skill" "pass" "$skill_md" "description length ok ($n chars, under 1024 Codex cap)"
  fi
}

# ── area: workspace ───────────────────────────────────────────────────────────
check_workspace() {
  if [[ ! -d ".spectacular" ]]; then
    doc_add "workspace" "error" ".spectacular/" "directory missing — workspace not initialized" \
      "run \`spectacular init\`" "judgment"
    return
  fi
  doc_add "workspace" "pass" ".spectacular/" "workspace directory present"

  # Always-set files (per smart-init's definition)
  # Determine which agents-file is in use by reading config.yaml first
  local agents_file="AGENTS.md"
  if [[ -f ".spectacular/config.yaml" ]]; then
    local cfg_agents
    cfg_agents=$(awk '/^  file:/ { print $2; exit }' ".spectacular/config.yaml" 2>/dev/null)
    [[ -n "$cfg_agents" ]] && agents_file="$cfg_agents"
  fi

  local always_set=("PRD.md" "SPEC.md" "config.yaml" "POLICY.md" "$agents_file")
  for f in "${always_set[@]}"; do
    if [[ -f ".spectacular/$f" ]]; then
      doc_add "workspace" "pass" ".spectacular/$f" "always-set file present"
    else
      doc_add "workspace" "error" ".spectacular/$f" "always-set file missing" \
        "re-scaffold via \`spectacular doctor --fix\` or \`spectacular init\`" "mechanical"
    fi
  done

  # Always-set directories
  for d in "requests" "specs"; do
    if [[ -d ".spectacular/$d" ]]; then
      doc_add "workspace" "pass" ".spectacular/$d/" "always-set directory present"
    else
      doc_add "workspace" "error" ".spectacular/$d/" "always-set directory missing" \
        "mkdir -p .spectacular/$d (mechanical fix available)" "mechanical"
    fi
  done

  # config.yaml parses + has project: stanza
  if [[ -f ".spectacular/config.yaml" ]]; then
    # Real YAML parse via Python if available (PyYAML is stdlib-adjacent; degrade if absent)
    local yaml_ok=true
    local yaml_err=""
    if command -v python3 >/dev/null 2>&1; then
      # Print only the YAMLError class name + message; drop traceback noise
      yaml_err=$(python3 -c '
import sys, yaml
try:
    yaml.safe_load(open(sys.argv[1]))
except yaml.YAMLError as e:
    msg = str(e).replace("\n", " ").strip()
    print(msg[:200])
    sys.exit(1)
' ".spectacular/config.yaml" 2>&1) || yaml_ok=false
    fi
    if ! $yaml_ok; then
      doc_add "workspace" "error" ".spectacular/config.yaml" "config.yaml is not valid YAML: ${yaml_err:-parse failed}" \
        "fix YAML syntax in config.yaml" "judgment"
    elif ! grep -q "^project:" ".spectacular/config.yaml" 2>/dev/null; then
      doc_add "workspace" "error" ".spectacular/config.yaml" "config.yaml missing project: stanza" \
        "rewrite config.yaml with project name/summary/kit" "judgment"
    else
      doc_add "workspace" "pass" ".spectacular/config.yaml" "config.yaml parses + has project: stanza"
    fi
  fi

  # .gitignore present + includes .spectacular.local/
  local gitignore=".gitignore"
  if [[ -f "$gitignore" ]]; then
    if grep -qF ".spectacular.local/" "$gitignore"; then
      doc_add "workspace" "pass" ".gitignore" ".spectacular.local/ ignored"
    else
      doc_add "workspace" "warning" ".gitignore" "missing .spectacular.local/ entry" \
        "append .spectacular.local/ to .gitignore" "mechanical"
    fi
  else
    doc_add "workspace" "warning" ".gitignore" ".gitignore not found; .spectacular.local/ unprotected" \
      "create .gitignore with .spectacular.local/" "mechanical"
  fi

  # v0.6+ scaffold suggestion: surface optional canonical files conventionally
  # added by `coding` / `product` kits. Single info line, listing whichever are
  # missing. Silent when all three are present. These files are opt-in — no
  # error, no warning, just discoverability for projects scaffolded against
  # older kits or that initialized with --kit blank.
  local missing_v06=()
  for v06_file in PRINCIPLES.md ARCHITECTURE.md ROADMAP.md; do
    [[ -f ".spectacular/$v06_file" ]] || missing_v06+=("${v06_file%.md}")
  done
  if (( ${#missing_v06[@]} > 0 )); then
    local v06_list with_arg
    v06_list=$(printf '%s, ' "${missing_v06[@]}" | sed 's/, $//')
    # Bash 3-compatible lowercase via tr (macOS default is bash 3.2)
    with_arg=$(printf '%s,' "${missing_v06[@]}" | sed 's/,$//' | tr '[:upper:]' '[:lower:]')
    doc_add "workspace" "info" ".spectacular/" \
      "v0.6+ conventional files missing: ${v06_list} (optional)" \
      "spectacular init --with ${with_arg}" "judgment"
  fi

  # v0.9+ ROADMAP shape detection: structured roadmaps have `**Phase:**` markers
  # and `**Scope (in):**` slots. Pre-v0.9 freeform roadmaps have only `**Status:**`
  # plus loose bullet lists. Surface as info — never error.
  local roadmap=".spectacular/ROADMAP.md"
  if [[ -f "$roadmap" ]]; then
    if grep -q "^## v" "$roadmap" 2>/dev/null && ! grep -q "^\*\*Phase:\*\*" "$roadmap" 2>/dev/null; then
      doc_add "workspace" "info" "$roadmap" \
        "ROADMAP uses pre-v0.7.1 freeform shape — structured grill available" \
        "spectacular roadmap grill (or: re-scaffold from templates/roadmap/base.md)" "judgment"
    fi
    # v0.10+ Icebox naming: convergent dev-tool idiom; flag pre-v0.7.2 'Bucket list'
    # heading when no Icebox heading is present yet. Mechanical fix = sed rename.
    if grep -q "^## Bucket list" "$roadmap" 2>/dev/null && ! grep -q "^## Icebox" "$roadmap" 2>/dev/null; then
      doc_add "workspace" "info" "$roadmap" \
        "ROADMAP uses pre-v0.7.2 'Bucket list' section name — convergent dev-tool idiom is 'Icebox'" \
        "rename: sed -i '' 's/^## Bucket list/## Icebox/' $roadmap" "mechanical"
    fi
  fi
}

# ── area: frontmatter ─────────────────────────────────────────────────────────
# For each canonical .md at .spectacular/ root, check it has frontmatter delimiters
# and required fields (version, updated, summary). Schema-version drift = warning.
check_frontmatter() {
  if [[ ! -d ".spectacular" ]]; then
    return
  fi

  local required_fields="version updated summary"
  shopt -s nullglob
  # Note: only scan .spectacular root, not archive/ (archive is read-only per architecture)
  for f in .spectacular/*.md; do
    local base
    base=$(basename "$f")

    # Skip snapshot files (handled by snapshots area)
    if [[ "$base" =~ @v ]]; then
      continue
    fi

    # Frontmatter delimiter check
    if ! head -1 "$f" | grep -q '^---$'; then
      doc_add "frontmatter" "error" "$f" "missing frontmatter delimiter (first line must be '---')" \
        "add proper frontmatter block" "judgment"
      continue
    fi

    # Extract frontmatter block (between first two ---)
    local fm
    fm=$(awk '/^---$/ { count++; if (count == 2) exit; next } count == 1' "$f")

    for field in $required_fields; do
      if ! echo "$fm" | grep -q "^${field}:"; then
        doc_add "frontmatter" "warning" "$f" "missing required field: ${field}" \
          "add \`${field}:\` to frontmatter" "judgment"
      fi
    done

    # ISO date check on updated:
    local updated_val
    updated_val=$(echo "$fm" | awk -F': ' '/^updated:/ { print $2; exit }' | tr -d '"' | tr -d "'")
    if [[ -n "$updated_val" ]] && ! [[ "$updated_val" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
      doc_add "frontmatter" "warning" "$f" "\`updated:\` not in ISO format (got: $updated_val)" \
        "use YYYY-MM-DD format" "judgment"
    fi
  done
  shopt -u nullglob
}

# ── area: snapshots ───────────────────────────────────────────────────────────
# v1.5.0+ canonical layout: .spectacular/snapshots/<DOC>/@v<N>.md
# Legacy layout (pre-v1.5): .spectacular/<DOC>@v<N>.md at root, alongside canonical
# Two checks:
#   1. Flag legacy root-level snapshots as warnings with --fix migration path
#   2. Detect version-sequence gaps in the new snapshots/ tree
check_snapshots() {
  if [[ ! -d ".spectacular" ]]; then
    return
  fi

  # ── 1. Legacy root-level snapshot detection (migration warning) ─────────────
  shopt -s nullglob
  local legacy=(.spectacular/*@v*.md)
  shopt -u nullglob
  if [[ ${#legacy[@]} -gt 0 ]]; then
    for s in "${legacy[@]}"; do
      local b doc_prefix ver_part target
      b=$(basename "$s")
      doc_prefix="${b%@v*}"
      ver_part="@v${b#*@v}"
      target=".spectacular/snapshots/${doc_prefix}/${ver_part}"
      doc_add "snapshots" "warning" "$s" \
        "legacy root-level snapshot (v1.5.0+ layout is snapshots/<DOC>/@v<N>.md)" \
        "spectacular doctor --fix snapshots  # moves to $target" \
        "mechanical"
    done
  fi

  # ── 2. New-layout gap detection ─────────────────────────────────────────────
  shopt -s nullglob
  local snapshots=(.spectacular/snapshots/**/@v*.md .spectacular/snapshots/*/@v*.md)
  shopt -u nullglob
  # Deduplicate (the two globs overlap on direct children).
  # Note: bash 3.2 + `set -u` errors on `"${arr[@]}"` for an empty array, so
  # guard expansions with the `${arr[@]+...}` idiom (expands to nothing if empty).
  local seen="" dedup=()
  for s in ${snapshots[@]+"${snapshots[@]}"}; do
    if ! in_list "$s" "$seen"; then
      seen+="$s "
      dedup+=("$s")
    fi
  done
  snapshots=(${dedup[@]+"${dedup[@]}"})

  if [[ ${#snapshots[@]} -eq 0 && ${#legacy[@]} -eq 0 ]]; then
    return  # No snapshots is fine — many workspaces have none yet
  fi

  # Collect unique doc paths (the snapshots/<...>/ container, identifies the doc).
  # Guarded expansion (bash 3.2 + set -u): snapshots may be empty when only
  # legacy root-level snapshots exist.
  local doc_dirs=""
  for s in ${snapshots[@]+"${snapshots[@]}"}; do
    local d
    d=$(dirname "$s")
    if ! in_list "$d" "$doc_dirs"; then
      doc_dirs+="$d "
    fi
  done

  # For each doc dir, collect versions and check continuity
  for doc_dir in $doc_dirs; do
    # Derive the doc-base name (last segment of doc_dir, used for error labeling)
    local base
    base=$(basename "$doc_dir")
    local versions=""
    for s in ${snapshots[@]+"${snapshots[@]}"}; do
      [[ "$(dirname "$s")" == "$doc_dir" ]] || continue
      local b
      b=$(basename "$s")
      # Extract X.Y from @vX.Y.md
      local ver="${b#@v}"
      ver="${ver%.md}"
      versions+="$ver "
    done

    # Parse major.minor pairs, sort, look for gaps in the minor sequence within
    # each major. Heuristic: if v<M>.<N1> and v<M>.<N3> exist but v<M>.<N2> is
    # missing for any 0 < N2 < max minor, flag the gap.
    local sorted
    sorted=$(echo "$versions" | tr ' ' '\n' | sort -t. -k1n -k2n | grep -v '^$' | tr '\n' ' ')

    # Build minor-version list per major
    local prev_major="" prev_minor=""
    for v in $sorted; do
      local major="${v%.*}"
      local minor="${v#*.}"
      if [[ "$major" == "$prev_major" ]]; then
        local expected=$((prev_minor + 1))
        while [[ $expected -lt $minor ]]; do
          local missing="${major}.${expected}"
          doc_add "snapshots" "warning" "${doc_dir}/@v${missing}.md" \
            "version-sequence gap (have v${prev_major}.${prev_minor} and v${major}.${minor})" \
            "backfill from git log if possible, or document the skip in DECISIONS.md" \
            "judgment"
          expected=$((expected + 1))
        done
      fi
      prev_major="$major"
      prev_minor="$minor"
    done

    if [[ -z "$sorted" ]]; then continue; fi
    doc_add "snapshots" "info" "${doc_dir}/@v*.md" \
      "$(echo "$sorted" | wc -w | tr -d ' ') snapshot(s) found for $base"
  done
}

# ── area: links ───────────────────────────────────────────────────────────────
# Walk every canonical .md, extract `related:` frontmatter entries, verify each
# target exists (resolved relative to the file's location).
check_links() {
  if [[ ! -d ".spectacular" ]]; then return; fi

  # Root-aware target resolution (v1.16.0+):
  # - Bare slug (no '/', no '.md') → resolve as request slug: requests/<slug>/PLAN.md
  #   or archive/<slug>/PLAN.md (archived = satisfied)
  # - Root doc name (PRD.md, ARCHITECTURE.md, etc.) → resolve at .spectacular/
  # - Anything with '/' → resolve relative to the file's own dir (legacy behaviour)
  local -a _root_docs=(PRD.md ARCHITECTURE.md ROADMAP.md PRINCIPLES.md AGENTS.md
                       STACK.md DECISIONS.md SPEC.md PERSONAS.md POLICY.md)

  _cl_resolve_target() {
    local target="$1" file="$2"
    # Bare slug: no slash, not ending in .md
    if [[ "$target" != */* ]] && [[ "$target" != *.md ]]; then
      # depends-on:/blocks: are always slugs; handle via _cl_check_slug below
      echo "slug:$target"
      return
    fi
    # Root doc (just a filename, matches known root doc names)
    for _rd in "${_root_docs[@]}"; do
      if [[ "$target" == "$_rd" ]]; then
        echo "file:.spectacular/$target"
        return
      fi
    done
    # Relative path → resolve from file's dir
    echo "file:$(dirname "$file")/$target"
  }

  _cl_check_slug() {
    local slug="$1" file="$2" field="$3"
    if [[ -f ".spectacular/requests/$slug/PLAN.md" ]]; then
      : # active request — valid
    elif [[ -f ".spectacular/archive/$slug/PLAN.md" ]]; then
      : # archived = satisfied — valid, not a warning
    else
      doc_add "links" "warning" "$file" \
        "$field: slug '$slug' not found in requests/ or archive/" \
        "remove the stale link or create the request" \
        "judgment"
    fi
  }

  shopt -s nullglob
  while IFS= read -r f; do
    [[ -f "$f" ]] || continue
    if [[ "$(basename "$f")" =~ @v ]]; then continue; fi
    if [[ "$f" == *".spectacular/archive/"* ]]; then continue; fi

    local in_fm=false cur_field=""
    while IFS= read -r line; do
      if [[ "$line" == "---" ]]; then
        if $in_fm; then break; else in_fm=true; continue; fi
      fi
      $in_fm || continue

      # Detect which list field we're in (related:, depends-on:, blocks:)
      if [[ "$line" =~ ^related: ]];    then cur_field="related";    continue; fi
      if [[ "$line" =~ ^depends-on: ]]; then cur_field="depends-on"; continue; fi
      if [[ "$line" =~ ^blocks: ]];     then cur_field="blocks";     continue; fi
      # Exit current field on next top-level key
      if [[ -n "$cur_field" ]] && [[ "$line" =~ ^[a-zA-Z] ]]; then cur_field=""; fi

      if [[ -n "$cur_field" ]] && [[ "$line" =~ ^[[:space:]]+-[[:space:]]+(.+)$ ]]; then
        local target="${BASH_REMATCH[1]}"
        target="${target%%#*}"
        target="${target%\"}"; target="${target#\"}"
        target="${target%\'}"; target="${target#\'}"
        target="$(echo "$target" | xargs)"
        [[ -z "$target" ]] && continue

        if [[ "$cur_field" == "depends-on" ]] || [[ "$cur_field" == "blocks" ]]; then
          # These fields only accept slugs
          _cl_check_slug "$target" "$f" "$cur_field"
        else
          # related: — root-aware resolution
          local resolved_spec
          resolved_spec=$(_cl_resolve_target "$target" "$f")
          case "$resolved_spec" in
            slug:*)
              _cl_check_slug "${resolved_spec#slug:}" "$f" "related"
              ;;
            file:*)
              local resolved="${resolved_spec#file:}"
              if [[ ! -e "$resolved" ]]; then
                doc_add "links" "warning" "$f" \
                  "related: target '$target' does not exist (resolved: $resolved)" \
                  "remove the stale link or fix the target" \
                  "judgment"
              fi
              ;;
          esac
        fi
      fi
    done < "$f"
  done < <(find ".spectacular" -type f -name "*.md")
  shopt -u nullglob

  if ! echo "$DOC_FINDINGS" | grep -q "^links|warning"; then
    doc_add "links" "pass" ".spectacular/" "all related:/depends-on:/blocks: targets resolve"
  fi
}

# ── area: lifecycle ───────────────────────────────────────────────────────────
# For each request, check status frontmatter against required artifacts.
check_lifecycle() {
  if [[ ! -d ".spectacular/requests" ]]; then return; fi

  shopt -s nullglob
  local request_dirs=(.spectacular/requests/*/)
  shopt -u nullglob

  if [[ ${#request_dirs[@]} -eq 0 ]]; then
    doc_add "lifecycle" "info" ".spectacular/requests/" "no requests yet"
    return
  fi

  local issues=0
  for d in "${request_dirs[@]}"; do
    local plan="$d/PLAN.md"
    local slug
    slug=$(basename "$d")

    if [[ ! -f "$plan" ]]; then
      doc_add "lifecycle" "warning" "$plan" "request '$slug' has no PLAN.md" "" "judgment"
      issues=$((issues + 1))
      continue
    fi

    local status
    status=$(awk -F': ' '/^---$/{c++; next} c==1 && /^status:/ { print $2; exit }' "$plan" | tr -d '"' | tr -d "'" | xargs)

    case "$status" in
      active)
        if [[ ! -f "$d/SESSION.md" ]]; then
          doc_add "lifecycle" "warning" "$d" "request '$slug' active without SESSION.md" \
            "create SESSION.md or move status back to planned" "judgment"
          issues=$((issues + 1))
        fi
        ;;
      review|verified)
        # Must have at least one verification artifact:
        # VERIFY.md OR TASKS.md with ### Verification section OR PLAN.md with ## Validation
        local has_verify=false
        if [[ -f "$d/VERIFY.md" ]]; then
          has_verify=true
          # When status=verified, VERIFY.md must have zero unchecked items
          if [[ "$status" == "verified" ]] && grep -qE '^- \[ \]' "$d/VERIFY.md"; then
            doc_add "lifecycle" "error" "$d/VERIFY.md" \
              "request '$slug' is verified but VERIFY.md has unchecked items" \
              "complete remaining items or move status back to review" \
              "judgment"
            issues=$((issues + 1))
          fi
        fi
        if ! $has_verify; then
          local has_tasks_verif=false
          [[ -f "$d/TASKS.md" ]] && grep -qE "^### Verification|^## Verification" "$d/TASKS.md" && has_tasks_verif=true
          local has_plan_valid=false
          # Per [[verification]], PLAN's validation may live under several heading names:
          # "Validation", "Success criteria", "Goals & success criteria", or "Acceptance"
          grep -qE "^## .*[Vv]alidation|^## .*[Ss]uccess criteria|^## .*[Aa]cceptance" "$plan" && has_plan_valid=true
          if ! $has_tasks_verif && ! $has_plan_valid; then
            doc_add "lifecycle" "error" "$d" \
              "request '$slug' is $status without any verification artifact (VERIFY.md / TASKS Verification / PLAN Validation)" \
              "add one of: VERIFY.md (2-of-6 rule), TASKS § Verification, or PLAN § Validation/Success criteria" \
              "judgment"
            issues=$((issues + 1))
          fi
        fi

        # Stale verified — info only
        if [[ "$status" == "verified" ]]; then
          local updated
          updated=$(awk -F': ' '/^---$/{c++; next} c==1 && /^updated:/ { print $2; exit }' "$plan" | tr -d '"' | tr -d "'" | xargs)
          if [[ -n "$updated" ]]; then
            local age_days
            age_days=$(( ( $(date +%s) - $(date -j -f "%Y-%m-%d" "$updated" +%s 2>/dev/null || echo 0) ) / 86400 ))
            if [[ $age_days -gt 7 && $age_days -lt 99999 ]]; then
              doc_add "lifecycle" "info" "$d" \
                "request '$slug' verified $age_days days ago — archive candidate" \
                "run \`spectacular archive $slug\`" \
                "judgment"
            fi
          fi
        fi
        ;;
      planned)
        : # No verification artifact required for planned
        ;;
      "")
        doc_add "lifecycle" "warning" "$plan" "request '$slug' has no status: field" "" "judgment"
        issues=$((issues + 1))
        ;;
    esac
  done

  if [[ $issues -eq 0 ]]; then
    doc_add "lifecycle" "pass" ".spectacular/requests/" "all requests have valid lifecycle state"
  fi
}

# ── area: kits ────────────────────────────────────────────────────────────────
check_kits() {
  local agents_dir
  agents_dir="$(agents_skill_dir)"
  local kits_dir="$agents_dir/templates/prd/kits"

  if [[ ! -d "$kits_dir" ]]; then
    doc_add "kits" "warning" "$kits_dir" "bundled kits directory missing" \
      "re-install skill via \`spectacular init --update\`" "judgment"
    return
  fi

  shopt -s nullglob
  local kit_files=("$kits_dir"/*.md)
  shopt -u nullglob

  local ok=0 bad=0
  for kit in "${kit_files[@]}"; do
    local name
    name=$(basename "$kit" .md)
    # Frontmatter present?
    if ! head -1 "$kit" | grep -q '^---$'; then
      doc_add "kits" "error" "$kit" "kit '$name' has no frontmatter" \
        "fix kit frontmatter or re-install skill" "judgment"
      bad=$((bad + 1))
      continue
    fi
    # extends: prd (only allowed value in v1)
    local extends_val
    extends_val=$(awk -F': ' '/^---$/{c++; next} c==1 && /^extends:/ { print $2; exit }' "$kit" | xargs)
    if [[ -n "$extends_val" && "$extends_val" != "prd" ]]; then
      doc_add "kits" "error" "$kit" "kit '$name' extends '$extends_val' (only 'prd' allowed in v1)" \
        "change to extends: prd or remove kit" "judgment"
      bad=$((bad + 1))
      continue
    fi
    # triggers-docs entries match KNOWN_DOCS
    local triggers
    triggers=$(kit_triggers_always "$name")
    triggers+=" $(kit_triggers_suggested "$name")"
    local kit_ok=true
    for doc in $triggers; do
      [[ -z "$doc" ]] && continue
      if ! in_list "$doc" "$KNOWN_DOCS"; then
        doc_add "kits" "warning" "$kit" "kit '$name' triggers-docs references unknown doc ID: '$doc'" \
          "remove or rename to a known doc ID: $KNOWN_DOCS" "judgment"
        kit_ok=false
      fi
    done
    if $kit_ok; then ok=$((ok + 1)); else bad=$((bad + 1)); fi
  done

  # Project-local kits override
  local local_kits=".spectacular/templates/prd/kits"
  if [[ -d "$local_kits" ]]; then
    shopt -s nullglob
    local local_files=("$local_kits"/*.md)
    shopt -u nullglob
    if [[ ${#local_files[@]} -gt 0 ]]; then
      doc_add "kits" "info" "$local_kits" "${#local_files[@]} project-local kit override(s) found"
    fi
  fi

  # PRD kit identity check
  if [[ -f ".spectacular/PRD.md" ]]; then
    local prd_kit
    prd_kit=$(awk -F': ' '/^---$/{c++; next} c==1 && /^kit:/ { print $2; exit }' .spectacular/PRD.md | xargs)
    if [[ -n "$prd_kit" ]]; then
      if [[ -f "$kits_dir/$prd_kit.md" ]] || [[ -f "$local_kits/$prd_kit.md" ]]; then
        doc_add "kits" "pass" ".spectacular/PRD.md" "declared kit '$prd_kit' is resolvable"
      else
        doc_add "kits" "error" ".spectacular/PRD.md" "declares kit '$prd_kit' but no matching kit file found" \
          "install missing kit or change PRD's kit: field" "judgment"
      fi
    fi
  fi

  if [[ $bad -eq 0 && $ok -gt 0 ]]; then
    doc_add "kits" "pass" "$kits_dir" "$ok bundled kits parse cleanly"
  fi

  # Migration chain validation (v0.6.2+)
  # Validates skill-internal registry under references/migrations/.
  # See: skills/spectacular/references/migrations-contract.md § Chain validation
  local mig_dir
  if mig_dir="$(migrations_dir 2>/dev/null)"; then
    check_migration_chain "$mig_dir"
  fi
}

# Validate the migration registry chain. Called from check_kits.
# Reports gaps, duplicates, broken apply-fn references, and id/filename drift.
check_migration_chain() {
  local mig_dir="$1"
  shopt -s nullglob
  local files=("$mig_dir"/v*.md)
  shopt -u nullglob

  if [[ ${#files[@]} -eq 0 ]]; then
    doc_add "kits" "info" "$mig_dir" "no migrations registered (registry is empty)"
    return 0
  fi

  # Build a sorted list of (from, to, id, mech, apply-fn, filename, path)
  local -a entries=()
  local f
  for f in "${files[@]}"; do
    local basename id from to mech applyfn rev
    basename=$(basename "$f" .md)
    id="$(migration_field "$f" "id")"
    from="$(migration_field "$f" "from")"
    to="$(migration_field "$f" "to")"
    mech="$(migration_field "$f" "mechanical")"
    applyfn="$(migration_field "$f" "apply-fn")"
    rev="$(migration_field "$f" "reversible")"

    # id must match filename
    if [[ "$id" != "$basename" ]]; then
      doc_add "kits" "warning" "$f" "migration id '$id' does not match filename '$basename'" \
        "rename file or update id: field" "judgment"
    fi
    # Required fields
    if [[ -z "$from" || -z "$to" ]]; then
      doc_add "kits" "error" "$f" "migration missing required from: or to: field" \
        "add from + to in frontmatter" "judgment"
      continue
    fi
    # Mechanical → apply-fn required + must be a defined bash function
    if [[ "$mech" == "true" ]]; then
      if [[ -z "$applyfn" ]]; then
        doc_add "kits" "error" "$f" "mechanical: true but apply-fn is empty" \
          "add apply-fn: <bash function name> or set mechanical: false" "judgment"
      elif ! declare -F "$applyfn" >/dev/null; then
        doc_add "kits" "error" "$f" "apply-fn '$applyfn' is not defined in cli/spectacular" \
          "define migration_apply_<id>() in cli/spectacular or fix apply-fn field" "judgment"
      fi
    fi
    # Reversible → reverse function must exist if declared
    if [[ "$rev" == "true" ]]; then
      local revfn="migration_revert_${id//-/_}"
      if ! declare -F "$revfn" >/dev/null; then
        doc_add "kits" "warning" "$f" "reversible: true but no reverse function '$revfn' defined" \
          "either define $revfn() or set reversible: false" "judgment"
      fi
    fi
    entries+=("${from}|${to}|${id}")
  done

  # Sort entries by from-version
  IFS=$'\n' read -r -d '' -a entries < <(printf '%s\n' "${entries[@]}" | sort -t'|' -V -k1,1; printf '\0')

  # Chain integrity: every from: must be either "0.4" (baseline) or match a previous to:.
  # Bash 3.2 compat: indexed-array tracking, linear search via in_list helper.
  local seen_to="0.4"          # space-separated list of reachable schema versions
  local seen_edges=""          # space-separated list of "from->to" pairs already seen
  local entry
  for entry in "${entries[@]}"; do
    IFS='|' read -r from to id <<< "$entry"
    local edge_key="${from}->${to}"
    if in_list "$edge_key" "$seen_edges"; then
      doc_add "kits" "error" "$mig_dir" "duplicate migration edge: ${edge_key} (multiple migrations declare from=${from} to=${to})" \
        "remove or merge duplicate migrations" "judgment"
    else
      seen_edges="$seen_edges $edge_key"
    fi
    if ! in_list "$from" "$seen_to"; then
      doc_add "kits" "error" "$mig_dir" "migration '${id}' has from: ${from} but no previous migration targets that version (chain gap)" \
        "add a migration whose to: is ${from}, or correct from: to a reachable version" "judgment"
    fi
    seen_to="$seen_to $to"
  done

  # Summary line on clean chain
  local chain_count=${#entries[@]}
  if [[ $chain_count -gt 0 ]]; then
    doc_add "kits" "pass" "$mig_dir" "migration chain validates (${chain_count} entries)"
  fi
}

# check_conventions — validates the active convention pack and (when mode=enforce)
# flags drift between project state and the pack's declared rules.
# Active only when .spectacular/config.yaml declares convention_pack:.
check_conventions() {
  local pack_src_name pack_mode
  pack_src_name="$(config_pack_source 2>/dev/null)"

  if [[ -z "$pack_src_name" ]]; then
    doc_add "conventions" "info" ".spectacular/config.yaml" "no convention_pack declared — skipped"
    return
  fi

  pack_mode="$(config_pack_mode)"

  # Detect unknown-mode drift: raw value present but doesn't match allow-list.
  # config_pack_mode silently fell back to suggest; surface the original here
  # so the user knows their value was ignored.
  local pack_mode_raw
  pack_mode_raw="$(config_pack_mode_raw)"
  if [[ -n "$pack_mode_raw" ]]; then
    case "$pack_mode_raw" in
      suggest|scaffold|enforce) ;;
      *)
        doc_add "conventions" "info" ".spectacular/config.yaml" \
          "unknown convention_pack.mode '$pack_mode_raw' (valid: suggest / scaffold / enforce) — falling back to 'suggest'" \
          "set mode to one of: suggest, scaffold, enforce" "judgment"
        ;;
    esac
  fi

  local pack_resolved
  if ! pack_resolved="$(pack_resolve "$pack_src_name")"; then
    doc_add "conventions" "error" ".spectacular/config.yaml" \
      "convention_pack source '$pack_src_name' not found in any scope" \
      "run 'spectacular pack install $pack_src_name' or change source in config.yaml" "judgment"
    return
  fi

  doc_add "conventions" "pass" "$pack_resolved" "active pack '$pack_src_name' ($pack_mode) resolves to $(pack_scope_of "$pack_resolved")"

  # In suggest mode, doctor only reports the pack is active; no drift checks
  if [[ "$pack_mode" == "suggest" ]]; then
    doc_add "conventions" "info" "$pack_resolved" "mode=suggest — drift checks are disabled (use scaffold or enforce)"
    return
  fi

  # In scaffold/enforce modes, check gitignore alignment
  local gitignore=".gitignore"
  if [[ ! -f "$gitignore" ]]; then
    doc_add "conventions" "warning" ".gitignore" "pack '$pack_src_name' declares gitignore.always-add but .gitignore is missing" \
      "create .gitignore (or run 'spectacular init' to scaffold)" "mechanical"
    return
  fi

  local missing=0 expected=0
  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    expected=$((expected + 1))
    if ! grep -qF -- "$entry" "$gitignore"; then
      local sev="warning"
      [[ "$pack_mode" == "enforce" ]] && sev="error"
      doc_add "conventions" "$sev" ".gitignore" \
        "pack '$pack_src_name' requires gitignore entry: '$entry' (missing)" \
        "append to .gitignore (or run 'spectacular init' to re-apply pack)" "mechanical"
      missing=$((missing + 1))
    fi
  done < <(pack_gitignore_always_add "$pack_resolved")

  if [[ $expected -gt 0 && $missing -eq 0 ]]; then
    doc_add "conventions" "pass" ".gitignore" "all $expected required gitignore entries from pack '$pack_src_name' present"
  fi
}

# ── area: specs ───────────────────────────────────────────────────────────────
# Validate the system-spec surface: SPEC.md index + specs/ dir + legacy current/ migration.
# Per-capability files under specs/<capability>/SPEC.md are optional (only for complex work).
check_specs() {
  [[ -d ".spectacular" ]] || return 0

  local spec_file=".spectacular/SPEC.md"
  local specs_dir=".spectacular/specs"
  local legacy_dir=".spectacular/current"

  # Conflict: both current/ and specs/ present → manual merge required
  if [[ -d "$legacy_dir" && -d "$specs_dir" ]]; then
    doc_add "specs" "error" "$legacy_dir" \
      "both .spectacular/current/ and .spectacular/specs/ exist — manual merge required (no auto-fix)" \
      "move contents of current/ into specs/, then 'rmdir .spectacular/current'" "judgment"
    return
  fi

  # Legacy: current/ present without specs/ → mechanical rename available
  if [[ -d "$legacy_dir" && ! -d "$specs_dir" ]]; then
    doc_add "specs" "warning" "$legacy_dir" \
      "legacy current/ folder found — rename to specs/ (current/ deprecated in v0.5.0)" \
      "mv .spectacular/current .spectacular/specs" "mechanical"
    return
  fi

  # specs/ dir present
  if [[ -d "$specs_dir" ]]; then
    doc_add "specs" "pass" "$specs_dir/" "specs/ directory present"
  else
    doc_add "specs" "error" "$specs_dir/" "specs/ directory missing" \
      "mkdir -p .spectacular/specs (mechanical fix available)" "mechanical"
  fi

  # SPEC.md present + parseable
  if [[ -f "$spec_file" ]]; then
    if head -1 "$spec_file" | grep -q '^---$'; then
      doc_add "specs" "pass" "$spec_file" "SPEC.md present with frontmatter"
    else
      doc_add "specs" "error" "$spec_file" "SPEC.md missing frontmatter delimiter" \
        "add proper frontmatter block" "judgment"
    fi
  else
    doc_add "specs" "error" "$spec_file" "SPEC.md missing" \
      "re-scaffold via 'spectacular doctor --fix' or 'spectacular init'" "mechanical"
  fi

  # Per-capability subfolders: optional; if present, each must hold a SPEC.md
  shopt -s nullglob
  for subdir in "$specs_dir"/*/; do
    local cap_spec="${subdir}SPEC.md"
    if [[ -f "$cap_spec" ]]; then
      if head -1 "$cap_spec" | grep -q '^---$'; then
        doc_add "specs" "pass" "$cap_spec" "capability spec present"
      else
        doc_add "specs" "warning" "$cap_spec" "capability spec missing frontmatter delimiter" \
          "add proper frontmatter block" "judgment"
      fi
    else
      doc_add "specs" "warning" "$subdir" "capability folder missing SPEC.md" \
        "create ${cap_spec} or remove the empty folder" "judgment"
    fi
  done

  # Flat contract docs (v0.6.1+): top-level .md files in specs/ are valid alongside
  # capability subfolders. Convention: kebab-case names (e.g. SCHEMA-TASK.md,
  # AXIS-MODEL.md), not "SPEC.md" (which lives one level up at .spectacular/).
  for contract_doc in "$specs_dir"/*.md; do
    local basename
    basename="$(basename "$contract_doc")"
    # SPEC.md doesn't belong at specs/ root (it's at .spectacular/SPEC.md). Flag it.
    if [[ "$basename" == "SPEC.md" ]]; then
      doc_add "specs" "warning" "$contract_doc" "SPEC.md belongs at .spectacular/SPEC.md, not under specs/" \
        "move to .spectacular/SPEC.md or rename if intended as a contract doc" "judgment"
      continue
    fi
    if head -1 "$contract_doc" 2>/dev/null | grep -q '^---$'; then
      doc_add "specs" "pass" "$contract_doc" "contract doc present (top-level .md in specs/)"
    else
      doc_add "specs" "warning" "$contract_doc" "contract doc missing frontmatter delimiter" \
        "add proper frontmatter block" "judgment"
    fi
  done

  # Drift: SPEC.md staler than the newest archived request → it likely missed a
  # spec-sync. ponytail: date heuristic, not a content diff — a request archived
  # without touching any capability false-positives, hence "may be stale".
  if [[ -f "$spec_file" ]] && head -1 "$spec_file" | grep -q '^---$'; then
    local spec_updated newest_arch="" newest_epoch=0 spec_epoch
    spec_updated=$(fm_get "$spec_file" "updated")
    spec_epoch=$(_date_to_epoch "$spec_updated")
    for arch_plan in .spectacular/archive/*/PLAN.md; do
      [[ -f "$arch_plan" ]] || continue
      local a_upd a_epoch
      a_upd=$(fm_get "$arch_plan" "updated")
      a_epoch=$(_date_to_epoch "$a_upd")
      if (( a_epoch > newest_epoch )); then
        newest_epoch=$a_epoch
        newest_arch="$(basename "$(dirname "$arch_plan")")"
      fi
    done
    if (( newest_epoch > 0 && spec_epoch > 0 && newest_epoch > spec_epoch )); then
      doc_add "specs" "warning" "$spec_file" \
        "SPEC.md (updated $spec_updated) may be stale — request '$newest_arch' archived more recently; run spec-sync to confirm it's reflected" \
        "review SPEC.md against archive/$newest_arch and update if a capability is missing" "judgment"
    fi
  fi

  shopt -u nullglob
}

# ── area: docs (slim discovery — v1.2.0+) ────────────────────────────────────
# Schema validation, frontmatter checks, orphan detection, and renderer config
# all moved to pageworks. Spectacular now reports only what it observes about
# docs/: folder presence, manifest presence, and whether pageworks is installed.
# Anyone needing the full validation surface should run `pageworks doctor`.
check_docs() {
  local docs_dir="docs"
  local manifest="${docs_dir}/docs.yaml"

  # No docs/ at all → skip silently (docs are opt-in)
  if [[ ! -d "$docs_dir" ]]; then
    return 0
  fi

  doc_add "docs" "pass" "$docs_dir" "docs/ folder present"

  # Manifest discovery — pageworks handles its absence as an init prompt.
  if [[ -f "$manifest" ]]; then
    doc_add "docs" "pass" "$manifest" "docs.yaml manifest present"
  else
    doc_add "docs" "info" "$manifest" "docs.yaml not found — run 'pageworks init' to scaffold one" \
      "pageworks owns docs/ schema and authoring" "judgment"
  fi

  # Pageworks install discovery — non-blocking; install hint only.
  if command -v pageworks >/dev/null 2>&1; then
    doc_add "docs" "pass" "pageworks" "pageworks CLI available — run 'pageworks doctor' for full validation"
  else
    doc_add "docs" "info" "pageworks" "pageworks not installed — public-doc validation moved to pageworks in v1.2.0" \
      "install: https://github.com/alexsmedile/pageworks" "judgment"
  fi
}

# ── area: personas (v1.3.0+ — opt-in) ────────────────────────────────────────
# PERSONAS.md is an opt-in canonical doc. Absent → skip with info. Present →
# validate frontmatter + at least one persona block + at least one story per
# persona. Never errors on absence.
check_personas() {
  [[ -d ".spectacular" ]] || return 0

  local pf=".spectacular/PERSONAS.md"

  if [[ ! -f "$pf" ]]; then
    doc_add "personas" "info" "$pf" "PERSONAS.md not scaffolded — opt-in via 'spectacular init --with personas' or product/content kits" \
      "skip" "judgment"
    return 0
  fi

  # Frontmatter present
  if head -1 "$pf" | grep -q '^---$'; then
    doc_add "personas" "pass" "$pf" "PERSONAS.md present with frontmatter"
  else
    doc_add "personas" "error" "$pf" "PERSONAS.md missing frontmatter delimiter" \
      "add proper frontmatter block" "judgment"
    return 0
  fi

  # Count persona blocks (lines starting with "## " in body, skipping placeholder).
  # Only the first two `---` lines are frontmatter delimiters; later `---` are
  # visual separators between persona blocks and must not toggle the fm state.
  local persona_count
  persona_count=$(awk '
    /^---$/ && fm_seen < 2 { fm = !fm; fm_seen++; next }
    !fm && /^## / && !/^## <Persona/ { count++ }
    END { print count + 0 }
  ' "$pf")

  if [[ "$persona_count" -eq 0 ]]; then
    doc_add "personas" "warning" "$pf" "PERSONAS.md has no filled persona blocks (only placeholders)" \
      "replace '## <Persona name>' placeholders with real persona blocks" "judgment"
    return 0
  fi

  doc_add "personas" "pass" "$pf" "${persona_count} persona block(s) found"

  # Soft warn: >5 personas
  if [[ "$persona_count" -gt 5 ]]; then
    doc_add "personas" "warning" "$pf" "${persona_count} personas — >5 typically signals decoration; consider merging or cutting" \
      "ask: would removing one change a build decision? if no, cut it" "judgment"
  fi

  # Per-persona story count: each persona block (## heading) must contain ≥1
  # story line ("- As ..."). Awk walks blocks and reports any block with zero.
  local empty_personas
  empty_personas=$(awk '
    /^---$/ && fm_seen < 2 { fm = !fm; fm_seen++; next }
    !fm && /^## / && !/^## <Persona/ {
      if (in_block && story_count_in_block == 0) {
        empty_names = empty_names ? empty_names ", " current : current
      }
      current = $0
      sub(/^## /, "", current)
      in_block = 1
      story_count_in_block = 0
      next
    }
    !fm && in_block && /^- As / { story_count_in_block++ }
    END {
      if (in_block && story_count_in_block == 0) {
        empty_names = empty_names ? empty_names ", " current : current
      }
      print empty_names
    }
  ' "$pf")

  local total_story_count
  total_story_count=$(grep -c '^- As ' "$pf" || true)

  if [[ -n "$empty_personas" ]]; then
    doc_add "personas" "warning" "$pf" "persona(s) without stories: ${empty_personas}" \
      "each persona needs ≥1 'As X, I want Y, so Z' story; persona without stories is decoration" "judgment"
  fi

  if [[ "$total_story_count" -gt 0 ]]; then
    doc_add "personas" "pass" "$pf" "${total_story_count} user story line(s) across ${persona_count} persona(s)"
  else
    doc_add "personas" "warning" "$pf" "no user stories found (expected 'As X, I want Y, so Z' format)" \
      "add stories to each persona" "judgment"
  fi
}

# ── check_memory (v1.5.0+) ───────────────────────────────────────────────────
# Soft-DB self-check: index ↔ entries drift, frontmatter shape.
check_memory() {
  [[ -d ".spectacular" ]] || return 0
  local idx=".spectacular/MEMORY.md" dir=".spectacular/memory"

  if [[ ! -f "$idx" ]] && [[ ! -d "$dir" ]]; then
    doc_add "memory" "info" "$idx" "MEMORY.md not scaffolded — opt-in via 'spectacular init --with memory' or coding kit" \
      "skip" "judgment"
    return 0
  fi

  if [[ ! -f "$idx" ]]; then
    doc_add "memory" "warning" "$idx" "memory/ directory exists but MEMORY.md index is missing" \
      "run 'spectacular remember \"...\"' to regenerate the index, or scaffold MEMORY.md manually" "judgment"
    return 0
  fi

  if head -1 "$idx" | grep -q '^---$'; then
    doc_add "memory" "pass" "$idx" "MEMORY.md present with frontmatter"
  else
    doc_add "memory" "warning" "$idx" "MEMORY.md missing frontmatter delimiter" \
      "add proper frontmatter block (type: index, doc: memory, updated: <date>)" "judgment"
  fi

  # Count entries
  local entry_count=0 file
  if [[ -d "$dir" ]]; then
    for file in "$dir"/*.md; do
      [[ -f "$file" ]] || continue
      entry_count=$((entry_count + 1))
    done
  fi

  if [[ $entry_count -eq 0 ]]; then
    doc_add "memory" "info" "$dir" "no memory entries yet"
    return 0
  fi

  # Detect index ↔ entries drift
  local index_links
  index_links=$(grep -oE '\[\[memory/[^]]+\]\]' "$idx" 2>/dev/null | sed 's/\[\[memory\///; s/\]\]//' | sort -u || true)
  local index_link_count
  index_link_count=$(echo "$index_links" | grep -c . || true)

  if [[ $entry_count -ne $index_link_count ]]; then
    doc_add "memory" "warning" "$idx" "drift: ${entry_count} entries on disk vs ${index_link_count} links in MEMORY.md" \
      "regenerate by writing or removing an entry — any 'spectacular remember' call rebuilds the index" "judgment"
  else
    doc_add "memory" "pass" "$dir" "${entry_count} memory entries; index ↔ entries in sync"
  fi

  # Staleness check (v1.16.0+): flag memory entries older than 180 days.
  # Memory holds durable facts; 180d is a conservative nudge to review and
  # prune obsolete entries before they mislead. Gradient: sessions 4h <
  # feedback 30d < ideas 90d < memory 180d.
  local _stale_count=0 _stale_slugs="" _now_epoch _entry_epoch _age_days _updated
  _now_epoch=$(date "+%s")
  if [[ -d "$dir" ]]; then
    for file in "$dir"/*.md; do
      [[ -f "$file" ]] || continue
      _updated=$(fm_get "$file" "updated" 2>/dev/null || true)
      [[ -z "$_updated" ]] && continue
      # Parse ISO date YYYY-MM-DD; skip if not that shape
      [[ "$_updated" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || continue
      _entry_epoch=$(date -j -f "%Y-%m-%d" "$_updated" "+%s" 2>/dev/null || echo 0)
      [[ "$_entry_epoch" -eq 0 ]] && continue
      _age_days=$(( (_now_epoch - _entry_epoch) / 86400 ))
      if [[ $_age_days -gt 180 ]]; then
        _stale_count=$((_stale_count + 1))
        local _mslug; _mslug=$(basename "$file" .md)
        _stale_slugs="${_stale_slugs:+$_stale_slugs, }$_mslug (${_age_days}d)"
      fi
    done
  fi
  if [[ $_stale_count -gt 0 ]]; then
    doc_add "memory" "warning" "$dir" \
      "${_stale_count} memory $([ $_stale_count -eq 1 ] && echo entry || echo entries) older than 180 days: ${_stale_slugs}" \
      "review and update or archive stale entries" "judgment"
  fi
}

# ── check_sessions (v1.5.0+) ─────────────────────────────────────────────────
# Soft-DB + lifecycle: at most one open, 4h stale-open warning.
check_sessions() {
  [[ -d ".spectacular" ]] || return 0
  local idx=".spectacular/SESSIONS.md" dir=".spectacular/sessions"

  if [[ ! -f "$idx" ]] && [[ ! -d "$dir" ]]; then
    doc_add "sessions" "info" "$idx" "SESSIONS.md not scaffolded — opt-in via 'spectacular init --with sessions' or coding kit" \
      "skip" "judgment"
    return 0
  fi

  if [[ ! -f "$idx" ]]; then
    doc_add "sessions" "warning" "$idx" "sessions/ directory exists but SESSIONS.md index is missing" \
      "run 'spectacular session start' to regenerate the index" "judgment"
    return 0
  fi

  if head -1 "$idx" | grep -q '^---$'; then
    doc_add "sessions" "pass" "$idx" "SESSIONS.md present with frontmatter"
  else
    doc_add "sessions" "warning" "$idx" "SESSIONS.md missing frontmatter delimiter" \
      "add proper frontmatter block (type: index, doc: sessions, updated: <date>)" "judgment"
  fi

  # Count entries + open sessions
  local entry_count=0 open_count=0 open_slugs="" stale_slugs="" file status start
  if [[ -d "$dir" ]]; then
    for file in "$dir"/*.md; do
      [[ -f "$file" ]] || continue
      entry_count=$((entry_count + 1))
      status=$(fm_get "$file" "status")
      if [[ "$status" == "open" ]]; then
        open_count=$((open_count + 1))
        local slug
        slug=$(basename "$file" .md)
        open_slugs="${open_slugs:+$open_slugs, }$slug"
        # 4h staleness check (per D7)
        start=$(fm_get "$file" "start_date")
        if [[ -n "$start" ]]; then
          local start_epoch now_epoch age_seconds
          start_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S" "$start" "+%s" 2>/dev/null || echo 0)
          now_epoch=$(date "+%s")
          age_seconds=$((now_epoch - start_epoch))
          if [[ $start_epoch -gt 0 ]] && [[ $age_seconds -gt 14400 ]]; then
            stale_slugs="${stale_slugs:+$stale_slugs, }$slug"
          fi
        fi
      fi
    done
  fi

  if [[ $entry_count -eq 0 ]]; then
    doc_add "sessions" "info" "$dir" "no session entries yet"
    return 0
  fi

  # Lifecycle invariant: ≤1 open
  if [[ $open_count -gt 1 ]]; then
    doc_add "sessions" "error" "$dir" "lifecycle violation: ${open_count} sessions open simultaneously ($open_slugs)" \
      "close all but one with 'spectacular session end' (manually edit the others if needed)" "judgment"
  elif [[ $open_count -eq 1 ]]; then
    doc_add "sessions" "info" "$dir" "1 session open: $open_slugs"
  fi

  # Stale-open warning (>4h)
  if [[ -n "$stale_slugs" ]]; then
    doc_add "sessions" "warning" "$dir" "open session(s) >4h old: $stale_slugs" \
      "close with 'spectacular session end' if work is done; otherwise --ignore-stale (TBD)" "judgment"
  fi

  # Drift check (entries vs index rows)
  local index_links
  index_links=$(grep -oE '\[\[sessions/[^]]+\]\]' "$idx" 2>/dev/null | sed 's/\[\[sessions\///; s/\]\]//' | sort -u || true)
  local index_link_count
  index_link_count=$(echo "$index_links" | grep -c . || true)

  if [[ $entry_count -ne $index_link_count ]]; then
    doc_add "sessions" "warning" "$idx" "drift: ${entry_count} entries on disk vs ${index_link_count} links in SESSIONS.md" \
      "regenerate by running any 'spectacular session start' or 'session end' — both rebuild the index" "judgment"
  else
    doc_add "sessions" "pass" "$dir" "${entry_count} session entries; index ↔ entries in sync"
  fi
}

# ── check_feedback (v1.6.0+) ─────────────────────────────────────────────────
# Judgment-only area (no --fix). Flags:
#   - open entries older than 30 days
#   - missing required frontmatter fields
#   - orphan back-refs (PLAN feedback: list mentions a missing file, or
#     entry's request: field points to a missing request)
check_feedback() {
  [[ -d ".spectacular" ]] || return 0

  local top_dir=".spectacular/feedback"
  local has_any=false

  if [[ -d "$top_dir" ]] || ls -d .spectacular/requests/*/feedback >/dev/null 2>&1; then
    has_any=true
  fi

  if ! $has_any; then
    doc_add "feedback" "info" ".spectacular/feedback/" "no feedback entries yet — start one with 'spectacular feedback-loop new <target>'" \
      "skip" "judgment"
    return 0
  fi

  local entry_count=0 open_count=0 stale_count=0 malformed_count=0 orphan_count=0
  local stale_slugs="" malformed_files="" orphan_files=""
  local now_epoch threshold_epoch
  now_epoch=$(date "+%s")
  # 30 days = 2592000 seconds
  threshold_epoch=$((now_epoch - 2592000))

  local f
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    entry_count=$((entry_count + 1))

    # Required fields
    local type_v status_v opened_v target_v request_v
    type_v=$(fm_get "$f" "type")
    status_v=$(fm_get "$f" "status")
    opened_v=$(fm_get "$f" "opened")
    target_v=$(fm_get "$f" "target")
    request_v=$(fm_get "$f" "request")

    if [[ "$type_v" != "feedback" ]] || [[ -z "$status_v" ]] || [[ -z "$opened_v" ]] || [[ -z "$target_v" ]]; then
      malformed_count=$((malformed_count + 1))
      malformed_files="${malformed_files:+$malformed_files, }$(basename "$f")"
      continue
    fi

    if [[ "$status_v" == "open" ]]; then
      open_count=$((open_count + 1))
      local opened_epoch
      opened_epoch=$(date -j -f "%Y-%m-%d" "$opened_v" "+%s" 2>/dev/null || echo 0)
      if [[ $opened_epoch -gt 0 && $opened_epoch -lt $threshold_epoch ]]; then
        stale_count=$((stale_count + 1))
        stale_slugs="${stale_slugs:+$stale_slugs, }$(basename "$f" .md)"
      fi
    fi

    # Orphan back-ref: request: field set but request folder missing
    if [[ -n "$request_v" && "$request_v" != "null" ]]; then
      if [[ ! -d ".spectacular/requests/$request_v" ]]; then
        orphan_count=$((orphan_count + 1))
        orphan_files="${orphan_files:+$orphan_files, }$(basename "$f" .md)→$request_v"
      fi
    fi
  done < <(_feedback_iter_all)

  if [[ $entry_count -eq 0 ]]; then
    doc_add "feedback" "info" "$top_dir" "no feedback entries yet"
    return 0
  fi

  doc_add "feedback" "pass" "$top_dir" "$entry_count feedback entries ($open_count open)"

  if [[ $malformed_count -gt 0 ]]; then
    doc_add "feedback" "warning" "$top_dir" "$malformed_count entries missing required frontmatter ($malformed_files)" \
      "ensure type, status, opened, and target fields are set; see references/feedback-rules.md" "judgment"
  fi

  if [[ $stale_count -gt 0 ]]; then
    doc_add "feedback" "warning" "$top_dir" "$stale_count open entries stale (>30 days): $stale_slugs" \
      "resolve with 'spectacular feedback-loop resolve <slug>' or mark parked" "judgment"
  fi

  if [[ $orphan_count -gt 0 ]]; then
    doc_add "feedback" "warning" "$top_dir" "$orphan_count entries reference a missing request: $orphan_files" \
      "unset request: field or restore the request folder" "judgment"
  fi
}

# ── check_ideas (v1.7.0+) ────────────────────────────────────────────────────
# Judgment-only — no --fix. Flags stale exploring, orphan promoted, malformed.
check_ideas() {
  [[ -d ".spectacular" ]] || return 0

  local top_dir=".spectacular/ideas"

  if [[ ! -d "$top_dir" ]]; then
    doc_add "ideas" "info" "$top_dir" "no ideas/ folder — opt-in via 'spectacular idea new <slug>'" \
      "skip" "judgment"
    return 0
  fi

  local entry_count=0 exploring_count=0 stale_count=0 malformed_count=0 orphan_count=0 unknown_status_count=0
  local stale_slugs="" malformed_files="" orphan_files="" unknown_files=""
  local now_epoch threshold_epoch
  now_epoch=$(date "+%s")
  # 90 days = 7776000 seconds
  threshold_epoch=$((now_epoch - 7776000))

  local f
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    entry_count=$((entry_count + 1))

    local type_v status_v updated_v
    type_v=$(fm_get "$f" "type")
    status_v=$(fm_get "$f" "status")
    updated_v=$(fm_get "$f" "updated")

    if [[ "$type_v" != "idea" ]] || [[ -z "$status_v" ]] || [[ -z "$updated_v" ]]; then
      malformed_count=$((malformed_count + 1))
      malformed_files="${malformed_files:+$malformed_files, }$(basename "$f")"
      continue
    fi

    case "$status_v" in
      parked) ;;
      exploring)
        exploring_count=$((exploring_count + 1))
        local updated_epoch
        updated_epoch=$(date -j -f "%Y-%m-%d" "$updated_v" "+%s" 2>/dev/null || echo 0)
        if [[ $updated_epoch -gt 0 && $updated_epoch -lt $threshold_epoch ]]; then
          stale_count=$((stale_count + 1))
          stale_slugs="${stale_slugs:+$stale_slugs, }$(basename "$f" .md)"
        fi
        ;;
      promoted)
        # Orphan: status: promoted but file is still in live ideas/ (should be in archive/ideas/)
        orphan_count=$((orphan_count + 1))
        orphan_files="${orphan_files:+$orphan_files, }$(basename "$f" .md)"
        ;;
      *)
        unknown_status_count=$((unknown_status_count + 1))
        unknown_files="${unknown_files:+$unknown_files, }$(basename "$f" .md)→$status_v"
        ;;
    esac
  done < <(_idea_iter_all)

  if [[ $entry_count -eq 0 ]]; then
    doc_add "ideas" "info" "$top_dir" "no ideas yet — start one with 'spectacular idea new <slug>'"
    return 0
  fi

  doc_add "ideas" "pass" "$top_dir" "$entry_count idea(s) ($exploring_count exploring)"

  if [[ $malformed_count -gt 0 ]]; then
    doc_add "ideas" "warning" "$top_dir" "$malformed_count entries missing required frontmatter ($malformed_files)" \
      "ensure type, status, updated fields are set; see references/idea-rules.md" "judgment"
  fi

  if [[ $stale_count -gt 0 ]]; then
    doc_add "ideas" "warning" "$top_dir" "$stale_count exploring idea(s) stale (>90 days): $stale_slugs" \
      "decide: promote, demote to parked, or delete" "judgment"
  fi

  if [[ $orphan_count -gt 0 ]]; then
    doc_add "ideas" "warning" "$top_dir" "$orphan_count promoted idea(s) still in ideas/ — should be in archive/ideas/ ($orphan_files)" \
      "move file to .spectacular/archive/ideas/ or rerun 'spectacular idea promote'" "judgment"
  fi

  if [[ $unknown_status_count -gt 0 ]]; then
    doc_add "ideas" "warning" "$top_dir" "$unknown_status_count entries with unknown status ($unknown_files)" \
      "use one of: parked | exploring | promoted" "judgment"
  fi
}

# ── check_vision (v1.15.0+) ──────────────────────────────────────────────────
# Validates each request's vision/ soft-folder: fragment frontmatter shape,
# kind-vs-subfolder match, dangling persona refs, manifest-vs-files drift, and
# approval progress. Mechanical --fix: regenerate the spine manifest.
check_vision() {
  [[ -d ".spectacular/requests" ]] || return 0

  local personas=".spectacular/PERSONAS.md"
  local req vdir found_any=false
  for req in .spectacular/requests/*/; do
    vdir="${req}vision"
    [[ -d "$vdir" ]] || continue
    found_any=true
    local slug; slug=$(basename "$req")

    if [[ ! -f "$vdir/VISION.md" ]]; then
      doc_add "vision" "warning" "$vdir" "vision/ has no VISION.md spine" \
        "rerun 'spectacular imagine $slug' or create vision/VISION.md" "judgment"
    fi

    local frag_count=0 malformed="" bad_kind="" dangling="" approved_count=0
    local f kind caption approved subdir
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      frag_count=$((frag_count + 1))
      kind=$(fm_get "$f" "kind")
      caption=$(fm_get "$f" "caption")
      approved=$(fm_get "$f" "approved")
      subdir=$(basename "$(dirname "$f")")

      if [[ -z "$kind" || -z "$caption" || -z "$approved" ]]; then
        malformed="${malformed:+$malformed, }$(basename "$f")"
        continue
      fi

      case "$kind" in
        story) [[ "$subdir" == "stories" ]] || bad_kind="${bad_kind:+$bad_kind, }$(basename "$f")(kind=$kind in $subdir/)" ;;
        ui)    [[ "$subdir" == "ui" ]]      || bad_kind="${bad_kind:+$bad_kind, }$(basename "$f")(kind=$kind in $subdir/)" ;;
        arch)  [[ "$subdir" == "arch" ]]    || bad_kind="${bad_kind:+$bad_kind, }$(basename "$f")(kind=$kind in $subdir/)" ;;
        *)     bad_kind="${bad_kind:+$bad_kind, }$(basename "$f")(kind=$kind)" ;;
      esac

      case "$approved" in
        true) approved_count=$((approved_count + 1)) ;;
      esac

      # Dangling persona refs (stories only)
      if [[ "$kind" == "story" && -f "$personas" ]]; then
        local plist; plist=$(fm_get "$f" "personas")
        # personas is a YAML inline list like [a, b]; strip brackets and split
        plist="${plist#[}"; plist="${plist%]}"
        local p
        local IFS_OLD="$IFS"; IFS=','
        for p in $plist; do
          p="${p#"${p%%[![:space:]]*}"}"; p="${p%"${p##*[![:space:]]}"}"
          [[ -z "$p" ]] && continue
          if ! grep -qi "$p" "$personas"; then
            dangling="${dangling:+$dangling, }$(basename "$f")→$p"
          fi
        done
        IFS="$IFS_OLD"
      fi
    done < <(_vision_iter_fragments "$vdir")

    doc_add "vision" "pass" "$vdir" "$frag_count fragment(s), $approved_count approved [$slug]"

    if [[ -n "$malformed" ]]; then
      doc_add "vision" "warning" "$vdir" "fragments missing kind/caption/approved: $malformed" \
        "fill the required frontmatter; see references/vision-rules.md" "judgment"
    fi
    if [[ -n "$bad_kind" ]]; then
      doc_add "vision" "warning" "$vdir" "kind does not match subfolder: $bad_kind" \
        "move the file to the matching subfolder, or fix its kind:" "judgment"
    fi
    if [[ -n "$dangling" ]]; then
      doc_add "vision" "warning" "$vdir" "story personas not found in PERSONAS.md: $dangling" \
        "add the persona to PERSONAS.md or correct the story's personas:" "judgment"
    fi

    # Manifest drift: compare the live manifest body to a freshly-computed one.
    # This catches missing/extra fragments AND stale approved-state/captions — the
    # manifest's whole job is to mirror current fragment state.
    if [[ -f "$vdir/VISION.md" && $frag_count -gt 0 ]]; then
      local live_manifest fresh_manifest
      live_manifest=$(awk 'f{print} /^## Manifest$/{f=1}' "$vdir/VISION.md" | awk 'BEGIN{s=0}/./{s=1}s{print}')
      fresh_manifest=$(_vision_manifest_lines "$vdir")
      if [[ "$live_manifest" != "$fresh_manifest" ]]; then
        doc_add "vision" "warning" "$vdir" "spine manifest out of date (fragment state changed)" \
          "regenerate the spine manifest" "mechanical"
      fi
    fi

    # Approval progress: active request but nothing reacted-to yet.
    local req_status; req_status=$(fm_get "${req}PLAN.md" "status")
    if [[ "$req_status" == "active" && $frag_count -gt 0 && $approved_count -eq 0 ]]; then
      doc_add "vision" "info" "$vdir" "request active but no fragment approved yet — vision not reacted-to" \
        "skip" "judgment"
    fi
  done

  if ! $found_any; then
    doc_add "vision" "info" ".spectacular/requests/" "no vision/ folders — opt-in via 'spectacular imagine <slug>'" \
      "skip" "judgment"
  fi
}

# ── check_policies (v1.12.0+) ────────────────────────────────────────────────
# Mechanical self-check of the practice layer: POLICY.md present + well-formed
# (every policy block has a check; severities are block|warn; hooks are from the
# known 8), plus the `understand-before-change` gate on any active request
# (PLAN § Understanding filled OR UNDERSTANDING.md present). Judgment checks are
# left to the skill's injection loop.
check_policies() {
  [[ -d ".spectacular" ]] || return 0
  local pol=".spectacular/POLICY.md"

  if [[ ! -f "$pol" ]]; then
    # check_workspace already emits the mechanical always-set finding that drives
    # --fix re-scaffolding; emit an info here (fix_type=skip) so the repair loop,
    # which matches on $file alone, doesn't re-scaffold POLICY.md twice.
    doc_add "policies" "info" "$pol" "POLICY.md missing — see the 'workspace' always-set finding (re-scaffolds via --fix)" \
      "skip" "judgment"
    return 0
  fi

  if head -1 "$pol" | grep -q '^---$'; then
    doc_add "policies" "pass" "$pol" "POLICY.md present with frontmatter"
  else
    doc_add "policies" "warning" "$pol" "POLICY.md missing frontmatter delimiter" \
      "add a frontmatter block (version, updated, summary)" "judgment"
  fi

  # Structure check: orphan hooks, missing checks, bad severities, dangling principle refs.
  local orphan_hooks="" missing_check="" bad_sev="" dangling_pr="" policy_count=0
  local cur_hook="" cur_id="" seen_check=false cur_is_block=false
  local pr=".spectacular/PRINCIPLES.md"
  local line
  while IFS= read -r line; do
    case "$line" in
      "## @"*)
        local h="${line#\#\# }"
        h="${h%"${h##*[![:space:]]}"}"
        if ! in_list "$h" "$POLICY_VALID_HOOKS"; then
          orphan_hooks="${orphan_hooks:+$orphan_hooks, }$h"
        fi
        cur_hook="$h"
        ;;
      "### "*)
        # close previous policy block — a `check:` is required only for blockers.
        if [[ -n "$cur_id" ]] && $cur_is_block && ! $seen_check; then
          missing_check="${missing_check:+$missing_check, }$cur_id"
        fi
        cur_id="${line#\#\#\# }"; cur_id="${cur_id%"${cur_id##*[![:space:]]}"}"
        policy_count=$((policy_count + 1))
        seen_check=false; cur_is_block=false
        ;;
      "- principle:"*)
        # Flag a principle ref that can't resolve (no PRINCIPLES.md, or no § N).
        local pn="${line#- principle:}"; pn="${pn//[[:space:]]/}"
        if [[ -n "$pn" ]]; then
          if [[ ! -f "$pr" ]] || ! grep -q "^##[[:space:]]\+${pn}\." "$pr" 2>/dev/null; then
            dangling_pr="${dangling_pr:+$dangling_pr, }${cur_id}→P${pn}"
          fi
        fi
        ;;
      "- check:"*) seen_check=true ;;
      "- severity:"*)
        local sv="${line#- severity:}"; sv="${sv#"${sv%%[![:space:]]*}"}"; sv="${sv%"${sv##*[![:space:]]}"}"
        case "$sv" in
          block) cur_is_block=true ;;
          warn)  ;;
          *) bad_sev="${bad_sev:+$bad_sev, }$cur_id=$sv" ;;
        esac
        ;;
    esac
  done < "$pol"
  # close the final block
  if [[ -n "$cur_id" ]] && $cur_is_block && ! $seen_check; then
    missing_check="${missing_check:+$missing_check, }$cur_id"
  fi

  if [[ $policy_count -eq 0 ]]; then
    doc_add "policies" "warning" "$pol" "POLICY.md has no policy blocks (### <id>)" \
      "re-scaffold via 'spectacular doctor --fix' to restore the 8 defaults" "mechanical"
  else
    doc_add "policies" "pass" "$pol" "$policy_count policy block(s) defined"
  fi
  [[ -n "$orphan_hooks" ]] && doc_add "policies" "warning" "$pol" \
    "unknown hook section(s): $orphan_hooks" "use one of: $POLICY_VALID_HOOKS" "judgment"
  [[ -n "$missing_check" ]] && doc_add "policies" "warning" "$pol" \
    "policy block(s) with no 'check:' field: $missing_check" "add a '- check:' line to each" "judgment"
  [[ -n "$bad_sev" ]] && doc_add "policies" "warning" "$pol" \
    "invalid severity value(s): $bad_sev" "severity must be 'block' or 'warn' (or omitted = non-blocking)" "judgment"
  # Dangling principle refs are info, not error — PRINCIPLES.md is optional.
  [[ -n "$dangling_pr" ]] && doc_add "policies" "info" "$pol" \
    "principle ref(s) with no matching PRINCIPLES.md section: $dangling_pr" \
    "scaffold PRINCIPLES.md (e.g. 'spectacular init --with principles') or drop the principle: tag" "judgment"

  # understand-before-change gate: any active request must have Understanding.
  # Mechanical presence-check; the skill enforces at the transition. Honor config:
  # skip the gate entirely when the policy is disabled in the merged contract.
  if _policy_enabled "understand-before-change"; then
    local reqs_dir=".spectacular/requests" plan slug status_v
    if [[ -d "$reqs_dir" ]]; then
      for plan in "$reqs_dir"/*/PLAN.md; do
        [[ -f "$plan" ]] || continue
        status_v="$(fm_get "$plan" "status")"
        [[ "$status_v" == "active" ]] || continue
        slug="$(basename "$(dirname "$plan")")"
        if _plan_understanding_filled "$plan"; then
          doc_add "policies" "pass" "$plan" "[$slug] active + Understanding present (understand-before-change satisfied)"
        else
          doc_add "policies" "warning" "$plan" \
            "[$slug] active but no filled '## Understanding' (or UNDERSTANDING.md) — understand-before-change unmet" \
            "fill PLAN § Understanding (How it works now / What changes / What stays the same) or add UNDERSTANDING.md" "judgment"
        fi
      done
    fi
  fi
}

# ── area: decisions ──────────────────────────────────────────────────────────
# v1.17.0: check DECISIONS.md index-mode consistency.
# Only runs when decisions/ folder exists (index mode). Flat mode: skip.
check_decisions() {
  [[ -d ".spectacular" ]] || return 0
  local decisions=".spectacular/DECISIONS.md"
  local decisions_dir=".spectacular/decisions"

  # Flat mode — skip. All checks are index-mode only.
  if [[ ! -d "$decisions_dir" ]]; then
    doc_add "decisions" "pass" "$decisions" "flat mode — no decisions/ folder (index checks skipped)"
    return 0
  fi

  # Check 1: mode consistency — DECISIONS.md must not contain prose blocks
  if [[ -f "$decisions" ]]; then
    if grep -q "^\*\*Context:\*\*\|^\*\*Decision:\*\*\|^\*\*Consequences:\*\*" "$decisions"; then
      doc_add "decisions" "warning" "$decisions" \
        "DECISIONS.md contains prose blocks but decisions/ folder exists — file is not a pure index" \
        "run 'spectacular decisions migrate' to convert the remaining prose to per-entry files" "judgment"
    else
      doc_add "decisions" "pass" "$decisions" "DECISIONS.md is index-only (no prose blocks)"
    fi
  else
    doc_add "decisions" "info" "$decisions" "DECISIONS.md missing (index-mode workspace has decisions/ but no root index)" \
      "run 'spectacular decide' to create the first entry — it will bootstrap the index" "judgment"
  fi

  # Collect index entries: lines matching "- **D<N>**"
  local -a index_nums=()
  if [[ -f "$decisions" ]]; then
    local line dnum
    while IFS= read -r line; do
      if [[ "$line" =~ ^\-[[:space:]]\*\*D([0-9]+)\*\* ]]; then
        index_nums+=("${BASH_REMATCH[1]}")
      fi
    done < "$decisions"
  fi

  # Collect file entries: D<N>.md in decisions/
  local -a file_nums=()
  local f num
  for f in "$decisions_dir"/D*.md; do
    [[ -f "$f" ]] || continue
    num=$(basename "$f" .md)
    num="${num#D}"
    [[ "$num" =~ ^[0-9]+$ ]] && file_nums+=("$num")
  done

  local idx_count=${#index_nums[@]}
  local file_count=${#file_nums[@]}

  # Check 2: no orphan index lines (index entry with no corresponding file)
  local orphans=""
  local n
  for n in "${index_nums[@]}"; do
    [[ -f "${decisions_dir}/D${n}.md" ]] || orphans="${orphans:+$orphans, }D${n}"
  done
  if [[ -n "$orphans" ]]; then
    doc_add "decisions" "warning" "$decisions_dir" \
      "orphan index line(s) with no file: $orphans" \
      "create the missing decisions/D<N>.md files or remove the stale index lines" "judgment"
  else
    (( idx_count > 0 )) && doc_add "decisions" "pass" "$decisions_dir" "all $idx_count index lines have a corresponding file"
  fi

  # Check 3: no stale files (file with no corresponding index line)
  local stale=""
  for n in "${file_nums[@]}"; do
    local found=false
    local idx_n
    for idx_n in "${index_nums[@]}"; do
      [[ "$n" == "$idx_n" ]] && found=true && break
    done
    $found || stale="${stale:+$stale, }D${n}"
  done
  if [[ -n "$stale" ]]; then
    doc_add "decisions" "warning" "$decisions_dir" \
      "stale file(s) with no index line: $stale" \
      "add a '- **D<N>** — Title — rationale' line to DECISIONS.md for each" "judgment"
  else
    (( file_count > 0 )) && doc_add "decisions" "pass" "$decisions_dir" "all $file_count per-entry files have a corresponding index line"
  fi

  # Check 4: numbering — sequential, no gaps, no duplicates
  if [[ $file_count -gt 0 ]]; then
    # Sort numerically
    local sorted_nums
    sorted_nums=$(printf '%s\n' "${file_nums[@]}" | sort -n)
    local prev=0 gap="" dup="" seen_list=""
    while IFS= read -r n; do
      # Duplicate check
      if [[ " $seen_list " == *" $n "* ]]; then
        dup="${dup:+$dup, }D${n}"
      fi
      seen_list="$seen_list $n"
      # Gap check
      if (( n > prev + 1 )); then
        local missing_start=$(( prev + 1 ))
        local missing_end=$(( n - 1 ))
        if (( missing_start == missing_end )); then
          gap="${gap:+$gap, }D${missing_start}"
        else
          gap="${gap:+$gap, }D${missing_start}-D${missing_end}"
        fi
      fi
      prev=$n
    done <<< "$sorted_nums"

    if [[ -n "$gap" ]]; then
      doc_add "decisions" "warning" "$decisions_dir" \
        "D-number gap(s) in decisions/: $gap" \
        "either create the missing files or renumber to close the gap" "judgment"
    fi
    if [[ -n "$dup" ]]; then
      doc_add "decisions" "error" "$decisions_dir" \
        "duplicate D-number(s) in decisions/: $dup" \
        "rename files to remove duplicates" "judgment"
    fi
    if [[ -z "$gap" && -z "$dup" ]]; then
      doc_add "decisions" "pass" "$decisions_dir" "D-numbers are sequential with no gaps or duplicates (1–${prev})"
    fi
  fi
}

# ── doctor orchestrator ───────────────────────────────────────────────────────
# Dispatch a list of area names to their check_<area> functions.
# Single source of truth — adding a new area only requires touching this one case.
run_areas() {
  for area in "$@"; do
    case "$area" in
      skill)       check_skill ;;
      workspace)   check_workspace ;;
      frontmatter) check_frontmatter ;;
      snapshots)   check_snapshots ;;
      links)       check_links ;;
      lifecycle)   check_lifecycle ;;
      kits)        check_kits ;;
      conventions) check_conventions ;;
      specs)       check_specs ;;
      docs)        check_docs ;;
      personas)    check_personas ;;
      memory)      check_memory ;;
      sessions)    check_sessions ;;
      feedback)    check_feedback ;;
      ideas)       check_ideas ;;
      policies)    check_policies ;;
      vision)      check_vision ;;
      decisions)   check_decisions ;;
      *)           die "Unknown doctor area: '$area'" ;;
    esac
  done
}

doctor() {
  doctor_parse_args "$@"

  DOC_FINDINGS=""

  local areas_to_run
  if [[ -n "$DOC_OPT_AREA" ]]; then
    areas_to_run="$DOC_OPT_AREA"
  else
    areas_to_run="$DOC_AREAS"
  fi

  run_areas $areas_to_run

  # Apply mechanical fixes if --fix flag set
  if $DOC_OPT_FIX; then
    doctor_apply_mechanical_fixes
    # Re-run detection to refresh state
    DOC_FINDINGS=""
    run_areas $areas_to_run
  fi

  if [[ "$DOC_OPT_FORMAT" == "json" ]]; then
    doctor_emit_json
  else
    doctor_emit_text
  fi

  # Exit code
  if echo "$DOC_FINDINGS" | grep -q "|error|"; then
    exit 2
  elif echo "$DOC_FINDINGS" | grep -q "|warning|"; then
    exit 1
  fi
  exit 0
}

doctor_apply_mechanical_fixes() {
  local applied=0
  while IFS='|' read -r area sev file msg fix ftype; do
    [[ "$ftype" == "mechanical" ]] || continue
    case "$file" in
      *.gitignore*) ;;  # handled below
    esac

    # Docs frontmatter stub injection (from check_docs)
    # Either missing delimiter OR missing required field.
    if [[ "$area" == "docs" && "$file" == docs/*.md ]]; then
      if [[ "$msg" == *"missing frontmatter delimiter"* ]]; then
        # Prepend a minimal stub; don't try to infer title from H1, leave that to the user
        if [[ -f "$file" ]] && ! head -1 "$file" | grep -q '^---$'; then
          local section_id
          section_id="$(basename "$(dirname "$file")")"
          [[ "$section_id" == "docs" ]] && section_id=""
          local slug
          slug="$(basename "$file" .md)"
          local tmp="${file}.tmp.$$"
          {
            echo "---"
            echo "title: ${slug}"
            echo "description: TODO — one-sentence description"
            echo "section: ${section_id}"
            echo "status: draft"
            echo "updated: ${TODAY}"
            echo "---"
            echo ""
            cat "$file"
          } > "$tmp" && mv "$tmp" "$file"
          echo "  ✓ fixed [docs]: injected frontmatter stub into $file"
          applied=$((applied + 1))
        fi
        continue
      fi
      if [[ "$msg" == *"missing required frontmatter field:"* ]]; then
        # Extract the field name from the message
        local field
        field=$(echo "$msg" | sed -n 's/.*missing required frontmatter field: \([a-z]*\).*/\1/p')
        if [[ -n "$field" && -f "$file" ]]; then
          # Insert "<field>: TODO" after the opening --- line (right at top of frontmatter)
          # Skip if field somehow already present
          local fm
          fm=$(awk '/^---$/ { count++; if (count == 2) exit; next } count == 1' "$file")
          if ! echo "$fm" | grep -qE "^${field}:"; then
            local default_val="TODO"
            [[ "$field" == "status" ]] && default_val="draft"
            [[ "$field" == "updated" ]] && default_val="$TODAY"
            local tmp="${file}.tmp.$$"
            awk -v field="$field" -v val="$default_val" '
              BEGIN { inserted=0; count=0 }
              /^---$/ { count++; print; if (count == 1 && !inserted) { print field ": " val; inserted=1 }; next }
              { print }
            ' "$file" > "$tmp" && mv "$tmp" "$file"
            echo "  ✓ fixed [docs]: injected '${field}: ${default_val}' into $file"
            applied=$((applied + 1))
          fi
        fi
        continue
      fi
    fi

    # Pack-driven gitignore drift (from check_conventions in scaffold/enforce modes)
    # Findings have area=conventions and msg containing "requires gitignore entry: 'X'"
    if [[ "$area" == "conventions" && "$msg" == *"gitignore entry:"* ]]; then
      # Extract the entry between single quotes: ...entry: 'X' (...
      local entry
      entry=$(echo "$msg" | sed -n "s/.*gitignore entry: '\([^']*\)'.*/\1/p")
      if [[ -n "$entry" ]]; then
        [[ -f ".gitignore" ]] || touch .gitignore
        if ! grep -qF -- "$entry" .gitignore; then
          echo "$entry" >> .gitignore
          echo "  ✓ fixed [conventions]: appended $entry to .gitignore"
          applied=$((applied + 1))
        fi
      fi
      continue
    fi

    # Vision spine manifest drift (from check_vision)
    if [[ "$area" == "vision" && "$msg" == *"spine manifest out of date"* ]]; then
      # $file is the vision/ dir
      if [[ -d "$file" ]]; then
        _regen_vision_manifest "$file"
        echo "  ✓ fixed [vision]: regenerated spine manifest in $file"
        applied=$((applied + 1))
      fi
      continue
    fi

    # gitignore append (workspace area — .spectacular.local/ baseline)
    if [[ "$file" == ".gitignore"* || "$msg" == *".gitignore"* ]]; then
      if [[ -f ".gitignore" ]]; then
        if ! grep -qF ".spectacular.local/" .gitignore; then
          echo ".spectacular.local/" >> .gitignore
          echo "  ✓ fixed [gitignore]: appended .spectacular.local/"
          applied=$((applied + 1))
        fi
      else
        echo ".spectacular.local/" > .gitignore
        echo "  ✓ fixed [gitignore]: created with .spectacular.local/"
        applied=$((applied + 1))
      fi
      continue
    fi

    # Missing dir
    if [[ "$file" == ".spectacular/requests/" || "$file" == ".spectacular/specs/" ]]; then
      mkdir -p "$file"
      [[ "$file" == ".spectacular/specs/" ]] && touch "${file}.gitkeep"
      echo "  ✓ fixed [workspace]: created $file"
      applied=$((applied + 1))
      continue
    fi

    # Legacy current/ → specs/ migration (specs area, mechanical)
    if [[ "$area" == "specs" && "$msg" == *"legacy current/ folder"* ]]; then
      if [[ -d ".spectacular/current" && ! -d ".spectacular/specs" ]]; then
        mv .spectacular/current .spectacular/specs
        echo "  ✓ fixed [specs]: renamed .spectacular/current/ → .spectacular/specs/"
        applied=$((applied + 1))
      fi
      continue
    fi

    # Legacy snapshot migration (snapshots area, mechanical)
    # Pattern: .spectacular/<DOC>@v<N>.md → .spectacular/snapshots/<DOC>/@v<N>.md
    if [[ "$area" == "snapshots" && "$msg" == *"legacy root-level snapshot"* ]]; then
      if [[ -f "$file" ]]; then
        local b doc_prefix ver_part target_dir target
        b=$(basename "$file")
        doc_prefix="${b%@v*}"
        ver_part="@v${b#*@v}"
        target_dir=".spectacular/snapshots/${doc_prefix}"
        target="${target_dir}/${ver_part}"
        mkdir -p "$target_dir"
        # Prefer git mv when the file is tracked; fall back to plain mv
        if git ls-files --error-unmatch "$file" >/dev/null 2>&1; then
          git mv "$file" "$target" 2>/dev/null && {
            echo "  ✓ fixed [snapshots]: git mv $file → $target"
            applied=$((applied + 1))
          }
        else
          mv "$file" "$target" && {
            echo "  ✓ fixed [snapshots]: mv $file → $target"
            applied=$((applied + 1))
          }
        fi
      fi
      continue
    fi

    # Dangling symlink
    if [[ "$sev" == "error" && "$file" == *".claude/skills/spectacular"* ]]; then
      local agents_dir
      agents_dir="$(agents_skill_dir)"
      if [[ -d "$agents_dir" ]]; then
        rm -f "$file"
        mkdir -p "$(dirname "$file")"
        ln -s "$agents_dir" "$file"
        echo "  ✓ fixed [skill]: recreated symlink $file → $agents_dir"
        applied=$((applied + 1))
      fi
      continue
    fi

    # Missing always-set file → re-scaffold using doc_<id>
    if [[ "$file" == ".spectacular/PRD.md" || "$file" == ".spectacular/SPEC.md" || "$file" == ".spectacular/config.yaml" || "$file" == ".spectacular/POLICY.md" || "$file" == ".spectacular/AGENTS.md" || "$file" == ".spectacular/CLAUDE.md" ]]; then
      local fname
      fname=$(basename "$file")
      local name="${OPT_NAME:-$(slug_from_dir)}"
      case "$fname" in
        PRD.md)        doc_prd "$name" "blank" ;;
        SPEC.md)       doc_spec "$name" ;;
        config.yaml)   doc_config "$name" "" "AGENTS.md" "blank" ;;
        POLICY.md)     doc_policy "$name" ;;
        AGENTS.md|CLAUDE.md) doc_agents "$name" "$fname" ;;
      esac
      echo "  ✓ fixed [workspace]: re-scaffolded $file"
      applied=$((applied + 1))
      continue
    fi
  done <<< "$DOC_FINDINGS"

  if [[ $applied -eq 0 ]]; then
    echo "  (no mechanical fixes applied)"
  fi
  echo ""
}

# ── text emitter ──────────────────────────────────────────────────────────────
doctor_emit_text() {
  echo "Spectacular doctor"
  echo ""

  local last_area="" errors=0 warnings=0 infos=0
  while IFS='|' read -r area sev file msg fix ftype; do
    [[ -z "$area" ]] && continue
    if [[ "$area" != "$last_area" ]]; then
      last_area="$area"
    fi
    case "$sev" in
      pass)    icon="✅" ;;
      warning) icon="⚠️ "; warnings=$((warnings + 1)) ;;
      error)   icon="❌"; errors=$((errors + 1)) ;;
      info)    icon="ℹ️ "; infos=$((infos + 1)) ;;
      *)       icon="?"  ;;
    esac
    printf "%-13s %s %s — %s\n" "$area" "$icon" "$file" "$msg"
    if [[ -n "$fix" && "$sev" != "pass" ]]; then
      local route="(mechanical — \`--fix\` applies)"
      [[ "$ftype" == "judgment" ]] && route="(judgment — \`/spectacular doctor --fix\`)"
      printf "%-13s    → %s %s\n" "" "$fix" "$route"
    fi
  done <<< "$DOC_FINDINGS"

  echo ""
  printf "%d error(s), %d warning(s), %d info\n" "$errors" "$warnings" "$infos"
  if [[ $errors -gt 0 || $warnings -gt 0 ]]; then
    echo ""
    echo "Run \`spectacular doctor --fix\` for mechanical repairs."
    echo "Run \`/spectacular doctor --fix\` (in your AI agent) for judgment repairs."
  fi
}

# ── json emitter ──────────────────────────────────────────────────────────────
doctor_emit_json() {
  local ran_at
  ran_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local workspace="$(pwd)"
  local errors=0 warnings=0 infos=0 first=true

  printf '{\n'
  printf '  "version": "0.3.0",\n'
  printf '  "ran_at": "%s",\n' "$ran_at"
  printf '  "workspace": "%s",\n' "$workspace"
  printf '  "findings": [\n'

  while IFS='|' read -r area sev file msg fix ftype; do
    [[ -z "$area" ]] && continue
    [[ "$sev" == "pass" ]] && continue  # pass entries omitted from json (signal-to-noise)
    case "$sev" in
      warning) warnings=$((warnings + 1)) ;;
      error)   errors=$((errors + 1)) ;;
      info)    infos=$((infos + 1)) ;;
    esac
    if ! $first; then printf ',\n'; fi
    first=false
    # JSON-escape strings (basic — escape quotes and backslashes)
    local esc_msg="${msg//\\/\\\\}"; esc_msg="${esc_msg//\"/\\\"}"
    local esc_fix="${fix//\\/\\\\}"; esc_fix="${esc_fix//\"/\\\"}"
    local esc_file="${file//\\/\\\\}"; esc_file="${esc_file//\"/\\\"}"
    printf '    {"area": "%s", "severity": "%s", "file": "%s", "message": "%s", "proposed_fix": "%s", "fix_type": "%s"}' \
      "$area" "$sev" "$esc_file" "$esc_msg" "$esc_fix" "$ftype"
  done <<< "$DOC_FINDINGS"

  printf '\n  ],\n'
  printf '  "summary": { "errors": %d, "warnings": %d, "info": %d }\n' "$errors" "$warnings" "$infos"
  printf '}\n'
}

# ────────────────────────────────────────────────────────────────────────────
# pack subcommand — convention-pack lifecycle (install / list / remove)
# ────────────────────────────────────────────────────────────────────────────

pack_usage() {
  cat <<EOF
Usage: spectacular pack <verb> [args]

Manage convention packs — repo-shape opinions (naming + taxonomy + gitignore
+ file-placement + project-types). Schema: skills/spectacular/references/packs-contract.md

Verbs:
  list                       Show installed packs across all scopes
  install <name> [--from <path>]
                             Install pack to ~/.spectacular/packs/<name>/.
                             --from <path> copies from a local folder (default:
                             searches bundled, then app-store at <repo>/packs/<name>).
  remove <name> [--force]    Remove user-scope pack at ~/.spectacular/packs/<name>/.
                             --force allows removing bundled/project-local packs.
  show <name>                Print pack.md frontmatter for the named pack.

Pack scopes (precedence: project-local > user > app-store > bundled):
  bundled        skills/spectacular/templates/packs/<name>/
  app-store      <repo-root>/packs/<name>/
  user           ~/.spectacular/packs/<name>/
  project-local  <project>/.spectacular/packs/<name>/

Examples:
  spectacular pack list
  spectacular pack install minimal
  spectacular pack install alex-default --from /path/to/pack
  spectacular pack show minimal
  spectacular pack remove old-pack
EOF
}

pack_user_dir() { echo "${HOME}/.spectacular/packs"; }

pack_bundled_dir() {
  local agents_dir
  agents_dir="$(agents_skill_dir)"
  echo "${agents_dir}/templates/packs"
}

pack_appstore_dir() {
  # Walk up from cli/ looking for a packs/ sibling (source repo layout)
  # Fallback: cwd/packs if present
  local candidate
  if [[ -d "${SCRIPT_DIR}/../packs" ]]; then
    candidate="$(cd "${SCRIPT_DIR}/.." && pwd)/packs"
    echo "$candidate"
  elif [[ -d "./packs" ]]; then
    echo "$(pwd)/packs"
  else
    echo ""
  fi
}

pack_projectlocal_dir() {
  if [[ -d "./.spectacular/packs" ]]; then
    echo "$(pwd)/.spectacular/packs"
  else
    echo ""
  fi
}

# Resolve a pack name to a source folder, applying precedence rules.
# Args: $1 = pack name, $2 = optional explicit source override (--from)
# Stdout: absolute path to the resolved pack folder, or empty if not found
pack_resolve() {
  local name="$1"
  local override="${2:-}"

  if [[ -n "$override" ]]; then
    [[ -d "$override" ]] && echo "$override" && return 0
    return 1
  fi

  # Precedence order for INSTALL source (read from): project-local → user → app-store → bundled
  local pl ud as bd
  pl="$(pack_projectlocal_dir)"
  ud="$(pack_user_dir)"
  as="$(pack_appstore_dir)"
  bd="$(pack_bundled_dir)"

  for dir in "$pl" "$ud" "$as" "$bd"; do
    [[ -z "$dir" ]] && continue
    if [[ -d "${dir}/${name}" && -f "${dir}/${name}/pack.md" ]]; then
      echo "${dir}/${name}"
      return 0
    fi
  done
  return 1
}

pack_scope_of() {
  local path="$1"
  local pl ud as bd
  pl="$(pack_projectlocal_dir)"
  ud="$(pack_user_dir)"
  as="$(pack_appstore_dir)"
  bd="$(pack_bundled_dir)"

  # Order matters: most-specific scope first. Empty scope dirs are skipped
  # (an empty $pl would otherwise expand the pattern to "/*" and match everything).
  [[ -n "$pl" && "$path" == "${pl}/"* ]] && echo "project-local" && return
  [[ -n "$ud" && "$path" == "${ud}/"* ]] && echo "user" && return
  [[ -n "$as" && "$path" == "${as}/"* ]] && echo "app-store" && return
  [[ -n "$bd" && "$path" == "${bd}/"* ]] && echo "bundled" && return
  echo "unknown"
}

pack_list() {
  echo "Convention packs:"
  echo ""
  local found=0
  for scope_pair in \
    "bundled|$(pack_bundled_dir)" \
    "app-store|$(pack_appstore_dir)" \
    "user|$(pack_user_dir)" \
    "project-local|$(pack_projectlocal_dir)"
  do
    local scope="${scope_pair%%|*}"
    local dir="${scope_pair##*|}"
    [[ -z "$dir" || ! -d "$dir" ]] && continue
    local entries=()
    for sub in "$dir"/*/; do
      [[ -d "$sub" ]] || continue
      local name
      name="$(basename "$sub")"
      [[ -f "${sub}pack.md" ]] || continue
      entries+=("$name")
      found=$((found + 1))
    done
    if [[ ${#entries[@]} -gt 0 ]]; then
      printf "  %-14s %s\n" "[${scope}]" "$dir"
      for e in "${entries[@]}"; do
        printf "    • %s\n" "$e"
      done
    fi
  done
  echo ""
  if [[ $found -eq 0 ]]; then
    echo "  (no packs found)"
  else
    echo "Install: spectacular pack install <name>"
    echo "Show:    spectacular pack show <name>"
  fi
}

pack_install() {
  local name="$1"
  local from_path="${2:-}"
  [[ -z "$name" ]] && die "pack install: missing pack name. Usage: spectacular pack install <name> [--from <path>]"

  local src
  if ! src="$(pack_resolve "$name" "$from_path")"; then
    if [[ -n "$from_path" ]]; then
      die "pack install: source path not found or not a pack folder: $from_path"
    fi
    die "pack install: pack '$name' not found. Run 'spectacular pack list' to see available packs."
  fi

  local user_dir
  user_dir="$(pack_user_dir)"
  mkdir -p "$user_dir"
  local dest="${user_dir}/${name}"

  if [[ -d "$dest" ]]; then
    die "pack install: '$name' already installed at $dest. Remove first: spectacular pack remove $name"
  fi

  # Copy via cp -R (POSIX-portable enough; preserves dotfiles like templates/.gitignore)
  cp -R "$src" "$dest"

  echo "✓ installed $name → $dest"
  echo "  source:  $src ($(pack_scope_of "$src"))"
  echo ""
  echo "Activate per-repo by adding to .spectacular/config.yaml:"
  echo "  convention_pack:"
  echo "    source: $name"
  echo "    mode: suggest    # or scaffold | enforce"
}

pack_remove() {
  local name="$1"
  local force="${2:-false}"
  [[ -z "$name" ]] && die "pack remove: missing pack name. Usage: spectacular pack remove <name> [--force]"

  local user_dir
  user_dir="$(pack_user_dir)"
  local target="${user_dir}/${name}"

  if [[ -d "$target" ]]; then
    rm -rf "$target"
    echo "✓ removed user-scope pack: $target"
    return 0
  fi

  # If not in user scope, check if it exists elsewhere — refuse without --force
  local found
  if found="$(pack_resolve "$name")"; then
    local scope
    scope="$(pack_scope_of "$found")"
    if [[ "$force" != "true" ]]; then
      die "pack remove: '$name' lives in $scope scope ($found). Use --force to remove."
    fi
    rm -rf "$found"
    echo "✓ removed $scope pack: $found"
    return 0
  fi

  die "pack remove: '$name' not installed in any scope."
}

pack_show() {
  local name="$1"
  [[ -z "$name" ]] && die "pack show: missing pack name. Usage: spectacular pack show <name>"

  local src
  if ! src="$(pack_resolve "$name")"; then
    die "pack show: '$name' not found in any scope."
  fi

  local manifest="${src}/pack.md"
  [[ -f "$manifest" ]] || die "pack show: $manifest missing"

  echo "pack:   $name"
  echo "scope:  $(pack_scope_of "$src")"
  echo "path:   $src"
  echo ""
  echo "── pack.md frontmatter ──"
  awk '/^---$/{c++; if(c==2) exit; if(c==1) next} c==1' "$manifest"
}

pack() {
  local verb="${1:-}"
  case "$verb" in
    ""|--help|-h) pack_usage; exit 0 ;;
    list)
      pack_list
      ;;
    install)
      shift
      local name="${1:-}"
      [[ -n "$name" && "$name" != -* ]] || die "pack install: missing pack name. Usage: spectacular pack install <name> [--from <path>]"
      shift || true
      local from_path=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --from) require_value "--from" "${2:-}"; from_path="$2"; shift 2 ;;
          *) die "pack install: unknown option: $1" ;;
        esac
      done
      pack_install "$name" "$from_path"
      ;;
    remove)
      shift
      local name="${1:-}"
      [[ -n "$name" && "$name" != -* ]] || die "pack remove: missing pack name. Usage: spectacular pack remove <name> [--force]"
      shift || true
      local force="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --force) force="true"; shift ;;
          *) die "pack remove: unknown option: $1" ;;
        esac
      done
      pack_remove "$name" "$force"
      ;;
    show)
      shift
      pack_show "${1:-}"
      ;;
    *)
      die "Unknown pack verb: '$verb'. Run 'spectacular pack --help' for usage."
      ;;
  esac
}

# ── skill-verb stubs ──────────────────────────────────────────────────────────
# These verbs are interactive flows owned by the skill (not the CLI). Their
# references in docs/SKILL/refs use the `spectacular <verb>` form, so when a
# user types one directly we explain rather than emit "Unknown command".

skill_verb_message() {
  local verb="$1"; shift
  local description="$1"; shift
  cat >&2 <<EOF
'spectacular $verb' is an interactive skill flow — it must run inside your AI agent.

  ${description}

Run it as:  /spectacular $verb${1:+ }$*

(Inside Claude Code, Codex, etc. with the spectacular skill installed.)
EOF
  exit 1
}

main() {
  local subcmd="${1:-}"

  case "$subcmd" in
    --version|-v|version)
      echo "spectacular ${SPECTACULAR_VERSION}"
      exit 0
      ;;
    ""|--help|-h|help)
      top_usage; exit 0
      ;;
  esac

  # Skill-owned interactive verbs — explain and exit, don't pretend to dispatch.
  # Exception: `status --against-latest` is a CLI-mechanical flag (no skill needed).
  case "$subcmd" in
    archive)  shift; cmd_archive "$@"; exit $? ;;
    status)
      shift
      # Intercept CLI-mechanical flags before falling through to the skill stub.
      local _i=0
      while (( _i < $# )); do
        _i=$((_i + 1))
        local arg="${!_i}"
        case "$arg" in
          --against-latest) cmd_status_against_latest; exit $? ;;
          --since)
            local _next=$((_i + 1))
            cmd_status_since "${!_next:-}"
            exit $?
            ;;
          --since=*)
            cmd_status_since "${arg#--since=}"
            exit $?
            ;;
        esac
      done
      skill_verb_message "status" "Briefing of project state — frontmatter only, no full-file reads." "$@"
      ;;
    new)      shift; cmd_new "$@"; exit $? ;;
    snapshot) shift; cmd_snapshot "$@"; exit $? ;;
    remember)
      shift
      # v1.5.0: if invoked with text argument, route to CLI writer.
      # Bare `spectacular remember` (or `remember this`) remains a skill verb.
      if [[ $# -eq 0 ]] || [[ "$1" == "this" && $# -eq 1 ]]; then
        skill_verb_message "remember" "Write an operational lesson to .spectacular/memory/." "$@"
      else
        cmd_remember "$@"; exit $?
      fi
      ;;
    decide)   shift; cmd_decide "$@"; exit $? ;;
    session)  shift; cmd_session "$@"; exit $? ;;
    promote)  shift; cmd_promote "$@"; exit $? ;;
    # Verify (v1.11.0+): skill-only validation walk. Needs an LLM to read each
    # check, run/judge it by kind, and gate review→verified. No CLI dispatch.
    verify)
      shift
      skill_verb_message "verify" \
        "Validation walk — reads VERIFY.md (or PLAN § Validation), verifies each check by its kind (executable / assertable / judgable / observable / manual), records to VERIFY-LOG, and gates review→verified." \
        "$@"
      ;;
    # Feedback-loop (v1.6.0+): canonical name + hidden aliases.
    # Aliases are dispatched but NOT documented in --help per the contract.
    feedback-loop|iterate|experiment|test|probe|try)
      shift; cmd_feedback_loop "$@"; exit $? ;;
    # Idea (v1.7.0+): thinking scratchpad.
    idea)
      shift; cmd_idea "$@"; exit $? ;;
    # Imagine / vision (v1.15.0+): imagination-backed planning.
    # `imagine <slug>` scaffolds the vision/ folder (mechanical), then the skill
    # renders + derives. Bare `imagine` (no slug) is a skill verb. `vision add`
    # is the mechanical fragment mutator.
    imagine)
      shift
      if [[ $# -eq 0 ]]; then
        skill_verb_message "imagine" \
          "Imagination-backed planning — render ASCII artifacts (stories/ui/arch), react per-fragment, then derive a draft PLAN. Generative-first; needs an LLM." \
          "$@"
      else
        cmd_imagine "$@"; exit $?
      fi
      ;;
    vision)
      shift; cmd_vision "$@"; exit $? ;;
    # Read verbs (v1.8.0+): plural-noun = list, singular-noun = detail.
    requests)   shift; cmd_requests "$@";   exit $? ;;
    decisions)  shift; cmd_decisions "$@";  exit $? ;;
    memories)   shift; cmd_memories "$@";   exit $? ;;
    sessions)   shift; cmd_sessions "$@";   exit $? ;;
    request)    shift; cmd_request "$@";    exit $? ;;
    links)      shift; cmd_links "$@";      exit $? ;;
    decision)   shift; cmd_decision "$@";   exit $? ;;
    memory)     shift; cmd_memory "$@";     exit $? ;;
    show)       shift; cmd_show "$@";       exit $? ;;
    summary)    shift; cmd_summary "$@";    exit $? ;;
    progress)   shift; cmd_progress "$@";   exit $? ;;
    roadmap)    shift; cmd_roadmap "$@";    exit $? ;;
    paths)      shift; cmd_paths "$@";      exit $? ;;
    # Policy (v1.12.0+): read the merged policy contract. CLI-mechanical
    # retrieval — the skill calls `policy @<hook>` on entering a phase.
    # `policy grill|refine|review` falls through to the doc-verb redirect
    # (POLICY is also a doc); everything else is CLI retrieval.
    policy)
      case "${2:-}" in
        grill|refine|review) : ;;  # fall through to doc-verb pre-check below
        *) shift; cmd_policy "$@"; exit $? ;;
      esac
      ;;
  esac

  if [[ "$subcmd" == "doctor" ]]; then
    shift
    doctor "$@"
    # doctor exits internally; this is unreachable
    exit 0
  fi

  if [[ "$subcmd" == "pack" ]]; then
    shift
    pack "$@"
    exit 0
  fi

  if [[ "$subcmd" == "migrate" ]]; then
    shift
    cmd_migrate "$@"
    exit $?
  fi

  if [[ "$subcmd" == "touch" ]]; then
    shift
    cmd_touch "$@"
    exit $?
  fi

  # ── doc-verb pre-check (agentic verbs are skill-only) ──
  # Matches `spectacular <doc> grill|refine|review` and redirects when called
  # from terminal. Grill + refine require an LLM (slot interview, vibe→spec
  # rewrite). Review is mixed — structural part runs in `doctor`, semantic
  # part requires the skill.
  if in_list "$subcmd" "$KNOWN_DOCS"; then
    local doc_verb="${2:-}"
    case "$doc_verb" in
      grill|refine|review)
        local doc="$subcmd"
        shift 2
        skill_verb_message "$doc $doc_verb" \
          "Agentic verb — requires an LLM to interview, rewrite, or gate-check ${doc}." \
          "$@"
        ;;
      "")
        # `spectacular <doc>` with no verb — let the skill infer (grill if empty, review if filled)
        local doc="$subcmd"
        shift
        skill_verb_message "$doc" \
          "Agentic dispatch — the skill resolves the right verb from ${doc}'s current state." \
          "$@"
        ;;
      *)
        die "Unknown verb '$doc_verb' for doc '$subcmd'.
Agentic verbs (skill-only):  grill | refine | review
Run inside Claude Code or Codex:  /spectacular $subcmd <verb>"
        ;;
    esac
  fi

  if [[ "$subcmd" != "init" ]]; then
    die "Unknown command: '${subcmd}'.
CLI verbs:   init | doctor | pack | migrate | new | promote | snapshot | archive | touch | decide | remember | session | feedback-loop | idea
Read verbs:  summary | requests | request | decisions | decision | memories | memory | sessions | show | progress | paths (v1.8.0+)
Skill verbs (run via /spectacular in your AI agent): status | remember this | verify <slug> | <doc> grill | <doc> refine | <doc> review"
  fi

  shift
  parse_args "$@"

  echo "Spectacular init"
  echo ""

  # ── Detect existing installs + resolve skill scope ──────────────────────────
  # Warn if spectacular is already available (upstream / global / plugin), then
  # decide whether to install. If the user did not pin a scope explicitly, an
  # existing install means we default to 'none' (scaffold only, no redundant copy).
  local existing_installs
  existing_installs="$(detect_existing_installs)"

  if [[ -n "$existing_installs" ]]; then
    info "⚠ spectacular already available via:"
    while IFS=$'\t' read -r label path; do
      [[ -z "$label" ]] && continue
      info "    • ${label}: ${path}"
    done <<< "$existing_installs" || true

    if [[ -z "$OPT_SKILL_SCOPE" ]]; then
      OPT_SKILL_SCOPE="none"
      info "  Skipping skill install. Use --skill-scope project (or global) to force a copy."
    fi
    echo ""
  fi

  # No explicit scope and nothing detected → default to a project-local install.
  [[ -z "$OPT_SKILL_SCOPE" ]] && OPT_SKILL_SCOPE="project"

  if $OPT_UPDATE; then
    update_skill
  fi

  if $OPT_INTERACTIVE; then
    run_interactive
  fi

  [[ -z "$OPT_NAME" ]] && OPT_NAME="$(slug_from_dir)"

  local agents_dir claude_dir lock_ref
  agents_dir="$(agents_skill_dir)"
  claude_dir="$(claude_skill_dir)"
  lock_ref="$(read_lock_ref)"

  # Interactive mode: show final summary, ask for confirmation before any writes
  if $OPT_INTERACTIVE; then
    local doc_set_preview
    doc_set_preview="$(resolve_doc_set)"
    echo "Ready to scaffold:"
    echo "  project:     $OPT_NAME"
    echo "  summary:     ${OPT_SUMMARY:-(none)}"
    echo "  agents-file: $OPT_AGENTS_FILE"
    echo "  kit:         $OPT_KIT"
    echo "  skill-scope: $OPT_SKILL_SCOPE"
    echo "  docs:        $doc_set_preview"
    echo ""
    printf "Proceed? [Y/n]: "
    local confirm
    read -r confirm
    case "${confirm:-y}" in
      y|Y|yes|YES) ;;
      *) echo "Aborted. No files written."; exit 0 ;;
    esac
    echo ""
  fi

  echo "Scaffold:"

  scaffold "$OPT_NAME" "$OPT_SUMMARY" "$OPT_AGENTS_FILE"

  echo ""
  echo "Skill:"

  INSTALLED_REF=""
  AGENTS_SKILL_INSTALLED=""
  CLAUDE_SKILL_INSTALLED=""

  if [[ "$OPT_SKILL_SCOPE" == "none" ]]; then
    skip "skill install skipped (--skill-scope none)"
  elif [[ -n "$lock_ref" && -d "$agents_dir" ]]; then
    skip "${agents_dir}  (${lock_ref}, already installed)"
    skip "${claude_dir}  → symlink"
  else
    install_skill
    info "  installed  ${AGENTS_SKILL_INSTALLED}  (${INSTALLED_REF})"
    info "  symlinked  ${CLAUDE_SKILL_INSTALLED}  → ${AGENTS_SKILL_INSTALLED}"
  fi

  print_summary
}

INSTALLED_REF=""
AGENTS_SKILL_INSTALLED=""
CLAUDE_SKILL_INSTALLED=""

main "$@"
