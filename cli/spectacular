# ── cmd_summary (aggregate workspace overview) ───────────────────────────────
cmd_summary() {
  local json=false
  while (( $# > 0 )); do
    case "$1" in
      --json) json=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular summary [--json]

One-page workspace overview: counts of requests by status, recent decisions,
recent memories, open sessions. Aggregates by calling other read verbs.
EOF
        exit 0 ;;
      *) die "Unknown flag for summary: $1" ;;
    esac
  done

  [[ -d ".spectacular" ]] || die "summary: not inside a Spectacular workspace"

  # Count requests by status
  local total_requests=0 planned=0 active=0 review=0 verified=0
  local f s
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    total_requests=$((total_requests + 1))
    s=$(fm_get "$f" "status")
    case "$s" in
      planned)  planned=$((planned + 1)) ;;
      active)   active=$((active + 1)) ;;
      review)   review=$((review + 1)) ;;
      verified) verified=$((verified + 1)) ;;
    esac
  done < <(_request_iter_all)

  # Count decisions, memories
  local total_decisions=0 total_memories=0
  while IFS= read -r f; do [[ -n "$f" ]] && total_decisions=$((total_decisions + 1)); done < <(_decision_iter_all)
  while IFS= read -r f; do [[ -n "$f" ]] && total_memories=$((total_memories + 1)); done < <(_memory_iter_all)

  # Sessions: total + open
  local total_sessions=0 open_sessions=0
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    total_sessions=$((total_sessions + 1))
    s=$(fm_get "$f" "status")
    [[ "$s" == "open" ]] && open_sessions=$((open_sessions + 1))
  done < <(_session_iter_all)

  # Ideas + feedback (light counts)
  local total_ideas=0
  if [[ -d ".spectacular/ideas" ]]; then
    for f in .spectacular/ideas/*.md; do [[ -f "$f" ]] && total_ideas=$((total_ideas + 1)); done
  fi
  local total_feedback=0
  if [[ -d ".spectacular/feedback" ]]; then
    for f in .spectacular/feedback/*.md; do [[ -f "$f" ]] && total_feedback=$((total_feedback + 1)); done
  fi

  # Project name
  local project="?"
  if [[ -f ".spectacular/config.yaml" ]]; then
    project=$(awk '/^  name:/ { sub(/^  name:[[:space:]]*/, ""); print; exit }' .spectacular/config.yaml)
    [[ -z "$project" ]] && project="?"
  fi

  if $json; then
    printf '{"project":"%s","requests":{"total":%d,"planned":%d,"active":%d,"review":%d,"verified":%d},' \
      "$(_json_escape "$project")" "$total_requests" "$planned" "$active" "$review" "$verified"
    printf '"decisions":%d,"memories":%d,"sessions":{"total":%d,"open":%d},"ideas":%d,"feedback":%d}\n' \
      "$total_decisions" "$total_memories" "$total_sessions" "$open_sessions" "$total_ideas" "$total_feedback"
    return 0
  fi

  echo "── Spectacular Workspace Summary ──"
  echo ""
  printf "Project:    %s\n" "$project"
  echo ""

  if (( total_requests > 0 )); then
    printf "Requests:   %d total\n" "$total_requests"
    # Status breakdown with mini bars (width=10, proportional to total)
    local statuses=("planned" "active" "review" "verified")
    local counts=("$planned" "$active" "$review" "$verified")
    local s c bar
    for (( i=0; i<4; i++ )); do
      s="${statuses[$i]}"
      c="${counts[$i]}"
      (( c == 0 )) && continue
      bar=$(_ascii_bar "$c" "$total_requests" 10)
      printf "            %-10s %s  %d\n" "$s" "$bar" "$c"
    done
  else
    echo "Requests:   0"
  fi
  echo ""
  printf "Decisions:  %d\n" "$total_decisions"
  printf "Memories:   %d\n" "$total_memories"
  printf "Sessions:   %d (%d open)\n" "$total_sessions" "$open_sessions"
  printf "Ideas:      %d\n" "$total_ideas"
  printf "Feedback:   %d\n" "$total_feedback"
  echo ""
  if (( active > 0 )); then
    echo "Active requests:"
    spectacular_self_active_requests=true cmd_requests --active --limit 5 2>/dev/null | tail -n +3 | sed 's/^/  /'
  fi

  # Cross-request link advisory (v1.16.0+): show active requests that have
  # declared edges so an agent sees ordering dependencies at a glance.
  local _link_lines=""
  if [[ -d ".spectacular/requests" ]]; then
    local _link_gdir
    _link_gdir=$(mktemp -d)
    local _active_plan_slugs=()
    shopt -s nullglob
    for _d in .spectacular/requests/*/; do
      local _sl; _sl=$(basename "$_d")
      local _st; _st=$(fm_get ".spectacular/requests/$_sl/PLAN.md" "status" 2>/dev/null || true)
      [[ "$_st" == "active" ]] || continue
      _active_plan_slugs+=("$_sl")
      local _dp
      _dp=$(awk '/^---$/{c++;if(c>1)exit;next}c==1&&f&&/^[a-zA-Z]/{exit}c==1&&f&&/^[[:space:]]*-/{v=$0;sub(/^[[:space:]]*-[[:space:]]*/,"",v);gsub(/^"|"$/,"",v);gsub(/[[:space:]]+$/,"",v);if(v!="")print v}c==1&&/^depends-on:/{f=1}' \
        ".spectacular/requests/$_sl/PLAN.md")
      local _bk
      _bk=$(awk '/^---$/{c++;if(c>1)exit;next}c==1&&f&&/^[a-zA-Z]/{exit}c==1&&f&&/^[[:space:]]*-/{v=$0;sub(/^[[:space:]]*-[[:space:]]*/,"",v);gsub(/^"|"$/,"",v);gsub(/[[:space:]]+$/,"",v);if(v!="")print v}c==1&&/^blocks:/{f=1}' \
        ".spectacular/requests/$_sl/PLAN.md")
      [[ -n "$_dp" ]] && printf '%s\n' "$_dp" > "$_link_gdir/$_sl.dep"
      [[ -n "$_bk" ]] && printf '%s\n' "$_bk" > "$_link_gdir/$_sl.blk"
    done
    shopt -u nullglob
    # Compute inverses for active requests only.
    # ponytail: ${arr[@]+...} guards the empty-array-under-set-u bash quirk.
    for _sl in ${_active_plan_slugs[@]+"${_active_plan_slugs[@]}"}; do
      if [[ -f "$_link_gdir/$_sl.dep" ]]; then
        while IFS= read -r _t; do
          [[ -z "$_t" ]] && continue
          echo "$_sl" >> "$_link_gdir/$_t.req_by"
        done < "$_link_gdir/$_sl.dep"
      fi
      if [[ -f "$_link_gdir/$_sl.blk" ]]; then
        while IFS= read -r _t; do
          [[ -z "$_t" ]] && continue
          echo "$_sl" >> "$_link_gdir/$_t.blk_by"
        done < "$_link_gdir/$_sl.blk"
      fi
    done
    # Build advisory lines
    for _sl in ${_active_plan_slugs[@]+"${_active_plan_slugs[@]}"}; do
      local _has=false
      [[ -f "$_link_gdir/$_sl.dep"    ]] && _has=true
      [[ -f "$_link_gdir/$_sl.blk"    ]] && _has=true
      [[ -f "$_link_gdir/$_sl.req_by" ]] && _has=true
      [[ -f "$_link_gdir/$_sl.blk_by" ]] && _has=true
      $_has || continue
      local _parts=""
      if [[ -f "$_link_gdir/$_sl.dep" ]]; then
        local _ts; _ts=$(paste -sd, "$_link_gdir/$_sl.dep")
        _parts="${_parts:+$_parts; }depends-on: $_ts"
      fi
      if [[ -f "$_link_gdir/$_sl.blk" ]]; then
        local _ts; _ts=$(paste -sd, "$_link_gdir/$_sl.blk")
        _parts="${_parts:+$_parts; }blocks: $_ts"
      fi
      if [[ -f "$_link_gdir/$_sl.req_by" ]]; then
        local _ts; _ts=$(paste -sd, "$_link_gdir/$_sl.req_by")
        _parts="${_parts:+$_parts; }required-by: $_ts"
      fi
      if [[ -f "$_link_gdir/$_sl.blk_by" ]]; then
        local _ts; _ts=$(paste -sd, "$_link_gdir/$_sl.blk_by")
        _parts="${_parts:+$_parts; }blocked-by: $_ts"
      fi
      _link_lines="${_link_lines:+$_link_lines$'\n'}  ${_sl}: $_parts"
    done
    rm -rf "$_link_gdir"
  fi
  if [[ -n "$_link_lines" ]]; then
    echo "Active links:"
    echo "$_link_lines"
    echo ""
  fi
}

# ── cmd_roadmap (v1.15.0+, ledger-driven v1.13.0+) ────────────────────────────
# Renders ROADMAP.md using the ledger table as the single source of truth.
# Ledger columns: build | slug | title | tier | target-version | status
# Tier legend: full = current/near-term detail, themed = mid-term, vision = future.
# Non-TTY / NO_COLOR: degrades to plain text (no box chars, no color logic).
cmd_roadmap() {
  local json=false all=false
  while (( $# > 0 )); do
    case "$1" in
      --json)    json=true;  shift ;;
      --all)     all=true;   shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular roadmap [--all] [--json]

Render the ROADMAP.md as a version arc — runway (near-term), major (breaking),
and vision (future-direction) tiers shown with aligned status indicators.
Data source: the roadmap ledger table (build → target-version mapping).

  --all   include shipped entries (default: only planned/active)
  --json  machine-readable: array of {build,slug,version,title,tier,status} objects
EOF
        exit 0 ;;
      -*) die "Unknown flag for roadmap: $1" ;;
      *) die "roadmap: unexpected argument '$1'" ;;
    esac
  done

  local roadmap=".spectacular/ROADMAP.md"
  [[ -f "$roadmap" ]] || die "roadmap: ROADMAP.md not found at $roadmap"

  # Parse ledger table → emit pipe-delimited: build|slug|title|tier|version|status
  # Ledger format: | build | slug | title | tier | target-version | status |
  # Skips header row (contains "build") and separator row (contains "---").
  local -a builds slugs titles tiers versions statuses
  while IFS='|' read -r _pre build slug title tier ver status _post; do
    # strip whitespace from each field
    build="${build## }"; build="${build%% }"
    slug="${slug## }";   slug="${slug%% }"
    title="${title## }"; title="${title%% }"
    tier="${tier## }";   tier="${tier%% }"
    ver="${ver## }";     ver="${ver%% }"
    status="${status## }"; status="${status%% }"
    # skip header, separator, and empty rows
    [[ "$build" == "build" || "$build" == "---"* || -z "$build" ]] && continue
    builds+=("$build")
    slugs+=("$slug")
    titles+=("$title")
    tiers+=("$tier")
    versions+=("$ver")
    statuses+=("$status")
  done < <(awk '/^\| *build/,/^[^|]/' "$roadmap" | grep '^|')

  if (( ${#builds[@]} == 0 )); then
    info "roadmap: no ledger table found in $roadmap"
    return 0
  fi

  if $json; then
    printf "["
    local first=true i
    for (( i=0; i<${#builds[@]}; i++ )); do
      $all || [[ "${statuses[$i]}" != "shipped" ]] || continue
      $first && first=false || printf ","
      printf '{"build":"%s","slug":"%s","version":"%s","title":"%s","tier":"%s","status":"%s"}' \
        "${builds[$i]}" "${slugs[$i]}" "${versions[$i]}" \
        "${titles[$i]}" "${tiers[$i]}" "${statuses[$i]}"
    done
    printf "]\n"
    return 0
  fi

  # Text render
  if _ascii_color_enabled; then
    echo "── Roadmap ──────────────────────────────────────────────────────"
  else
    echo "── Roadmap ──"
  fi
  echo ""

  local cur_tier="" i
  for (( i=0; i<${#builds[@]}; i++ )); do
    local status="${statuses[$i]}"
    $all || [[ "$status" != "shipped" ]] || continue

    local tier="${tiers[$i]}"
    if [[ "$tier" != "$cur_tier" ]]; then
      [[ -n "$cur_tier" ]] && echo ""
      case "$tier" in
        full)    echo "  ── Runway (near-term) ──" ;;
        themed)  echo "  ── Major (mid-term) ──" ;;
        vision)  echo "  ── Vision (future) ──" ;;
        *)       echo "  ── $tier ──" ;;
      esac
      cur_tier="$tier"
    fi

    local indicator
    case "$status" in
      shipped)  indicator="✓" ;;
      active)   indicator="▶" ;;
      planned)  indicator="·" ;;
      *)        indicator="?" ;;
    esac

    local ver="${versions[$i]}"
    local title="${titles[$i]}"
    if (( ${#title} > 44 )); then title="${title:0:43}…"; fi
    printf "  %s  %-12s  %s\n" "$indicator" "$ver" "$title"
  done
  echo ""
}

# `spectacular archive <slug> [--force]`
# Moves request to .spectacular/archive/, rewrites inbound related: links,
# sets status: archived + archived: <today>. Refuses if not in verified/review
# without --force.
cmd_archive() {
  local slug="" opt_force=false opt_skip_doctor=false opt_no_docs_prompt=false
  while (( $# > 0 )); do
    case "$1" in
      --force)           opt_force=true; shift ;;
      --skip-doctor)     opt_skip_doctor=true; shift ;;
      --no-docs-prompt)  opt_no_docs_prompt=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular archive <slug> [--force] [--skip-doctor] [--no-docs-prompt]

Move a request from .spectacular/requests/<slug>/ to .spectacular/archive/<slug>/
and rewrite inbound related: links in other request files to point at the new
location.

Refuses unless status is 'verified' or 'review'. Use --force to override.
Refuses if doctor finds workspace/specs/links errors. Use --skip-doctor to bypass.

If the archived request touched SPEC.md / specs/ / ARCHITECTURE.md / PRD.md AND
docs/ exists, prints a hint suggesting 'pageworks audit'. Suppress per-call with
--no-docs-prompt, or per-project with 'docs.prompt_on_archive: false' in
.spectacular/config.yaml. See: skills/spectacular/references/pageworks-handoff.md

Options:
  --force            Skip status-gate check (allow archiving planned/active requests)
  --skip-doctor      Bypass the doctor precondition (use with caution)
  --no-docs-prompt   Suppress the post-archive pageworks suggestion this run
  -h, --help         Show this help
EOF
        exit 0 ;;
      -*) die "Unknown flag for archive: $1" ;;
      *)
        [[ -n "$slug" ]] && die "archive takes one <slug> argument; got: $slug and $1"
        slug="$1"
        shift
        ;;
    esac
  done

  [[ -z "$slug" ]] && die "archive: <slug> argument required."
  [[ -d ".spectacular" ]] || die "archive: not inside a Spectacular workspace."

  require_doctor_clean "archive" "skip-doctor" "$opt_skip_doctor"

  local src=".spectacular/requests/$slug"
  if [[ ! -d "$src" ]]; then
    if [[ -d ".spectacular/archive/$slug" ]]; then
      die "archive: '$slug' is already archived (.spectacular/archive/$slug)"
    fi
    die "archive: request '$slug' not found at $src"
  fi

  local plan="$src/PLAN.md"
  if [[ ! -f "$plan" ]]; then
    die "archive: $plan not found — refuse to archive a request without PLAN.md"
  fi

  # Lifecycle gate
  local status
  status="$(fm_get "$plan" "status")"
  case "$status" in
    verified|review) ;;
    *)
      if ! $opt_force; then
        die "archive: refusing to archive '$slug' (status: ${status:-missing}). Promote to verified or use --force."
      fi
      ;;
  esac

  # Verify-walk advisory (v1.11.0+): verified without ever being walked.
  # If status is verified but no VERIFY-LOG.md exists, the request was flipped
  # verified without running `spectacular verify <slug>`. Advisory, not blocking.
  if [[ "$status" == "verified" && ! -f "$(dirname "$plan")/VERIFY-LOG.md" ]]; then
    echo "  ⚠ '$slug' is verified but has no VERIFY-LOG.md — it was never run through the verify walk." >&2
    echo "    Consider: /spectacular verify $slug  (records evidence + a walk log before archiving)" >&2
  fi

  # Bump PLAN frontmatter BEFORE the move (avoids losing the change)
  fm_set "$plan" "status" "archived"
  fm_set "$plan" "archived" "$TODAY"
  fm_touch "$plan"

  # Move dir
  mkdir -p .spectacular/archive
  local dest=".spectacular/archive/$slug"
  if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git mv "$src" "$dest" 2>/dev/null || mv "$src" "$dest"
  else
    mv "$src" "$dest"
  fi
  echo "  ✓ moved: $src → $dest"

  # Rewrite inbound related: links across all remaining request files.
  # Pattern: '../<slug>/' → '../../archive/<slug>/'
  # Also catches: '../<slug>/PLAN.md', '../<slug>/TASKS.md', etc.
  local rewrite_count=0
  shopt -s nullglob
  for target_file in .spectacular/requests/*/PLAN.md .spectacular/requests/*/TASKS.md .spectacular/requests/*/VERIFY.md; do
    if grep -q "\.\./${slug}/" "$target_file" 2>/dev/null; then
      sed -i.bak "s|\\.\\./${slug}/|../../archive/${slug}/|g" "$target_file"
      rm -f "$target_file.bak"
      rewrite_count=$((rewrite_count + 1))
      echo "  ✓ rewrote inbound link in: $target_file"
    fi
  done
  shopt -u nullglob

  if [[ "$rewrite_count" -eq 0 ]]; then
    echo "  • no inbound related: links found to rewrite"
  fi

  # ── pageworks handoff prompt (v1.2.0+) ─────────────────────────────────────
  # If the archived request touched SPEC.md, specs/, ARCHITECTURE.md, or PRD.md
  # AND docs/ exists in the project, surface a hint about pageworks. The user
  # decides whether to act. See: skills/spectacular/references/pageworks-handoff.md
  if ! $opt_no_docs_prompt && [[ -d "docs" ]]; then
    # Per-project suppression via config.yaml
    local prompt_setting
    prompt_setting="$(awk '
      /^docs:/ { in_docs=1; next }
      in_docs && /^[a-zA-Z]/ && !/^  / { in_docs=0 }
      in_docs && /^[[:space:]]+prompt_on_archive:/ {
        sub(/^[[:space:]]+prompt_on_archive:[[:space:]]*/, "")
        sub(/[[:space:]]*#.*$/, "")
        sub(/[[:space:]]*$/, "")
        print; exit
      }
    ' .spectacular/config.yaml 2>/dev/null)"

    if [[ "$prompt_setting" != "false" ]]; then
      # Detect spec-touching changes in the archived request's tracked content
      local touched_spec=false
      for sentinel in PLAN.md TASKS.md VERIFY.md; do
        if [[ -f "$dest/$sentinel" ]]; then
          if grep -qE '(SPEC\.md|specs/|ARCHITECTURE\.md|PRD\.md)' "$dest/$sentinel" 2>/dev/null; then
            touched_spec=true
            break
          fi
        fi
      done

      if $touched_spec; then
        echo ""
        echo "ℹ This request referenced internal specs. Public docs/ may need updates."
        echo ""
        if command -v pageworks >/dev/null 2>&1; then
          echo "  Suggested next steps:"
          echo "    pageworks audit           # find pages whose synced_from: matches the changed spec"
          echo "    pageworks review <page>   # work through each flagged page"
        else
          echo "  Public docs work has moved to a dedicated skill: pageworks."
          echo "  Install: https://github.com/alexsmedile/pageworks"
        fi
        echo ""
        echo "  Skip future prompts:"
        echo "    spectacular archive <slug> --no-docs-prompt"
        echo "    or set 'docs.prompt_on_archive: false' in .spectacular/config.yaml"
      fi
    fi
  fi
}

# ── snapshot ─────────────────────────────────────────────────────────────────
# `spectacular snapshot <file> [--major]`
# Copies a canonical doc to <FILE>@v<N>.md (next N inferred), bumps version
# field in the unversioned file. Idempotent: no-op if content unchanged since
# last snapshot.
cmd_snapshot() {
  local file="" opt_major=false
  while (( $# > 0 )); do
    case "$1" in
      --major) opt_major=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular snapshot <file> [--major]

Snapshot a canonical doc as <FILE>@v<N>.md, bump version field, set updated.
Idempotent: re-running with no content changes since last snapshot is a no-op.

Canonical docs are: PRD, SPEC, ARCHITECTURE, PRINCIPLES, ROADMAP, STACK,
DECISIONS, AGENTS, and specs/<capability>/SPEC.md files. Non-canonical files
are refused — manual snapshots for those use plain cp.

Options:
  --major    Bump major version (X.Y → (X+1).0). Default is minor bump (X.Y → X.(Y+1)).
  -h, --help Show this help
EOF
        exit 0 ;;
      -*) die "Unknown flag for snapshot: $1" ;;
      *)
        [[ -n "$file" ]] && die "snapshot takes one file argument; got: $file and $1"
        file="$1"
        shift
        ;;
    esac
  done

  [[ -z "$file" ]] && die "snapshot: <file> argument required. See: spectacular snapshot --help"
  [[ -f "$file" ]] || die "snapshot: file not found: $file"

  if ! is_canonical_doc "$file"; then
    die "snapshot: $file is not a registered canonical doc. Use plain cp for other files."
  fi

  if ! head -1 "$file" | grep -q '^---$'; then
    die "snapshot: $file has no frontmatter delimiter"
  fi

  # Determine next snapshot number
  local dir base ext base_no_ext
  dir=$(dirname "$file")
  base=$(basename "$file")
  ext="${base##*.}"
  base_no_ext="${base%.*}"

  # v1.5.0+ snapshot layout: snapshots/<DOC>/@v<N>.<ext>, mirroring sub-paths.
  # The canonical doc at .spectacular/PRD.md → .spectacular/snapshots/PRD/@v<N>.md
  # The capability spec at .spectacular/specs/cli/SPEC.md → .spectacular/snapshots/specs/cli/SPEC/@v<N>.md
  local snap_dir rel_dir
  rel_dir="${dir#.spectacular/}"
  if [[ "$rel_dir" == ".spectacular" || "$rel_dir" == "$dir" ]]; then
    # File is at .spectacular root (rel_dir collapses), or not under .spectacular at all
    snap_dir=".spectacular/snapshots/${base_no_ext}"
  else
    snap_dir=".spectacular/snapshots/${rel_dir}/${base_no_ext}"
  fi

  local max_n=0 latest_path=""
  shopt -s nullglob
  # Scan NEW location: snapshots/<DOC>/@v<N>.<ext>
  for existing in "$snap_dir/@v"*.${ext}; do
    local n
    n=$(echo "$existing" | sed -E "s|.*@v([0-9]+(\.[0-9]+)?)\.${ext}\$|\1|")
    # Reduce X.Y to X for max comparison; keep full string for latest_path
    local nint="${n%.*}"
    if [[ "$nint" =~ ^[0-9]+$ ]] && (( nint > max_n )); then
      max_n=$nint
      latest_path="$existing"
    fi
  done
  # Also scan LEGACY location: <dir>/<base>@v<N>.<ext> for back-compat
  for existing in "$dir/${base_no_ext}@v"*.${ext}; do
    local n
    n=$(echo "$existing" | sed -E "s|.*@v([0-9]+(\.[0-9]+)?)\.${ext}\$|\1|")
    local nint="${n%.*}"
    if [[ "$nint" =~ ^[0-9]+$ ]] && (( nint > max_n )); then
      max_n=$nint
      latest_path="$existing"
    fi
  done
  shopt -u nullglob

  local next_n=$((max_n + 1))
  local snapshot_path="$snap_dir/@v${next_n}.${ext}"

  # Idempotence: compare BODY (everything after the frontmatter block) only.
  # Frontmatter fields like `version:` and `updated:` change every snapshot,
  # so they'd cause false-positive "changes" if compared.
  if (( max_n > 0 )) && [[ -n "$latest_path" ]]; then
    local latest="$latest_path"
    local cur_body snap_body
    cur_body=$(awk '/^---$/{c++; if(c<=2) next} c>=2' "$file" | md5 2>/dev/null || awk '/^---$/{c++; if(c<=2) next} c>=2' "$file" | md5sum | cut -d' ' -f1)
    snap_body=$(awk '/^---$/{c++; if(c<=2) next} c>=2' "$latest" | md5 2>/dev/null || awk '/^---$/{c++; if(c<=2) next} c>=2' "$latest" | md5sum | cut -d' ' -f1)
    if [[ -n "$cur_body" && "$cur_body" == "$snap_body" ]]; then
      echo "  • $file: no body changes since $latest (no snapshot taken)"
      return 0
    fi
  fi

  # Compute new version field
  local current_ver new_ver
  current_ver="$(fm_get "$file" "version")"
  if [[ -z "$current_ver" ]]; then
    new_ver="1.0"
  elif [[ "$current_ver" =~ ^([0-9]+)\.([0-9]+)$ ]]; then
    local major="${BASH_REMATCH[1]}" minor="${BASH_REMATCH[2]}"
    if $opt_major; then
      new_ver="$((major + 1)).0"
    else
      new_ver="${major}.$((minor + 1))"
    fi
  else
    die "snapshot: cannot parse version '$current_ver' as MAJOR.MINOR. Set version: field manually first."
  fi

  # Write snapshot (creating dir if needed), then bump
  mkdir -p "$snap_dir"
  cp "$file" "$snapshot_path"
  fm_set "$file" "version" "$new_ver"
  fm_touch "$file"

  echo "  ✓ snapshot: $snapshot_path"
  echo "  ✓ version: ${current_ver:-(none)} → $new_ver"
}

# ── promote ──────────────────────────────────────────────────────────────────
# `spectacular promote <slug> [--to <state>] [--force]`
# State machine: planned → active → review → verified (linear).
# Is PLAN.md's `## Understanding` section filled? (the understand-before-change
# mechanical check). "Filled" = at least one line of real content under the
# section, ignoring HTML comment blocks (<!-- ... -->, possibly multi-line),
# blank lines, and the ### subheads themselves. Satisfied by a sibling
# UNDERSTANDING.md too. Exit 0 = filled, 1 = empty/absent.
_plan_understanding_filled() {
  local plan="$1"
  [[ -f "$plan" ]] || return 1
  local und_dir
  und_dir="$(dirname "$plan")/UNDERSTANDING.md"
  [[ -f "$und_dir" ]] && return 0
  awk '
    /^##[[:space:]]+Understanding/ { in_u=1; next }
    in_u && /^##[[:space:]]/ && !/^###/ { in_u=0 }
    !in_u { next }
    {
      line=$0
      # strip comment spans; track open multi-line comments. Strip the FIRST
      # complete comment each pass (awk sub is greedy + has no non-greedy op, so
      # we cut to the first "-->" via a placeholder) to avoid eating real content
      # sandwiched between two inline comments on one line.
      if (in_c) { ci=index(line, "-->"); if (ci) { line=substr(line, ci+3); in_c=0 } else next }
      while (match(line, /<!--/)) {
        if (line ~ /-->/) {
          # replace the first <!-- ... --> only: split at the first close marker
          pre=substr(line, 1, RSTART-1)
          rest=substr(line, RSTART)
          ci=index(rest, "-->")
          line=pre substr(rest, ci+3)
        } else { sub(/<!--.*/, "", line); in_c=1; break }
      }
      sub(/^###.*/, "", line)          # subheads are not content
      gsub(/[[:space:]]/, "", line)
      if (line != "") found=1
    }
    END { exit found ? 0 : 1 }
  ' "$plan"
}

# Advisory policy consult on a lifecycle transition. Prints the hook's active
# policies; for @Implementation it runs the mechanical understand-before-change
# presence-check and surfaces a warning if unmet. The CLI does NOT block — the
# skill's injection loop (policy-injection.md) is authoritative. Honors the
# locked design: CLI mechanical surface, skill judgment + enforcement.
_policy_consult_transition() {
  local slug="$1" plan="$2" hook="$3"
  [[ -f ".spectacular/POLICY.md" ]] || return 0

  local pol_out
  pol_out="$(cmd_policy "$hook" 2>/dev/null)"
  [[ -z "$pol_out" ]] && return 0

  echo "  policy gate $hook:"
  echo "$pol_out" | sed 's/^/    /'

  # Mechanical gate: understand-before-change on planned → active.
  # Honor config: skip entirely if the policy is disabled; label by merged severity.
  if [[ "$hook" == "@Implementation" ]] && _policy_enabled "understand-before-change" \
       && ! _plan_understanding_filled "$plan"; then
    local sev rec; rec="$(_policy_lookup "understand-before-change")"
    sev="${rec##*$'\037'}"; [[ -z "$sev" ]] && sev="block"
    info "  ⚠ understand-before-change ($sev): no filled '## Understanding' in PLAN.md (or UNDERSTANDING.md)."
    info "    Fill it before implementing — How it works now / What changes / What stays the same."
    info "    (CLI advisory only; run /spectacular to enforce the gate.)"
  fi
  echo ""
}

# Default --to: advances one step. Refuses backward without --force.
cmd_promote() {
  local slug="" opt_to="" opt_force=false opt_archive=false opt_skip_doctor=false
  while (( $# > 0 )); do
    case "$1" in
      --to)           require_value "--to" "${2:-}"; opt_to="$2"; shift 2 ;;
      --force)        opt_force=true; shift ;;
      --archive)      opt_archive=true; shift ;;
      --skip-doctor)  opt_skip_doctor=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular promote <slug> [--to <state>] [--force] [--archive] [--skip-doctor]

Advance a request through the lifecycle. State machine:
  planned → active → review → verified

Default behavior promotes one step (e.g. planned → active). Use --to to
jump (e.g. --to verified). Backward transitions refused without --force.

Promote alone is non-destructive (frontmatter edit only). When --archive is
passed, the chain into archive runs the doctor precondition; --skip-doctor
bypasses it.

Options:
  --to <state>    Target state explicitly (planned | active | review | verified)
  --force         Allow backward or non-adjacent transitions
  --archive       After promoting to verified, also archive the request
  --skip-doctor   Bypass doctor precondition on the --archive chain (caution)
  -h, --help      Show this help
EOF
        exit 0 ;;
      -*) die "Unknown flag for promote: $1" ;;
      *)
        [[ -n "$slug" ]] && die "promote takes one <slug> argument; got: $slug and $1"
        slug="$1"
        shift
        ;;
    esac
  done

  [[ -z "$slug" ]] && die "promote: <slug> argument required. See: spectacular promote --help"
  [[ -d ".spectacular" ]] || die "promote: not inside a Spectacular workspace."

  local plan=".spectacular/requests/$slug/PLAN.md"
  if [[ ! -f "$plan" ]]; then
    if [[ -f ".spectacular/archive/$slug/PLAN.md" ]]; then
      die "promote: '$slug' is archived. Restore from .spectacular/archive/ first."
    fi
    die "promote: request '$slug' not found at .spectacular/requests/$slug/"
  fi

  local current
  current="$(fm_get "$plan" "status")"
  [[ -z "$current" ]] && die "promote: PLAN.md has no status: field"

  # Compute target if --to omitted
  local target
  if [[ -n "$opt_to" ]]; then
    target="$opt_to"
  else
    case "$current" in
      planned)  target="active" ;;
      active)   target="review" ;;
      review)   target="verified" ;;
      verified) die "promote: '$slug' is already verified. Use 'spectacular archive $slug' to archive it." ;;
      archived) die "promote: '$slug' is archived (status: archived). Cannot promote further." ;;
      *) die "promote: unknown current status '$current' in PLAN.md" ;;
    esac
  fi

  # Validate target
  case "$target" in
    planned|active|review|verified) ;;
    *) die "promote: invalid --to '$target'. Must be: planned | active | review | verified" ;;
  esac

  # Refuse backward unless --force
  if [[ "$current" == "$target" ]]; then
    echo "  • $slug: already $current (no change)"
    return 0
  fi

  local order="planned active review verified"
  local cur_idx tgt_idx i=0
  for s in $order; do
    [[ "$s" == "$current" ]] && cur_idx=$i
    [[ "$s" == "$target" ]] && tgt_idx=$i
    i=$((i + 1))
  done
  if (( tgt_idx < cur_idx )) && ! $opt_force; then
    die "promote: backward transition $current → $target refused. Use --force to override."
  fi

  # Policy consult on spine transitions (advisory at the CLI; the skill's
  # injection loop is authoritative for block enforcement — see policy-injection.md).
  # The CLI surfaces the relevant hook's policies + a mechanical check so a
  # terminal user isn't blind to a gate they're about to cross.
  case "$target" in
    active)   _policy_consult_transition "$slug" "$plan" "@Implementation" ;;
    verified) _policy_consult_transition "$slug" "$plan" "@Verification" ;;
  esac

  fm_set "$plan" "status" "$target"
  fm_touch "$plan"
  # Also bump TASKS.md status: to stay in sync
  local tasks=".spectacular/requests/$slug/TASKS.md"
  if [[ -f "$tasks" ]]; then
    fm_set "$tasks" "status" "$target"
    fm_touch "$tasks"
  fi
  echo "  ✓ $slug: $current → $target"

  # --archive: chain into cmd_archive (pass --skip-doctor through if set)
  if $opt_archive && [[ "$target" == "verified" ]]; then
    echo ""
    if $opt_skip_doctor; then
      cmd_archive "$slug" --skip-doctor
    else
      cmd_archive "$slug"
    fi
  fi
}

# ── new ──────────────────────────────────────────────────────────────────────
# `spectacular new <slug> [--summary "..."] [--status planned|active|review] [--priority low|medium|high]`
# Scaffolds .spectacular/requests/<slug>/PLAN.md + TASKS.md from templates with
# frontmatter prefilled. Refuses if <slug> exists in requests/ OR archive/.
cmd_new() {
  local slug="" opt_summary="" opt_status="planned" opt_priority="medium"
  while (( $# > 0 )); do
    case "$1" in
      --summary)        require_value "--summary" "${2:-}"; opt_summary="$2"; shift 2 ;;
      --status)         require_value "--status" "${2:-}"; opt_status="$2"; shift 2 ;;
      --priority)       require_value "--priority" "${2:-}"; opt_priority="$2"; shift 2 ;;
      --help|-h)
        cat <<EOF
Usage: spectacular new <slug> [--summary "..."] [--status <state>] [--priority <level>]

Scaffold a new request at .spectacular/requests/<slug>/ with PLAN.md and
TASKS.md prefilled from templates. Assigns the next build id (build: bN) and
increments last_build: in config.yaml.

Arguments:
  <slug>              Kebab-case identifier (e.g. user-auth, fix-race-cond)

Options:
  --summary "..."     One-sentence description (default: empty placeholder)
  --status <state>    planned | active | review  (default: planned)
  --priority <level>  low | medium | high        (default: medium)
  -h, --help          Show this help

The target version is NOT set here — add a row to the roadmap ledger in
ROADMAP.md when you slot this request into a version.

Refuses if <slug> already exists in .spectacular/requests/ or
.spectacular/archive/.
EOF
        exit 0 ;;
      -*) die "Unknown flag for new: $1" ;;
      *)
        [[ -n "$slug" ]] && die "new takes one <slug> argument; got: $slug and $1"
        slug="$1"
        shift
        ;;
    esac
  done

  [[ -z "$slug" ]] && die "new: <slug> argument required. See: spectacular new --help"

  # Slug validation: kebab-case, max 64 chars, no dots/slashes
  if [[ ! "$slug" =~ ^[a-z0-9][a-z0-9-]{0,63}$ ]]; then
    die "new: invalid slug '$slug'. Must be kebab-case, lowercase alnum + hyphens, max 64 chars, starting with letter or digit."
  fi
  # Status + priority validation
  case "$opt_status" in
    planned|active|review) ;;
    *) die "new: invalid --status '$opt_status'. Must be: planned | active | review" ;;
  esac
  case "$opt_priority" in
    low|medium|high) ;;
    *) die "new: invalid --priority '$opt_priority'. Must be: low | medium | high" ;;
  esac

  [[ -d ".spectacular" ]] || die "new: not inside a Spectacular workspace. Run 'spectacular init' first."

  local target=".spectacular/requests/$slug"
  if [[ -d "$target" ]]; then
    die "new: slug '$slug' already exists at $target"
  fi
  if [[ -d ".spectacular/archive/$slug" ]]; then
    die "new: slug '$slug' exists in archive (.spectacular/archive/$slug). Pick a different slug or restore the archived request."
  fi

  # Read owner from config.yaml if present
  local owner=""
  if [[ -f ".spectacular/config.yaml" ]]; then
    owner=$(awk '/^  owner:/ { sub(/^  owner:[[:space:]]*/, ""); print; exit }' .spectacular/config.yaml)
  fi
  [[ -z "$owner" ]] && owner="$(whoami 2>/dev/null || echo unknown)"

  # Assign build id (v1.17.0+): read last_build: from config.yaml (missing = 0),
  # compute next id, stamp build: bN on PLAN.md, write last_build: N+1 back.
  local _last_build=0 _build_id=""
  if [[ -f ".spectacular/config.yaml" ]]; then
    local _lb
    _lb=$(awk '/^last_build:/ { sub(/^last_build:[[:space:]]*/, ""); print; exit }' .spectacular/config.yaml)
    [[ "$_lb" =~ ^[0-9]+$ ]] && _last_build="$_lb"
  fi
  local _next_build=$(( _last_build + 1 ))
  _build_id="b${_next_build}"

  mkdir -p "$target"

  # PLAN.md from template
  local plan_template
  plan_template="$(agents_skill_dir)/templates/plan/base.md"
  if [[ ! -f "$plan_template" ]]; then
    plan_template="${SCRIPT_DIR}/../skills/spectacular/templates/plan/base.md"
  fi
  if [[ -f "$plan_template" ]]; then
    sed -e "s|<OWNER>|${owner}|g" \
        -e "s|<DATE>|${TODAY}|g" \
        -e "s|<BUILD>|${_build_id}|g" \
        -e "s|<one-sentence description of what this request changes>|${opt_summary:-<one-sentence description of what this request changes>}|" \
        -e "s|<Request Title>|${slug}|g" \
        "$plan_template" > "$target/PLAN.md"
    # Override frontmatter status + priority via fm_set (build already in template)
    fm_set "$target/PLAN.md" "status" "$opt_status"
    fm_set "$target/PLAN.md" "priority" "$opt_priority"
  else
    # Fallback minimal scaffold
    cat > "$target/PLAN.md" <<EOF
---
status: $opt_status
priority: $opt_priority
owner: $owner
updated: $TODAY
build: $_build_id
summary: "${opt_summary}"
related: []
---

# Plan — $slug

## 1. Goal

<one sentence>

## 2. Constraints

## 3. Milestones

## 4. Tasks

See TASKS.md.

## 5. Dependencies

## 6. Validation

## 7. Deliverables
EOF
  fi

  # TASKS.md from template
  local tasks_template
  tasks_template="$(agents_skill_dir)/templates/tasks/base.md"
  if [[ ! -f "$tasks_template" ]]; then
    tasks_template="${SCRIPT_DIR}/../skills/spectacular/templates/tasks/base.md"
  fi
  if [[ -f "$tasks_template" ]]; then
    sed -e "s|<DATE>|${TODAY}|g" \
        -e "s|<Request Title>|${slug}|g" \
        "$tasks_template" > "$target/TASKS.md"
    fm_set "$target/TASKS.md" "status" "$opt_status"
  else
    cat > "$target/TASKS.md" <<EOF
---
status: $opt_status
updated: $TODAY
related:
  - PLAN.md
---

# Tasks — $slug

## v1

### M1 — <Milestone name>
- [ ] <Task>
EOF
  fi

  # Write last_build: back to config.yaml (create field if missing)
  if [[ -f ".spectacular/config.yaml" ]]; then
    if grep -q "^last_build:" .spectacular/config.yaml; then
      local _tmp; _tmp=$(mktemp)
      awk -v nb="$_next_build" '/^last_build:/ { print "last_build: " nb; next } { print }' \
        .spectacular/config.yaml > "$_tmp" && mv "$_tmp" .spectacular/config.yaml
    else
      printf '\nlast_build: %s\n' "$_next_build" >> .spectacular/config.yaml
    fi
  fi

  echo "  ✓ scaffolded: $target/PLAN.md"
  echo "  ✓ scaffolded: $target/TASKS.md"
  echo "  ✓ build id:   $_build_id"
  echo ""
  echo "Next: edit $target/PLAN.md to flesh out the 7 slots."
  echo "      When slotting into the roadmap, add a row to the ledger in ROADMAP.md."

  # Relationship prompt (v1.16.0+): if any active request's slug shares a
  # keyword with the new slug, hint to declare depends-on:/blocks:/related:.
  local _new_keywords _match_slugs=""
  _new_keywords=$(echo "$slug" | tr '-' '\n')
  shopt -s nullglob
  for _d in .spectacular/requests/*/; do
    local _cs; _cs=$(basename "$_d")
    [[ "$_cs" == "$slug" ]] && continue
    local _cst; _cst=$(fm_get ".spectacular/requests/$_cs/PLAN.md" "status" 2>/dev/null || true)
    [[ "$_cst" == "active" ]] || [[ "$_cst" == "planned" ]] || continue
    local _matched=false
    while IFS= read -r _kw; do
      [[ ${#_kw} -lt 4 ]] && continue  # skip short words
      if echo "$_cs" | grep -qi "$_kw"; then
        _matched=true; break
      fi
    done <<< "$_new_keywords"
    $_matched && _match_slugs="${_match_slugs:+$_match_slugs, }$_cs"
  done
  shopt -u nullglob
  if [[ -n "$_match_slugs" ]]; then
    echo "  ⚠  Related requests detected: $_match_slugs"
    echo "     Consider adding depends-on:, blocks:, or related: in PLAN.md."
  fi
}

# ── touch ────────────────────────────────────────────────────────────────────
# `spectacular touch <file>` — update frontmatter `updated:` to today.
# Idempotent: no-op if already today. Refuses files without frontmatter.
cmd_touch() {
  local file=""
  while (( $# > 0 )); do
    case "$1" in
      --help|-h)
        cat <<EOF
Usage: spectacular touch <file>

Update the frontmatter \`updated:\` field of <file> to today (${TODAY}).
Idempotent — re-running on a file already current is a clean no-op.
Refuses files without a YAML frontmatter block.
EOF
        exit 0 ;;
      -*) die "Unknown flag for touch: $1" ;;
      *)
        [[ -n "$file" ]] && die "touch takes one file argument; got: $file and $1"
        file="$1"
        shift
        ;;
    esac
  done

  [[ -z "$file" ]] && die "touch: <file> argument required. See: spectacular touch --help"
  [[ -f "$file" ]] || die "touch: file not found: $file"
  if ! head -1 "$file" | grep -q '^---$'; then
    die "touch: $file has no frontmatter delimiter"
  fi

  local current
  current="$(fm_get "$file" "updated")"
  if [[ "$current" == "$TODAY" ]]; then
    echo "  • $file: updated already $TODAY (no change)"
    return 0
  fi

  fm_touch "$file"
  echo "  ✓ $file: updated ${current:-(missing)} → $TODAY"
}

# ── doctor precondition (v0.7.4+) ────────────────────────────────────────────
# Run a scoped doctor check before destructive verbs (migrate, archive,
# promote --archive). Errors block (exit 1); warnings and info pass through.
# Bypass via --skip-doctor on the calling verb.
#
# Areas scoped: workspace, specs, links — the three most likely to surface
# structural problems that would make a destructive op unsafe. We don't run
# the full doctor (~10 areas) to keep precondition latency low and avoid
# blocking on unrelated drift (e.g. ROADMAP pre-v0.7.2 naming).
#
# Usage:  require_doctor_clean "<verb-name>" "<skip-doctor-flag-name>" $opt_skip_doctor
#         <verb-name>: human-readable verb (for error message)
#         <flag>: the bypass flag name (for error message)
#         $opt_skip_doctor: true|false — caller's parsed flag value
#
# Returns: 0 if clean (or skipped), exits 1 if errors found.
# Used by: archive (and promote --archive chain). For migrate, see
# require_doctor_clean_links — migrate would self-trigger on schema drift it's
# designed to fix.
require_doctor_clean() {
  _doctor_precondition "$1" "$2" "$3" "workspace specs links"
}

# Narrower precondition: only the links area. Used by migrate, which would
# self-trigger if it ran the workspace/specs checks (v0.4-shape workspaces
# have current/ which check_specs intentionally flags).
require_doctor_clean_links() {
  _doctor_precondition "$1" "$2" "$3" "links"
}

# Internal: run doctor on the named areas, count errors, refuse if any.
_doctor_precondition() {
  local verb="$1" flag="$2" skip="$3" areas="$4"
  if [[ "$skip" == "true" ]]; then
    return 0
  fi
  if [[ ! -d ".spectacular" ]]; then
    return 0  # outside-workspace check is the caller's job; don't double-error
  fi

  # JSON renders with `"severity": "error"` (space after colon) — match either spacing.
  local out err_count=0
  for area in $areas; do
    out=$("$0" doctor "$area" --format json 2>/dev/null) || true
    local n
    n=$(echo "$out" | grep -c '"severity":[[:space:]]*"error"' || true)
    err_count=$((err_count + n))
  done

  if (( err_count > 0 )); then
    local areas_display
    areas_display=$(echo "$areas" | tr ' ' '/')
    cat >&2 <<EOF

Refusing '$verb' — doctor found $err_count error(s) in $areas_display.

Run 'spectacular doctor' for details, fix the errors, then re-run.
To bypass (use with caution): pass --$flag

EOF
    exit 1
  fi
}

# ── migrate ──────────────────────────────────────────────────────────────────
# `spectacular migrate` — apply pending workspace-schema migrations.
#
# v0.6.2+: migrations live as .md files under skills/spectacular/references/
# migrations/. Each file declares (id, from, to, mechanical, reversible,
# apply-fn, affects) in frontmatter. The loader scans + sorts by `from` semver,
# resolves the chain from current_schema → target_schema, and dispatches each:
#   - mechanical: true  → calls the bash function named in apply-fn
#   - mechanical: false → prints "run /spectacular migrate in your AI agent",
#                         exits non-zero; the skill walks judgment migrations
#                         (see references/migrate.md)
#
# Schema contract: skills/spectacular/references/migrations-contract.md
#
# Idempotence: every migration self-detects whether it needs to run. Running
# `migrate` on an up-to-date workspace is a clean no-op.

# Resolve the directory where migration .md files live. Tries in order:
#   1. .agents/skills/spectacular/references/migrations/  (project-installed)
#   2. ~/.agents/skills/spectacular/references/migrations/ (global install)
#   3. ${SCRIPT_DIR}/../skills/spectacular/references/migrations/ (dev / source-tree run)
# Stdout: resolved absolute path, or empty string if none found.
migrations_dir() {
  local project_path="$(pwd)/.agents/skills/spectacular/references/migrations"
  local global_path="$HOME/.agents/skills/spectacular/references/migrations"
  local dev_path="${SCRIPT_DIR}/../skills/spectacular/references/migrations"
  for candidate in "$project_path" "$global_path" "$dev_path"; do
    if [[ -d "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

# Extract a single frontmatter field value from a migration .md file.
# Usage: migration_field <path> <field-name>
# Stdout: field value (trimmed, quotes stripped); empty if not found.
migration_field() {
  local path="$1" field="$2"
  awk -v fld="$field" '
    /^---$/ { fm = !fm; next }
    fm && $0 ~ "^"fld":" {
      val = $0
      sub("^"fld":[[:space:]]*", "", val)
      gsub(/^"|"$/, "", val)
      gsub(/[[:space:]]+$/, "", val)
      print val
      exit
    }
  ' "$path"
}

# Bump workspace_schema in config.yaml to the given version.
# Used internally by migration apply functions.
bump_workspace_schema() {
  local new_schema="$1"
  local cfg=".spectacular/config.yaml"
  if [[ ! -f "$cfg" ]]; then
    echo "  ✗ cannot bump workspace_schema — config.yaml not found" >&2
    return 1
  fi
  if grep -q "^workspace_schema:" "$cfg"; then
    # In-place update (portable sed: use a tmp file)
    sed "s/^workspace_schema:.*/workspace_schema: \"${new_schema}\"/" "$cfg" > "$cfg.tmp"
    mv "$cfg.tmp" "$cfg"
  else
    # Insert after the `project:` block (between line ending with ^summary: and the next blank line)
    # Simpler: append at end of file with a header comment
    cat >> "$cfg" <<EOF

# Structural version of .spectacular/ layout. Migrations bump this.
workspace_schema: "${new_schema}"
EOF
  fi
}

# v0.4 → v0.5: rename .spectacular/current/ → .spectacular/specs/ if present.
# Preserves contents verbatim (flat .md files OR per-capability subfolders).
# Idempotent: no-op when current/ absent.
migration_apply_v04_to_v05() {
  local dry="$1"
  local current_dir=".spectacular/current"
  local specs_dir=".spectacular/specs"

  if [[ ! -d "$current_dir" ]]; then
    echo "  • v0.4→v0.5: no .spectacular/current/ found — nothing to rename"
    [[ "$dry" == "true" ]] || bump_workspace_schema "0.5"
    return 0
  fi

  if [[ -d "$specs_dir" ]]; then
    echo "  ✗ v0.4→v0.5: both .spectacular/current/ AND .spectacular/specs/ exist" >&2
    echo "    Manual merge required. Run 'spectacular doctor specs' for guidance." >&2
    return 1
  fi

  if [[ "$dry" == "true" ]]; then
    echo "  • v0.4→v0.5: would rename .spectacular/current/ → .spectacular/specs/ (preserve contents)"
    return 0
  fi

  mv "$current_dir" "$specs_dir"
  echo "  ✓ v0.4→v0.5: renamed .spectacular/current/ → .spectacular/specs/"
  bump_workspace_schema "0.5"
}

# v0.5 → v0.6: ensure .spectacular/specs/ exists (mkdir + .gitkeep if empty).
# Idempotent: no-op when specs/ already present.
migration_apply_v05_to_v06() {
  local dry="$1"
  local specs_dir=".spectacular/specs"

  if [[ -d "$specs_dir" ]]; then
    # specs/ exists — just ensure schema is bumped
    if [[ "$dry" == "true" ]]; then
      echo "  • v0.5→v0.6: .spectacular/specs/ already present — would bump schema only"
    else
      echo "  • v0.5→v0.6: .spectacular/specs/ already present — bumping schema only"
      bump_workspace_schema "0.6"
    fi
    return 0
  fi

  if [[ "$dry" == "true" ]]; then
    echo "  • v0.5→v0.6: would create .spectacular/specs/ with .gitkeep"
    return 0
  fi

  mkdir -p "$specs_dir"
  touch "$specs_dir/.gitkeep"
  echo "  ✓ v0.5→v0.6: created .spectacular/specs/ with .gitkeep"
  bump_workspace_schema "0.6"
}

# Compare two schema versions (e.g. "0.4", "0.5"). Returns 0 if $1 < $2, else 1.
# Simple lexicographic comparison via sort -V.
schema_lt() {
  local a="$1" b="$2"
  [[ "$a" == "$b" ]] && return 1
  local first
  first=$(printf '%s\n%s\n' "$a" "$b" | sort -V | head -n1)
  [[ "$first" == "$a" ]]
}

cmd_migrate() {
  local dry_run=false
  local opt_to="" opt_from="" opt_list=false opt_skip_doctor=false
  while (( $# > 0 )); do
    case "$1" in
      --dry-run)      dry_run=true; shift ;;
      --list)         opt_list=true; shift ;;
      --to)           require_value "--to" "${2:-}"; opt_to="$2"; shift 2 ;;
      --from)         require_value "--from" "${2:-}"; opt_from="$2"; shift 2 ;;
      --skip-doctor)  opt_skip_doctor=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular migrate [--dry-run] [--to <ver>] [--from <ver>] [--list] [--skip-doctor]

Apply pending workspace-schema migrations to bring .spectacular/ to the latest
shape expected by this CLI (schema ${CURRENT_SCHEMA}).

Options:
  --dry-run       List planned migrations without writing
  --to <ver>      Migrate up to a specific schema version (default: latest)
  --from <ver>    Re-run starting from a specific schema (for repair)
  --list          List all known migrations from the registry; exit
  --skip-doctor   Bypass the doctor precondition (use with caution)
  -h, --help      Show this help

Migrations live as .md files in skills/spectacular/references/migrations/.
Each declares frontmatter (id, from, to, mechanical, reversible, apply-fn).
Mechanical migrations are applied by this CLI. Judgment migrations route
to '/spectacular migrate' in your AI agent.

A workspace with no workspace_schema: field is treated as "0.4".
Each migration is idempotent; running migrate on an up-to-date workspace
is a clean no-op.
EOF
        exit 0 ;;
      *) die "Unknown flag for migrate: $1" ;;
    esac
  done

  local reg_dir
  if ! reg_dir="$(migrations_dir)"; then
    die "Migration registry not found. Run \`spectacular init --update\` or check skill installation."
  fi

  # Build sorted list of migrations: "<from>|<to>|<id>|<mechanical>|<apply-fn>|<path>"
  local -a registry=()
  shopt -s nullglob
  for path in "$reg_dir"/v*.md; do
    local id from to mech applyfn
    id="$(migration_field "$path" "id")"
    from="$(migration_field "$path" "from")"
    to="$(migration_field "$path" "to")"
    mech="$(migration_field "$path" "mechanical")"
    applyfn="$(migration_field "$path" "apply-fn")"
    [[ -z "$id" || -z "$from" || -z "$to" ]] && continue
    registry+=("${from}|${to}|${id}|${mech}|${applyfn}|${path}")
  done
  shopt -u nullglob

  # Sort by `from` semver
  IFS=$'\n' read -r -d '' -a registry < <(printf '%s\n' "${registry[@]}" | sort -t'|' -V -k1,1; printf '\0')

  if $opt_list; then
    echo "Registered migrations (${#registry[@]} total):"
    echo ""
    local entry
    for entry in "${registry[@]}"; do
      IFS='|' read -r from to id mech _ path <<< "$entry"
      # description: prefer the first non-empty paragraph from the body's <H1>
      # if frontmatter description is a YAML literal block (|), parse the
      # indented continuation lines instead of the | marker
      local desc
      desc=$(awk '
        /^---$/ { fm = !fm; next }
        fm && /^description:[[:space:]]*\|/ { in_desc=1; next }
        fm && /^description:[[:space:]]*/ {
          val = $0
          sub(/^description:[[:space:]]*/, "", val)
          gsub(/^"|"$/, "", val)
          print val
          exit
        }
        fm && in_desc && /^  / {
          val = $0
          sub(/^[[:space:]]+/, "", val)
          print val
          exit
        }
      ' "$path")
      printf "  %-18s  %s → %s  (%s)  %s\n" "$id" "$from" "$to" "$mech" "$desc"
    done
    return 0
  fi

  if [[ ! -d ".spectacular" ]]; then
    die "Not inside a Spectacular workspace (no .spectacular/ here)."
  fi

  local current target
  current="${opt_from:-$(config_workspace_schema)}"
  target="${opt_to:-$CURRENT_SCHEMA}"

  if [[ "$current" == "$target" ]]; then
    echo "Workspace is up to date (schema ${current})."
    return 0
  fi

  # Doctor precondition (v0.7.4+): for migrate, only check links — workspace/specs
  # checks would fire on the very drift migrate is designed to repair (e.g. v0.4
  # shape has current/ which trips check_specs). Links remain valid signal: a
  # workspace with broken cross-doc references is unsafe to mutate further.
  # Dry-run skips entirely since no mutation will occur.
  if ! $dry_run; then
    require_doctor_clean_links "migrate" "skip-doctor" "$opt_skip_doctor"
  fi

  if schema_lt "$target" "$current"; then
    die "Downgrade not supported: --to ${target} is older than current schema ${current}. Bidirectional migrations are out of scope."
  fi

  if $dry_run; then
    echo "Dry-run: would migrate workspace_schema ${current} → ${target}"
  else
    echo "Migrating workspace_schema ${current} → ${target}"
  fi
  echo ""

  # Apply chain — for each registry entry where from >= current AND to <= target.
  local entry from to id mech applyfn path
  for entry in "${registry[@]}"; do
    IFS='|' read -r from to id mech applyfn path <<< "$entry"
    # Skip migrations whose `from` is older than current (already applied)
    schema_lt "$from" "$current" && continue
    # Skip migrations whose `to` exceeds target
    schema_lt "$target" "$to" && continue

    if [[ "$mech" != "true" ]]; then
      echo "  ⚠ ${id}: this migration requires judgment (mechanical: false)"
      echo ""
      echo "    Run '/spectacular migrate' in your AI agent (Claude Code, Codex, etc.)"
      echo "    to walk this migration with snapshot-before-edit + per-step confirmation."
      echo ""
      echo "    See: skills/spectacular/references/migrate.md"
      return 1
    fi

    if [[ -z "$applyfn" ]]; then
      die "${id}: mechanical: true but apply-fn is empty in frontmatter"
    fi
    if ! declare -F "$applyfn" >/dev/null; then
      die "${id}: apply-fn '${applyfn}' is not defined in cli/spectacular"
    fi

    "$applyfn" "$dry_run" || return $?
    [[ "$dry_run" == "false" ]] && current="$to"
  done

  echo ""
  if $dry_run; then
    echo "Dry-run complete. Run without --dry-run to apply."
  else
    echo "Migration complete. workspace_schema is now ${current}."
  fi
}

# `spectacular status --against-latest` — one-line workspace-schema verdict.
# Prints whether the workspace is up-to-date or behind the CLI's CURRENT_SCHEMA,
# plus the suggested verb to catch up. Always exits 0 (informational), unless
# the user is not inside a Spectacular workspace at all (exits 1).
cmd_status_against_latest() {
  if [[ ! -d ".spectacular" ]]; then
    echo "Not inside a Spectacular workspace (no .spectacular/ here)." >&2
    return 1
  fi
  local declared
  declared="$(config_workspace_schema)"
  if [[ "$declared" == "$CURRENT_SCHEMA" ]]; then
    echo "workspace_schema: ${declared}  ✓  up to date (CLI expects ${CURRENT_SCHEMA})"
    return 0
  fi
  # Behind: tell user what to run.
  echo "workspace_schema: ${declared}  ⚠  behind CLI (expects ${CURRENT_SCHEMA})"
  echo ""
  echo "  Run:  spectacular migrate            # apply pending migrations"
  echo "        spectacular migrate --dry-run  # preview without writing"
  return 0
}

# `spectacular status --since <date>` — activity report since a cutoff.
# Lists requests + canonical docs whose frontmatter `updated:` is >= <date>.
#
# Accepts: YYYY-MM-DD, relative ("7d", "2w", "1m"), or "yesterday".
# Frontmatter-only scan — no git involved. Always exits 0 unless outside a
# workspace (exits 1) or date can't be parsed (exits 2).
cmd_status_since() {
  local since_input="${1:-}"
  if [[ -z "$since_input" ]]; then
    echo "status --since: <date> argument required (YYYY-MM-DD | 7d | 2w | 1m | yesterday)" >&2
    return 2
  fi
  if [[ ! -d ".spectacular" ]]; then
    echo "Not inside a Spectacular workspace (no .spectacular/ here)." >&2
    return 1
  fi

  local cutoff
  cutoff="$(status_since_resolve_date "$since_input")" || {
    echo "status --since: cannot parse '$since_input' (expected YYYY-MM-DD | <N>d | <N>w | <N>m | yesterday)" >&2
    return 2
  }

  echo "Activity since ${cutoff}:"
  echo ""

  # Requests, grouped by status. Scan both requests/ and archive/.
  local -a archived=() verified=() review=() active=() planned=()
  local dir slug updated status
  shopt -s nullglob
  for dir in .spectacular/requests/*/ .spectacular/archive/*/; do
    [[ -f "$dir/PLAN.md" ]] || continue
    updated="$(fm_get "$dir/PLAN.md" "updated")"
    [[ -z "$updated" ]] && continue
    # Lexicographic compare works for YYYY-MM-DD; cutoff must be in same shape.
    [[ "$updated" < "$cutoff" ]] && continue
    slug="$(basename "$dir")"
    status="$(fm_get "$dir/PLAN.md" "status")"
    case "$status" in
      archived) archived+=("$slug") ;;
      verified) verified+=("$slug") ;;
      review)   review+=("$slug") ;;
      active)   active+=("$slug") ;;
      planned)  planned+=("$slug") ;;
    esac
  done
  shopt -u nullglob

  local req_total=$(( ${#archived[@]} + ${#verified[@]} + ${#review[@]} + ${#active[@]} + ${#planned[@]} ))
  echo "Requests (${req_total}):"
  status_since_print_group "archived" "${archived[@]+"${archived[@]}"}"
  status_since_print_group "verified" "${verified[@]+"${verified[@]}"}"
  status_since_print_group "review"   "${review[@]+"${review[@]}"}"
  status_since_print_group "active"   "${active[@]+"${active[@]}"}"
  status_since_print_group "planned"  "${planned[@]+"${planned[@]}"}"
  [[ $req_total -eq 0 ]] && echo "  (none)"

  # Canonical docs at .spectacular/ root.
  echo ""
  local -a docs=()
  local doc_file doc_base
  shopt -s nullglob
  for doc_file in .spectacular/*.md; do
    doc_base="$(basename "$doc_file")"
    # Skip snapshot files (@v in name)
    [[ "$doc_base" =~ @v ]] && continue
    updated="$(fm_get "$doc_file" "updated")"
    [[ -z "$updated" ]] && continue
    [[ "$updated" < "$cutoff" ]] && continue
    docs+=("$doc_base ($updated)")
  done
  shopt -u nullglob

  echo "Canonical docs (${#docs[@]}):"
  if (( ${#docs[@]} > 0 )); then
    local d
    for d in "${docs[@]}"; do
      echo "  $d"
    done
  else
    echo "  (none)"
  fi

  return 0
}

# Resolve a --since <date> input to an absolute YYYY-MM-DD cutoff.
# Accepts: YYYY-MM-DD, <N>d / <N>w / <N>m, "yesterday".
# Stdout: resolved date. Return 1 if unparseable.
status_since_resolve_date() {
  local input="$1"
  # Already YYYY-MM-DD
  if [[ "$input" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    echo "$input"
    return 0
  fi
  # Relative: <N>d, <N>w, <N>m
  if [[ "$input" =~ ^([0-9]+)(d|w|m)$ ]]; then
    local n="${BASH_REMATCH[1]}" unit="${BASH_REMATCH[2]}"
    local days
    case "$unit" in
      d) days="$n" ;;
      w) days=$((n * 7)) ;;
      m) days=$((n * 30)) ;;  # approximate; good enough for activity reports
    esac
    # BSD date (macOS): -v-Nd. GNU date (Linux): -d "N days ago".
    if date -v-1d >/dev/null 2>&1; then
      date -v-"${days}"d +%Y-%m-%d
    else
      date -d "${days} days ago" +%Y-%m-%d
    fi
    return 0
  fi
  # Special keywords
  if [[ "$input" == "yesterday" ]]; then
    if date -v-1d >/dev/null 2>&1; then
      date -v-1d +%Y-%m-%d
    else
      date -d "1 day ago" +%Y-%m-%d
    fi
    return 0
  fi
  return 1
}

# Print one status group, indented under "Requests (N):".
# Args: <status-name> <item1> <item2> ... (pass array elements inline)
status_since_print_group() {
  local name="$1"
  shift
  (( $# == 0 )) && return 0
  echo "  ${name} ($#):"
  local item
  for item in "$@"; do
    echo "    $item"
  done
}

# Read convention_pack: stanza values from .spectacular/config.yaml
# Stdout: pack source name (empty if no convention_pack block or commented out)
config_pack_source() {
  local cfg=".spectacular/config.yaml"
  [[ -f "$cfg" ]] || return 0
  awk '
    /^convention_pack:/ { in_block=1; next }
    in_block && /^[^[:space:]]/ { in_block=0 }
    in_block && /^  source:/ { gsub(/^  source:[[:space:]]*/, ""); gsub(/[[:space:]]*$/, ""); print; exit }
  ' "$cfg"
}

# Stdout: pack mode (suggest|scaffold|enforce); default "suggest" if convention_pack present without mode.
# Unknown values (e.g. "strict") silently fall back to "suggest" — call config_pack_mode_raw if you
# need to detect the discrepancy (used by check_conventions to emit an info note).
config_pack_mode() {
  local raw
  raw="$(config_pack_mode_raw)"
  case "$raw" in
    suggest|scaffold|enforce) echo "$raw" ;;
    *)                        echo "suggest" ;;  # unknown / empty → fallback
  esac
}

# Stdout: raw mode value as written in config.yaml (whatever string the user typed).
# Empty if convention_pack absent or mode: field omitted. Used by check_conventions
# to detect unknown-mode drift and emit an info note before silently falling back.
config_pack_mode_raw() {
  local cfg=".spectacular/config.yaml"
  [[ -f "$cfg" ]] || return 0
  local src
  src="$(config_pack_source)"
  [[ -z "$src" ]] && return 0
  awk '
    /^convention_pack:/ { in_block=1; next }
    in_block && /^[^[:space:]]/ { in_block=0 }
    in_block && /^  mode:/ { gsub(/^  mode:[[:space:]]*/, ""); gsub(/[[:space:]]*$/, ""); print; exit }
  ' "$cfg"
}

# ══════════════════════════════════════════════════════════════════════════════
# POLICY — the practice layer (v1.12.0)
#
# POLICY.md defines policies under `## @<hook>` sections; config.yaml's
# `policies:` block is an override layer (enable/disable/severity + custom).
# `spectacular policy` reads POLICY.md, applies overrides, returns merged result.
# The skill calls `spectacular policy @<hook>` on entering a phase. Full spec:
# references/policies-contract.md + references/policy-injection.md.
# ══════════════════════════════════════════════════════════════════════════════

POLICY_VALID_HOOKS="@Init @Planning @Implementation @Verification @Archive @Remember @Snapshot @SessionEnd"

# Emit the merged policy table to stdout, one record per line. Fields are
# separated by US (\x1f / octal 037) — NOT tab — because `read` with a
# whitespace IFS collapses consecutive separators, mangling empty fields
# (e.g. a policy with no `principle:` line). Field order:
#   hook⟨US⟩id⟨US⟩principle⟨US⟩severity⟨US⟩enabled⟨US⟩check
# Reads POLICY.md (definition) then applies config.yaml `policies:` overrides.
# Custom policies declared only in config (with a `hook:`) are appended.
_policy_records() {
  local pol=".spectacular/POLICY.md"
  local cfg=".spectacular/config.yaml"
  [[ -f "$pol" ]] || return 0
  local US=$'\037'

  # 1) Parse POLICY.md blocks.
  awk '
    BEGIN { hook=""; id=""; principle=""; severity=""; check=""; US=sprintf("%c",31) }
    function flush() {
      if (id != "") {
        printf "%s%s%s%s%s%s%s%s%s%s%s\n", hook, US, id, US, principle, US, severity, US, "true", US, check
      }
      id=""; principle=""; severity=""; check=""
    }
    /^##[[:space:]]+@/ {
      flush()
      h=$0; sub(/^##[[:space:]]+/, "", h); sub(/[[:space:]]+$/, "", h)
      hook=h; next
    }
    /^###[[:space:]]+/ {
      flush()
      i=$0; sub(/^###[[:space:]]+/, "", i); sub(/[[:space:]]+$/, "", i)
      id=i; next
    }
    /^-[[:space:]]+principle:/ { v=$0; sub(/^-[[:space:]]+principle:[[:space:]]*/, "", v); sub(/[[:space:]]+$/, "", v); principle=v; next }
    /^-[[:space:]]+severity:/  { v=$0; sub(/^-[[:space:]]+severity:[[:space:]]*/, "", v); sub(/[[:space:]]+$/, "", v); severity=v; next }
    /^-[[:space:]]+check:/     { v=$0; sub(/^-[[:space:]]+check:[[:space:]]*/, "", v); sub(/[[:space:]]+$/, "", v); check=v; next }
    END { flush() }
  ' "$pol" | while IFS="$US" read -r hook id principle severity enabled check; do
    # Apply config overrides for this id.
    local ov_enabled ov_severity
    ov_enabled="$(_policy_cfg_get "$id" "enabled")"
    ov_severity="$(_policy_cfg_get "$id" "severity")"
    [[ -n "$ov_enabled" ]]  && enabled="$ov_enabled"
    [[ -n "$ov_severity" ]] && severity="$ov_severity"
    printf '%s%s%s%s%s%s%s%s%s%s%s\n' "$hook" "$US" "$id" "$US" "$principle" "$US" "$severity" "$US" "$enabled" "$US" "$check"
  done

  # 2) Append config-only custom policies (have a `hook:` field, not in POLICY.md).
  [[ -f "$cfg" ]] || return 0
  local defined_ids
  defined_ids="$(awk '/^###[[:space:]]+/ { i=$0; sub(/^###[[:space:]]+/, "", i); sub(/[[:space:]]+$/, "", i); print i }' "$pol" | tr '\n' ' ')"
  _policy_cfg_custom_ids | while IFS= read -r cid; do
    [[ -z "$cid" ]] && continue
    in_list "$cid" "$defined_ids" && continue   # already defined in POLICY.md
    local c_hook c_sev c_check c_pr c_en
    c_hook="$(_policy_cfg_get "$cid" "hook")"
    [[ -z "$c_hook" ]] && continue               # custom must declare a hook
    c_sev="$(_policy_cfg_get "$cid" "severity")"
    c_check="$(_policy_cfg_get "$cid" "check")"
    c_pr="$(_policy_cfg_get "$cid" "principle")"
    c_en="$(_policy_cfg_get "$cid" "enabled")"; [[ -z "$c_en" ]] && c_en="true"
    printf '%s%s%s%s%s%s%s%s%s%s%s\n' "$c_hook" "$US" "$cid" "$US" "$c_pr" "$US" "$c_sev" "$US" "$c_en" "$US" "$c_check"
  done
}

# Read a single field for a policy id from config.yaml's `policies:` block.
# Block shape (2-space indent under `policies:`, 4-space under the id):
#   policies:
#     understand-before-change:
#       enabled: false
#       severity: block
_policy_cfg_get() {
  local id="$1" field="$2" cfg=".spectacular/config.yaml"
  [[ -f "$cfg" ]] || return 0
  awk -v id="$id" -v field="$field" '
    /^policies:/ { in_p=1; next }
    in_p && /^[^[:space:]]/ { in_p=0 }
    in_p && /^  [^[:space:]]/ {
      cur=$1; sub(/:.*/, "", cur); sub(/^[[:space:]]+/, "", cur)
      match_id = (cur == id)
      next
    }
    in_p && match_id && /^    [^[:space:]]/ {
      key=$1; sub(/:.*/, "", key); sub(/^[[:space:]]+/, "", key)
      if (key == field) {
        v=$0; sub(/^[[:space:]]*[^:]+:[[:space:]]*/, "", v); sub(/[[:space:]]+$/, "", v)
        gsub(/^"|"$/, "", v)
        print v; exit
      }
    }
  ' "$cfg"
}

# List all policy ids appearing in config.yaml's `policies:` block.
_policy_cfg_custom_ids() {
  local cfg=".spectacular/config.yaml"
  [[ -f "$cfg" ]] || return 0
  awk '
    /^policies:/ { in_p=1; next }
    in_p && /^[^[:space:]]/ { in_p=0 }
    in_p && /^  [^[:space:]]/ { cur=$1; sub(/:.*/, "", cur); sub(/^[[:space:]]+/, "", cur); print cur }
  ' "$cfg"
}

# Pull a principle's heading + first content line from PRINCIPLES.md.
# Arg: principle number N. Stdout: "N. <heading> — <first line>" or empty.
_policy_principle_line() {
  local n="$1" pr=".spectacular/PRINCIPLES.md"
  [[ -n "$n" ]] || return 0
  [[ -f "$pr" ]] || return 0
  awk -v n="$n" '
    $0 ~ "^##[[:space:]]+" n "\\." {
      head=$0; sub(/^##[[:space:]]+/, "", head)
      body=""; got=0
      while ((getline line) > 0) {
        if (line ~ /^##[[:space:]]/) break          # next heading → no body
        if (line ~ /^[[:space:]]*$/) continue       # skip blank lines
        body=line; got=1; break
      }
      sub(/^[[:space:]]+/, "", body)
      if (got) print head " — " body                # body found
      else     print head                           # heading only — no dangling em-dash
      exit
    }
  ' "$pr"
}

# is this severity a blocker? (opt-in: only literal "block")
_policy_is_block() { [[ "$1" == "block" ]]; }

# Look up one policy's MERGED state (POLICY.md + config overrides) by id.
# Stdout: "enabled<US>severity" (e.g. "true<US>block"); empty if the id is unknown.
# Use this — not the raw POLICY.md text — before enforcing a gate, so config
# `enabled: false` / severity overrides are honored.
_policy_lookup() {
  local want="$1" US=$'\037' hook id principle severity enabled check
  while IFS="$US" read -r hook id principle severity enabled check; do
    [[ "$id" == "$want" ]] || continue
    printf '%s%s%s\n' "${enabled:-true}" "$US" "$severity"
    return 0
  done < <(_policy_records)
  return 0
}

# Is a policy enabled in the merged contract? (default: true if id unknown — a
# gate hard-coded in a ref doc shouldn't vanish just because POLICY.md was edited).
_policy_enabled() {
  local rec; rec="$(_policy_lookup "$1")"
  [[ -z "$rec" ]] && return 0                       # unknown id → treat as enabled
  local US=$'\037'
  local en="${rec%%"$US"*}"
  case "$en" in
    false|no|off|0|False|FALSE|No|NO) return 1 ;;   # disabled
    *) return 0 ;;
  esac
}

cmd_policy() {
  local form="list" arg="" principle_filter="" json=false
  while (( $# > 0 )); do
    case "$1" in
      --principle) require_value "--principle" "${2:-}"; principle_filter="$2"; form="principle"; shift 2 ;;
      --principle=*) principle_filter="${1#--principle=}"; form="principle"; shift ;;
      --json) json=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular policy [@hook | <id> | --principle N | --json]

Read the merged policy contract (POLICY.md + config.yaml overrides).

Forms:
  spectacular policy                 All policies, grouped by hook (skim)
  spectacular policy @Verification   One hook's policies + linked principle lines
  spectacular policy <id>            One policy, full text + its principle
  spectacular policy --principle N   Reverse: which policies enforce principle N
  spectacular policy --json          Machine form (skill-consumed)

The skill calls 'spectacular policy @<hook>' on entering a work phase.
Valid hooks: ${POLICY_VALID_HOOKS}
EOF
        exit 0 ;;
      @*) arg="$1"; form="hook"; shift ;;
      -*) die "Unknown flag for policy: $1" ;;
      *)  arg="$1"; form="id"; shift ;;
    esac
  done

  [[ -d ".spectacular" ]] || die "policy: not inside a Spectacular workspace"
  [[ -f ".spectacular/POLICY.md" ]] || die_recover "policy: .spectacular/POLICY.md not found" \
    "spectacular doctor --fix   # re-scaffold the always-set POLICY.md"

  # Validate hook arg against the known set.
  if [[ "$form" == "hook" ]] && ! in_list "$arg" "$POLICY_VALID_HOOKS"; then
    die "policy: unknown hook '$arg'. Valid: ${POLICY_VALID_HOOKS}"
  fi

  local records US=$'\037'
  records="$(_policy_records)"
  [[ -z "$records" ]] && { info "(no policies defined)"; return 0; }

  # ── JSON form ──────────────────────────────────────────────────────────────
  if $json; then
    printf '['
    local i=0 hook id principle severity enabled check
    while IFS="$US" read -r hook id principle severity enabled check; do
      [[ -z "$id" ]] && continue
      # Apply filters
      if [[ "$form" == "hook" && "$hook" != "$arg" ]]; then continue; fi
      if [[ "$form" == "id"   && "$id"   != "$arg" ]]; then continue; fi
      if [[ "$form" == "principle" && "$principle" != "$principle_filter" ]]; then continue; fi
      local is_block="false"; _policy_is_block "$severity" && is_block="true"
      # Normalize enabled to a literal JSON boolean — config may carry yes/no/1/etc.
      local en_json="true"
      case "${enabled:-true}" in
        false|no|off|0|False|FALSE|No|NO) en_json="false" ;;
        *) en_json="true" ;;
      esac
      (( i > 0 )) && printf ','
      printf '{"hook":"%s","id":"%s","principle":"%s","severity":"%s","blocking":%s,"enabled":%s,"check":"%s"}' \
        "$(_json_escape "$hook")" "$(_json_escape "$id")" "$(_json_escape "$principle")" \
        "$(_json_escape "$severity")" "$is_block" "$en_json" "$(_json_escape "$check")"
      i=$((i + 1))
    done <<< "$records"
    printf ']\n'
    return 0
  fi

  # ── id form: one policy, full text + principle ───────────────────────────────
  if [[ "$form" == "id" ]]; then
    local found=false hook id principle severity enabled check
    while IFS="$US" read -r hook id principle severity enabled check; do
      [[ "$id" == "$arg" ]] || continue
      found=true
      local sev_disp="${severity:-warn}"; _policy_is_block "$sev_disp" && sev_disp="block (refuse)" || sev_disp="${sev_disp} (surface + continue)"
      echo "$id"
      echo "  hook:      $hook"
      echo "  severity:  $sev_disp"
      [[ "${enabled:-true}" == "false" ]] && echo "  enabled:   false (disabled via config)"
      [[ -n "$principle" ]] && echo "  principle: $principle"
      echo "  check:     $check"
      if [[ -n "$principle" ]]; then
        local pl; pl="$(_policy_principle_line "$principle")"
        [[ -n "$pl" ]] && echo "  → P$pl"
      fi
    done <<< "$records"
    $found || die "policy: no policy with id '$arg'"
    return 0
  fi

  # ── principle form: reverse lookup ───────────────────────────────────────────
  if [[ "$form" == "principle" ]]; then
    [[ "$principle_filter" =~ ^[0-9]+$ ]] || die "policy: --principle expects a number"
    local pl; pl="$(_policy_principle_line "$principle_filter")"
    echo "Principle $principle_filter${pl:+: ${pl#*. }}"
    echo ""
    local any=false hook id principle severity enabled check
    printf "%-28s  %-16s  %s\n" "POLICY" "HOOK" "SEVERITY"
    printf "%-28s  %-16s  %s\n" "------" "----" "--------"
    while IFS="$US" read -r hook id principle severity enabled check; do
      [[ "$principle" == "$principle_filter" ]] || continue
      any=true
      printf "%-28s  %-16s  %s\n" "$id" "$hook" "${severity:-warn}"
    done <<< "$records"
    $any || info "(no policies enforce principle $principle_filter)"
    return 0
  fi

  # ── hook form / bare list ────────────────────────────────────────────────────
  # Group by hook; in hook-form, show only the requested hook + principle lines.
  local current_hook="" hook id principle severity enabled check shown=0
  local order="$POLICY_VALID_HOOKS"
  local h
  for h in $order; do
    [[ "$form" == "hook" && "$h" != "$arg" ]] && continue
    local hook_has=false
    while IFS="$US" read -r hook id principle severity enabled check; do
      [[ "$hook" == "$h" ]] || continue
      [[ -z "$id" ]] && continue
      if ! $hook_has; then
        echo "$h"
        hook_has=true
      fi
      local marker="·"; _policy_is_block "$severity" && marker="⛔"
      local dis=""; [[ "${enabled:-true}" == "false" ]] && dis="  [disabled]"
      printf "  %s %-28s %-6s%s\n" "$marker" "$id" "${severity:-warn}" "$dis"
      shown=$((shown + 1))
      # In hook form, pull the linked principle line (the workhorse behavior).
      if [[ "$form" == "hook" && -n "$principle" ]]; then
        local pl; pl="$(_policy_principle_line "$principle")"
        [[ -n "$pl" ]] && printf "      → P%s\n" "$pl"
      fi
    done <<< "$records"
  done
  (( shown == 0 )) && info "(no policies for ${arg:-this workspace})"
  if [[ "$form" == "list" ]]; then
    echo ""
    info "⛔ = blocks   · = warns.   spectacular policy @<hook> for one phase's rules + principles."
  fi
  return 0
}

