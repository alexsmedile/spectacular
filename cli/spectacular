# ── main ──────────────────────────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════════════
# DOCTOR — environment / infrastructure self-check
#
# CLI detects substrate drift. Mechanical fixes (gitignore append, missing dirs,
# dangling symlinks, missing always-set stubs) can apply via --fix. Anything
# requiring judgment is reported as fix_type=judgment and routes to the skill
# (/spectacular doctor --fix). See references/doctor.md for the full spec.
# ══════════════════════════════════════════════════════════════════════════════

# ── doctor globals ────────────────────────────────────────────────────────────
DOC_OPT_AREA=""        # empty = all areas
DOC_OPT_FIX=false
DOC_OPT_FORMAT="text"  # text | json

DOC_AREAS="skill workspace frontmatter snapshots links lifecycle kits conventions specs docs"

# Findings accumulator. Each line:  area|severity|file|message|proposed_fix|fix_type
# severity: pass | warning | error | info
# fix_type: mechanical | judgment | none
DOC_FINDINGS=""

doc_add() {
  local area="$1" sev="$2" file="$3" msg="$4" fix="${5:-}" ftype="${6:-none}"
  DOC_FINDINGS+="${area}|${sev}|${file}|${msg}|${fix}|${ftype}"$'\n'
}

# ── usage block for doctor ────────────────────────────────────────────────────
doctor_usage() {
  cat <<EOF
Usage: spectacular doctor [<area>] [options]

Run substrate self-check on the current .spectacular/ workspace.

Areas (run all if omitted):
  skill         skill install + symlinks + skills.lock
  workspace     .spectacular/ directory + always-set + config.yaml
  frontmatter   required fields per canonical doc; schema versions
  snapshots     version-sequence continuity (PRD@v1.0 + v1.2 without v1.1)
  links         related: frontmatter targets exist
  lifecycle     request status vs required verification artifacts
  kits          bundled + project-local kit files parse cleanly
  conventions   active convention_pack resolves; gitignore drift in scaffold/enforce modes
  specs         SPEC.md present + parseable; specs/ dir present; legacy current/ migration
  docs          docs.yaml + frontmatter validation across the docs/ tree (v0.6.0+)

Options:
  --fix              Apply mechanical fixes (gitignore append, missing dirs,
                     dangling symlinks, missing always-set stubs). Judgment
                     fixes require the skill: /spectacular doctor --fix.
  --format text|json Report format (default: text). JSON suitable for the
                     skill or other tools to consume.
  -h, --help         Show this help

Exit codes: 0 clean, 1 warnings only, 2 errors present.

Examples:
  spectacular doctor
  spectacular doctor frontmatter
  spectacular doctor --fix
  spectacular doctor --format json > .spectacular/.doctor-report.json
EOF
}

doctor_parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fix) DOC_OPT_FIX=true; shift ;;
      --format) DOC_OPT_FORMAT="$2"; shift 2 ;;
      -h|--help) doctor_usage; exit 0 ;;
      skill|workspace|frontmatter|snapshots|links|lifecycle|kits|conventions|specs|docs)
        DOC_OPT_AREA="$1"; shift ;;
      *) die "Unknown doctor option: $1. Run 'spectacular doctor --help'." ;;
    esac
  done

  if [[ "$DOC_OPT_FORMAT" != "text" && "$DOC_OPT_FORMAT" != "json" ]]; then
    die "--format must be 'text' or 'json'"
  fi
}

# ── area: skill ───────────────────────────────────────────────────────────────
check_skill() {
  local agents_dir claude_dir lock_ref
  agents_dir="$(agents_skill_dir)"
  claude_dir="$(claude_skill_dir)"

  # Install path
  if [[ -d "$agents_dir" || -L "$agents_dir" ]]; then
    doc_add "skill" "pass" "$agents_dir" "skill installed"
  else
    doc_add "skill" "error" "$agents_dir" "skill not installed at this path" \
      "re-run \`spectacular init\` (or \`spectacular init --update\`)" "judgment"
    return
  fi

  # Symlink validity. Only report a problem when .claude/ exists (user is
  # actively using Claude Code) but the symlink under it is missing/broken.
  # If .claude/ doesn't exist at all, the user isn't using Claude Code here
  # and there's nothing to fix.
  local claude_parent
  claude_parent=$(dirname "$claude_dir")
  if [[ -L "$claude_dir" ]]; then
    if [[ -e "$claude_dir" ]]; then
      doc_add "skill" "pass" "$claude_dir" "symlink resolves"
    else
      doc_add "skill" "error" "$claude_dir" "symlink is dangling (target missing)" \
        "recreate symlink to $agents_dir" "mechanical"
    fi
  elif [[ -d "$claude_parent" ]] && [[ ! -e "$claude_dir" ]]; then
    doc_add "skill" "warning" "$claude_dir" "no symlink found (claude dir exists but skill not symlinked here)" \
      "create symlink from $claude_dir to $agents_dir" "mechanical"
  fi

  # skills.lock present + parseable
  # If running in the spectacular source repo itself (where cli/spectacular lives),
  # missing skills.lock is expected — downgrade warning to info.
  local lock="$(pwd)/.spectacular/skills.lock"
  local is_source_repo=false
  if [[ -f "$(pwd)/cli/spectacular" && -d "$(pwd)/skills/spectacular" ]]; then
    is_source_repo=true
  fi
  if [[ -f "$lock" ]]; then
    if grep -q "^spectacular:" "$lock" 2>/dev/null || grep -q "ref:" "$lock" 2>/dev/null; then
      doc_add "skill" "pass" ".spectacular/skills.lock" "skills.lock present"
    else
      doc_add "skill" "warning" ".spectacular/skills.lock" "skills.lock present but no ref/version detected" "" "judgment"
    fi
  elif $is_source_repo; then
    doc_add "skill" "info" ".spectacular/skills.lock" "absent (this is the spectacular source repo — expected)"
  else
    doc_add "skill" "warning" ".spectacular/skills.lock" "missing (skill may not have been installed via CLI)" "" "judgment"
  fi

  # SKILL.md parseable
  local skill_md="$agents_dir/SKILL.md"
  if [[ -f "$skill_md" ]]; then
    if head -1 "$skill_md" | grep -q '^---$'; then
      doc_add "skill" "pass" "$skill_md" "SKILL.md frontmatter loads"
    else
      doc_add "skill" "error" "$skill_md" "SKILL.md missing frontmatter delimiter" \
        "re-install the skill via \`spectacular init --update\`" "judgment"
    fi
  else
    doc_add "skill" "error" "$skill_md" "SKILL.md missing" \
      "re-install the skill via \`spectacular init --update\`" "judgment"
  fi
}

# ── area: workspace ───────────────────────────────────────────────────────────
check_workspace() {
  if [[ ! -d ".spectacular" ]]; then
    doc_add "workspace" "error" ".spectacular/" "directory missing — workspace not initialized" \
      "run \`spectacular init\`" "judgment"
    return
  fi
  doc_add "workspace" "pass" ".spectacular/" "workspace directory present"

  # Always-set files (per smart-init's definition)
  # Determine which agents-file is in use by reading config.yaml first
  local agents_file="AGENTS.md"
  if [[ -f ".spectacular/config.yaml" ]]; then
    local cfg_agents
    cfg_agents=$(awk '/^  file:/ { print $2; exit }' ".spectacular/config.yaml" 2>/dev/null)
    [[ -n "$cfg_agents" ]] && agents_file="$cfg_agents"
  fi

  local always_set=("PRD.md" "SPEC.md" "config.yaml" "$agents_file")
  for f in "${always_set[@]}"; do
    if [[ -f ".spectacular/$f" ]]; then
      doc_add "workspace" "pass" ".spectacular/$f" "always-set file present"
    else
      doc_add "workspace" "error" ".spectacular/$f" "always-set file missing" \
        "re-scaffold via \`spectacular doctor --fix\` or \`spectacular init\`" "mechanical"
    fi
  done

  # Always-set directories
  for d in "requests" "specs"; do
    if [[ -d ".spectacular/$d" ]]; then
      doc_add "workspace" "pass" ".spectacular/$d/" "always-set directory present"
    else
      doc_add "workspace" "error" ".spectacular/$d/" "always-set directory missing" \
        "mkdir -p .spectacular/$d (mechanical fix available)" "mechanical"
    fi
  done

  # config.yaml parses
  if [[ -f ".spectacular/config.yaml" ]]; then
    if grep -q "^project:" ".spectacular/config.yaml" 2>/dev/null; then
      doc_add "workspace" "pass" ".spectacular/config.yaml" "config.yaml has project: stanza"
    else
      doc_add "workspace" "error" ".spectacular/config.yaml" "config.yaml missing project: stanza" \
        "rewrite config.yaml with project name/summary/kit" "judgment"
    fi
  fi

  # .gitignore present + includes .spectacular.local/
  local gitignore=".gitignore"
  if [[ -f "$gitignore" ]]; then
    if grep -qF ".spectacular.local/" "$gitignore"; then
      doc_add "workspace" "pass" ".gitignore" ".spectacular.local/ ignored"
    else
      doc_add "workspace" "warning" ".gitignore" "missing .spectacular.local/ entry" \
        "append .spectacular.local/ to .gitignore" "mechanical"
    fi
  else
    doc_add "workspace" "warning" ".gitignore" ".gitignore not found; .spectacular.local/ unprotected" \
      "create .gitignore with .spectacular.local/" "mechanical"
  fi
}

# ── area: frontmatter ─────────────────────────────────────────────────────────
# For each canonical .md at .spectacular/ root, check it has frontmatter delimiters
# and required fields (version, updated, summary). Schema-version drift = warning.
check_frontmatter() {
  if [[ ! -d ".spectacular" ]]; then
    return
  fi

  local required_fields="version updated summary"
  shopt -s nullglob
  # Note: only scan .spectacular root, not archive/ (archive is read-only per architecture)
  for f in .spectacular/*.md; do
    local base
    base=$(basename "$f")

    # Skip snapshot files (handled by snapshots area)
    if [[ "$base" =~ @v ]]; then
      continue
    fi

    # Frontmatter delimiter check
    if ! head -1 "$f" | grep -q '^---$'; then
      doc_add "frontmatter" "error" "$f" "missing frontmatter delimiter (first line must be '---')" \
        "add proper frontmatter block" "judgment"
      continue
    fi

    # Extract frontmatter block (between first two ---)
    local fm
    fm=$(awk '/^---$/ { count++; if (count == 2) exit; next } count == 1' "$f")

    for field in $required_fields; do
      if ! echo "$fm" | grep -q "^${field}:"; then
        doc_add "frontmatter" "warning" "$f" "missing required field: ${field}" \
          "add \`${field}:\` to frontmatter" "judgment"
      fi
    done

    # ISO date check on updated:
    local updated_val
    updated_val=$(echo "$fm" | awk -F': ' '/^updated:/ { print $2; exit }' | tr -d '"' | tr -d "'")
    if [[ -n "$updated_val" ]] && ! [[ "$updated_val" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
      doc_add "frontmatter" "warning" "$f" "\`updated:\` not in ISO format (got: $updated_val)" \
        "use YYYY-MM-DD format" "judgment"
    fi
  done
  shopt -u nullglob
}

# ── area: snapshots ───────────────────────────────────────────────────────────
# For each <doc>@v<N>.<M>.md, group by doc and detect gaps in version sequence.
check_snapshots() {
  if [[ ! -d ".spectacular" ]]; then
    return
  fi

  # Group snapshots by canonical doc name (the prefix before @v)
  shopt -s nullglob
  local snapshots=(.spectacular/*@v*.md)
  shopt -u nullglob

  if [[ ${#snapshots[@]} -eq 0 ]]; then
    return  # No snapshots is fine — many workspaces have none yet
  fi

  # Collect unique doc bases
  local doc_bases=""
  for s in "${snapshots[@]}"; do
    local base
    base=$(basename "$s")
    local prefix="${base%@v*}"
    if ! in_list "$prefix" "$doc_bases"; then
      doc_bases+="$prefix "
    fi
  done

  # For each base, collect versions and check continuity
  for base in $doc_bases; do
    local versions=""
    for s in "${snapshots[@]}"; do
      local b
      b=$(basename "$s")
      [[ "$b" == "${base}@v"* ]] || continue
      # Extract X.Y from <base>@vX.Y.md
      local ver="${b#${base}@v}"
      ver="${ver%.md}"
      versions+="$ver "
    done

    # Parse major.minor pairs, sort, look for gaps in the minor sequence within
    # each major. Heuristic: if v<M>.<N1> and v<M>.<N3> exist but v<M>.<N2> is
    # missing for any 0 < N2 < max minor, flag the gap.
    local sorted
    sorted=$(echo "$versions" | tr ' ' '\n' | sort -t. -k1n -k2n | grep -v '^$' | tr '\n' ' ')

    # Build minor-version list per major
    local prev_major="" prev_minor=""
    for v in $sorted; do
      local major="${v%.*}"
      local minor="${v#*.}"
      if [[ "$major" == "$prev_major" ]]; then
        local expected=$((prev_minor + 1))
        while [[ $expected -lt $minor ]]; do
          local missing="${major}.${expected}"
          doc_add "snapshots" "warning" ".spectacular/${base}@v${missing}.md" \
            "version-sequence gap (have v${prev_major}.${prev_minor} and v${major}.${minor})" \
            "backfill from git log if possible, or document the skip in DECISIONS.md" \
            "judgment"
          expected=$((expected + 1))
        done
      fi
      prev_major="$major"
      prev_minor="$minor"
    done

    if [[ -z "$sorted" ]]; then continue; fi
    doc_add "snapshots" "info" ".spectacular/${base}@v*.md" \
      "$(echo "$sorted" | wc -w | tr -d ' ') snapshot(s) found for $base"
  done
}

# ── area: links ───────────────────────────────────────────────────────────────
# Walk every canonical .md, extract `related:` frontmatter entries, verify each
# target exists (resolved relative to the file's location).
check_links() {
  if [[ ! -d ".spectacular" ]]; then return; fi

  shopt -s nullglob
  while IFS= read -r f; do
    [[ -f "$f" ]] || continue
    # Skip snapshots
    if [[ "$(basename "$f")" =~ @v ]]; then continue; fi
    # Skip archive/ per architecture: skill does not read archive/ during normal operation
    if [[ "$f" == *".spectacular/archive/"* ]]; then continue; fi

    local in_fm=false in_related=false
    while IFS= read -r line; do
      if [[ "$line" == "---" ]]; then
        if $in_fm; then break; else in_fm=true; continue; fi
      fi
      $in_fm || continue
      if [[ "$line" =~ ^related: ]]; then in_related=true; continue; fi
      # Exit related: block on next top-level key
      if $in_related && [[ "$line" =~ ^[a-zA-Z] ]]; then in_related=false; fi

      if $in_related && [[ "$line" =~ ^[[:space:]]+-[[:space:]]+(.+)$ ]]; then
        local target="${BASH_REMATCH[1]}"
        # Strip quotes + comments
        target="${target%%#*}"
        target="${target%\"}"; target="${target#\"}"
        target="${target%\'}"; target="${target#\'}"
        target="$(echo "$target" | xargs)"  # trim whitespace
        [[ -z "$target" ]] && continue

        # Resolve relative to file's dir
        local base_dir
        base_dir=$(dirname "$f")
        local resolved="$base_dir/$target"

        if [[ -e "$resolved" ]]; then
          : # pass — don't spam pass entries for every link
        else
          doc_add "links" "warning" "$f" \
            "related: target '$target' does not exist (resolved: $resolved)" \
            "remove the stale link or fix the target" \
            "judgment"
        fi
      fi
    done < "$f"
  done < <(find ".spectacular" -type f -name "*.md")
  shopt -u nullglob

  # If no warnings emitted, add a single pass note
  if ! echo "$DOC_FINDINGS" | grep -q "^links|warning"; then
    doc_add "links" "pass" ".spectacular/" "all related: targets resolve"
  fi
}

# ── area: lifecycle ───────────────────────────────────────────────────────────
# For each request, check status frontmatter against required artifacts.
check_lifecycle() {
  if [[ ! -d ".spectacular/requests" ]]; then return; fi

  shopt -s nullglob
  local request_dirs=(.spectacular/requests/*/)
  shopt -u nullglob

  if [[ ${#request_dirs[@]} -eq 0 ]]; then
    doc_add "lifecycle" "info" ".spectacular/requests/" "no requests yet"
    return
  fi

  local issues=0
  for d in "${request_dirs[@]}"; do
    local plan="$d/PLAN.md"
    local slug
    slug=$(basename "$d")

    if [[ ! -f "$plan" ]]; then
      doc_add "lifecycle" "warning" "$plan" "request '$slug' has no PLAN.md" "" "judgment"
      issues=$((issues + 1))
      continue
    fi

    local status
    status=$(awk -F': ' '/^---$/{c++; next} c==1 && /^status:/ { print $2; exit }' "$plan" | tr -d '"' | tr -d "'" | xargs)

    case "$status" in
      active)
        if [[ ! -f "$d/SESSION.md" ]]; then
          doc_add "lifecycle" "warning" "$d" "request '$slug' active without SESSION.md" \
            "create SESSION.md or move status back to planned" "judgment"
          issues=$((issues + 1))
        fi
        ;;
      review|verified)
        # Must have at least one verification artifact:
        # VERIFY.md OR TASKS.md with ### Verification section OR PLAN.md with ## Validation
        local has_verify=false
        if [[ -f "$d/VERIFY.md" ]]; then
          has_verify=true
          # When status=verified, VERIFY.md must have zero unchecked items
          if [[ "$status" == "verified" ]] && grep -qE '^- \[ \]' "$d/VERIFY.md"; then
            doc_add "lifecycle" "error" "$d/VERIFY.md" \
              "request '$slug' is verified but VERIFY.md has unchecked items" \
              "complete remaining items or move status back to review" \
              "judgment"
            issues=$((issues + 1))
          fi
        fi
        if ! $has_verify; then
          local has_tasks_verif=false
          [[ -f "$d/TASKS.md" ]] && grep -qE "^### Verification|^## Verification" "$d/TASKS.md" && has_tasks_verif=true
          local has_plan_valid=false
          # Per [[verification]], PLAN's validation may live under several heading names:
          # "Validation", "Success criteria", "Goals & success criteria", or "Acceptance"
          grep -qE "^## .*[Vv]alidation|^## .*[Ss]uccess criteria|^## .*[Aa]cceptance" "$plan" && has_plan_valid=true
          if ! $has_tasks_verif && ! $has_plan_valid; then
            doc_add "lifecycle" "error" "$d" \
              "request '$slug' is $status without any verification artifact (VERIFY.md / TASKS Verification / PLAN Validation)" \
              "add one of: VERIFY.md (2-of-6 rule), TASKS § Verification, or PLAN § Validation/Success criteria" \
              "judgment"
            issues=$((issues + 1))
          fi
        fi

        # Stale verified — info only
        if [[ "$status" == "verified" ]]; then
          local updated
          updated=$(awk -F': ' '/^---$/{c++; next} c==1 && /^updated:/ { print $2; exit }' "$plan" | tr -d '"' | tr -d "'" | xargs)
          if [[ -n "$updated" ]]; then
            local age_days
            age_days=$(( ( $(date +%s) - $(date -j -f "%Y-%m-%d" "$updated" +%s 2>/dev/null || echo 0) ) / 86400 ))
            if [[ $age_days -gt 7 && $age_days -lt 99999 ]]; then
              doc_add "lifecycle" "info" "$d" \
                "request '$slug' verified $age_days days ago — archive candidate" \
                "run \`spectacular archive $slug\`" \
                "judgment"
            fi
          fi
        fi
        ;;
      planned)
        : # No verification artifact required for planned
        ;;
      "")
        doc_add "lifecycle" "warning" "$plan" "request '$slug' has no status: field" "" "judgment"
        issues=$((issues + 1))
        ;;
    esac
  done

  if [[ $issues -eq 0 ]]; then
    doc_add "lifecycle" "pass" ".spectacular/requests/" "all requests have valid lifecycle state"
  fi
}

# ── area: kits ────────────────────────────────────────────────────────────────
check_kits() {
  local agents_dir
  agents_dir="$(agents_skill_dir)"
  local kits_dir="$agents_dir/templates/prd/kits"

  if [[ ! -d "$kits_dir" ]]; then
    doc_add "kits" "warning" "$kits_dir" "bundled kits directory missing" \
      "re-install skill via \`spectacular init --update\`" "judgment"
    return
  fi

  shopt -s nullglob
  local kit_files=("$kits_dir"/*.md)
  shopt -u nullglob

  local ok=0 bad=0
  for kit in "${kit_files[@]}"; do
    local name
    name=$(basename "$kit" .md)
    # Frontmatter present?
    if ! head -1 "$kit" | grep -q '^---$'; then
      doc_add "kits" "error" "$kit" "kit '$name' has no frontmatter" \
        "fix kit frontmatter or re-install skill" "judgment"
      bad=$((bad + 1))
      continue
    fi
    # extends: prd (only allowed value in v1)
    local extends_val
    extends_val=$(awk -F': ' '/^---$/{c++; next} c==1 && /^extends:/ { print $2; exit }' "$kit" | xargs)
    if [[ -n "$extends_val" && "$extends_val" != "prd" ]]; then
      doc_add "kits" "error" "$kit" "kit '$name' extends '$extends_val' (only 'prd' allowed in v1)" \
        "change to extends: prd or remove kit" "judgment"
      bad=$((bad + 1))
      continue
    fi
    # triggers-docs entries match KNOWN_DOCS
    local triggers
    triggers=$(kit_triggers_always "$name")
    triggers+=" $(kit_triggers_suggested "$name")"
    local kit_ok=true
    for doc in $triggers; do
      [[ -z "$doc" ]] && continue
      if ! in_list "$doc" "$KNOWN_DOCS"; then
        doc_add "kits" "warning" "$kit" "kit '$name' triggers-docs references unknown doc ID: '$doc'" \
          "remove or rename to a known doc ID: $KNOWN_DOCS" "judgment"
        kit_ok=false
      fi
    done
    if $kit_ok; then ok=$((ok + 1)); else bad=$((bad + 1)); fi
  done

  # Project-local kits override
  local local_kits=".spectacular/templates/prd/kits"
  if [[ -d "$local_kits" ]]; then
    shopt -s nullglob
    local local_files=("$local_kits"/*.md)
    shopt -u nullglob
    if [[ ${#local_files[@]} -gt 0 ]]; then
      doc_add "kits" "info" "$local_kits" "${#local_files[@]} project-local kit override(s) found"
    fi
  fi

  # PRD kit identity check
  if [[ -f ".spectacular/PRD.md" ]]; then
    local prd_kit
    prd_kit=$(awk -F': ' '/^---$/{c++; next} c==1 && /^kit:/ { print $2; exit }' .spectacular/PRD.md | xargs)
    if [[ -n "$prd_kit" ]]; then
      if [[ -f "$kits_dir/$prd_kit.md" ]] || [[ -f "$local_kits/$prd_kit.md" ]]; then
        doc_add "kits" "pass" ".spectacular/PRD.md" "declared kit '$prd_kit' is resolvable"
      else
        doc_add "kits" "error" ".spectacular/PRD.md" "declares kit '$prd_kit' but no matching kit file found" \
          "install missing kit or change PRD's kit: field" "judgment"
      fi
    fi
  fi

  if [[ $bad -eq 0 && $ok -gt 0 ]]; then
    doc_add "kits" "pass" "$kits_dir" "$ok bundled kits parse cleanly"
  fi
}

# check_conventions — validates the active convention pack and (when mode=enforce)
# flags drift between project state and the pack's declared rules.
# Active only when .spectacular/config.yaml declares convention_pack:.
check_conventions() {
  local pack_src_name pack_mode
  pack_src_name="$(config_pack_source 2>/dev/null)"

  if [[ -z "$pack_src_name" ]]; then
    doc_add "conventions" "info" ".spectacular/config.yaml" "no convention_pack declared — skipped"
    return
  fi

  pack_mode="$(config_pack_mode)"
  local pack_resolved
  if ! pack_resolved="$(pack_resolve "$pack_src_name")"; then
    doc_add "conventions" "error" ".spectacular/config.yaml" \
      "convention_pack source '$pack_src_name' not found in any scope" \
      "run 'spectacular pack install $pack_src_name' or change source in config.yaml" "judgment"
    return
  fi

  doc_add "conventions" "pass" "$pack_resolved" "active pack '$pack_src_name' ($pack_mode) resolves to $(pack_scope_of "$pack_resolved")"

  # In suggest mode, doctor only reports the pack is active; no drift checks
  if [[ "$pack_mode" == "suggest" ]]; then
    doc_add "conventions" "info" "$pack_resolved" "mode=suggest — drift checks are disabled (use scaffold or enforce)"
    return
  fi

  # In scaffold/enforce modes, check gitignore alignment
  local gitignore=".gitignore"
  if [[ ! -f "$gitignore" ]]; then
    doc_add "conventions" "warning" ".gitignore" "pack '$pack_src_name' declares gitignore.always-add but .gitignore is missing" \
      "create .gitignore (or run 'spectacular init' to scaffold)" "mechanical"
    return
  fi

  local missing=0 expected=0
  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    expected=$((expected + 1))
    if ! grep -qF -- "$entry" "$gitignore"; then
      local sev="warning"
      [[ "$pack_mode" == "enforce" ]] && sev="error"
      doc_add "conventions" "$sev" ".gitignore" \
        "pack '$pack_src_name' requires gitignore entry: '$entry' (missing)" \
        "append to .gitignore (or run 'spectacular init' to re-apply pack)" "mechanical"
      missing=$((missing + 1))
    fi
  done < <(pack_gitignore_always_add "$pack_resolved")

  if [[ $expected -gt 0 && $missing -eq 0 ]]; then
    doc_add "conventions" "pass" ".gitignore" "all $expected required gitignore entries from pack '$pack_src_name' present"
  fi
}

# ── area: specs ───────────────────────────────────────────────────────────────
# Validate the system-spec surface: SPEC.md index + specs/ dir + legacy current/ migration.
# Per-capability files under specs/<capability>/SPEC.md are optional (only for complex work).
check_specs() {
  [[ -d ".spectacular" ]] || return 0

  local spec_file=".spectacular/SPEC.md"
  local specs_dir=".spectacular/specs"
  local legacy_dir=".spectacular/current"

  # Conflict: both current/ and specs/ present → manual merge required
  if [[ -d "$legacy_dir" && -d "$specs_dir" ]]; then
    doc_add "specs" "error" "$legacy_dir" \
      "both .spectacular/current/ and .spectacular/specs/ exist — manual merge required (no auto-fix)" \
      "move contents of current/ into specs/, then 'rmdir .spectacular/current'" "judgment"
    return
  fi

  # Legacy: current/ present without specs/ → mechanical rename available
  if [[ -d "$legacy_dir" && ! -d "$specs_dir" ]]; then
    doc_add "specs" "warning" "$legacy_dir" \
      "legacy current/ folder found — rename to specs/ (current/ deprecated in v0.5.0)" \
      "mv .spectacular/current .spectacular/specs" "mechanical"
    return
  fi

  # specs/ dir present
  if [[ -d "$specs_dir" ]]; then
    doc_add "specs" "pass" "$specs_dir/" "specs/ directory present"
  else
    doc_add "specs" "error" "$specs_dir/" "specs/ directory missing" \
      "mkdir -p .spectacular/specs (mechanical fix available)" "mechanical"
  fi

  # SPEC.md present + parseable
  if [[ -f "$spec_file" ]]; then
    if head -1 "$spec_file" | grep -q '^---$'; then
      doc_add "specs" "pass" "$spec_file" "SPEC.md present with frontmatter"
    else
      doc_add "specs" "error" "$spec_file" "SPEC.md missing frontmatter delimiter" \
        "add proper frontmatter block" "judgment"
    fi
  else
    doc_add "specs" "error" "$spec_file" "SPEC.md missing" \
      "re-scaffold via 'spectacular doctor --fix' or 'spectacular init'" "mechanical"
  fi

  # Per-capability subfolders: optional; if present, each must hold a SPEC.md
  shopt -s nullglob
  for subdir in "$specs_dir"/*/; do
    local cap_spec="${subdir}SPEC.md"
    if [[ -f "$cap_spec" ]]; then
      if head -1 "$cap_spec" | grep -q '^---$'; then
        doc_add "specs" "pass" "$cap_spec" "capability spec present"
      else
        doc_add "specs" "warning" "$cap_spec" "capability spec missing frontmatter delimiter" \
          "add proper frontmatter block" "judgment"
      fi
    else
      doc_add "specs" "warning" "$subdir" "capability folder missing SPEC.md" \
        "create ${cap_spec} or remove the empty folder" "judgment"
    fi
  done
  shopt -u nullglob
}

# ── area: docs (v0.6.0+) ──────────────────────────────────────────────────────
# Validate the public-docs surface — see docs-contract.md for full schema.
# Skipped silently if no docs/ tree exists (docs are opt-in, not always-set).
check_docs() {
  local docs_dir="docs"
  local manifest="${docs_dir}/docs.yaml"

  # No docs/ at all → skip silently (docs are opt-in)
  if [[ ! -d "$docs_dir" ]]; then
    return 0
  fi

  # docs/ exists but no manifest → error
  if [[ ! -f "$manifest" ]]; then
    doc_add "docs" "error" "$manifest" "docs.yaml missing but docs/ exists" \
      "run 'spectacular docs init' to scaffold it" "judgment"
    return
  fi

  doc_add "docs" "pass" "$manifest" "docs.yaml present"

  # Extract declared section ids + page slugs
  local declared_sections declared_pages
  declared_sections=$(awk '
    /^sections:/ { in_sec=1; next }
    in_sec && /^[a-zA-Z]/ && !/^  / { in_sec=0 }
    in_sec && /^  - id:/ {
      sub(/^  - id:[[:space:]]*/, "")
      sub(/[[:space:]]*#.*$/, "")
      sub(/[[:space:]]*$/, "")
      print
    }
  ' "$manifest")

  # For each declared section, collect declared pages (one line per section's pages: list)
  # Strip inline # comments before parsing, and only accept content between [ and ]
  declared_pages=$(awk '
    /^sections:/ { in_sec=1; next }
    in_sec && /^[a-zA-Z]/ && !/^  / { in_sec=0 }
    in_sec && /^  - id:/ {
      section=$0
      sub(/^  - id:[[:space:]]*/, "", section)
      sub(/[[:space:]]*#.*$/, "", section)
      sub(/[[:space:]]*$/, "", section)
    }
    in_sec && /^[[:space:]]*pages:[[:space:]]*\[/ {
      pages=$0
      # Extract only what is between [ and ] on this line
      if (match(pages, /\[[^\]]*\]/) > 0) {
        pages=substr(pages, RSTART+1, RLENGTH-2)
      } else {
        pages=""
      }
      gsub(/[[:space:]]/, "", pages)
      n=split(pages, arr, ",")
      for (i=1; i<=n; i++) if (arr[i] != "") print section "/" arr[i]
    }
  ' "$manifest")

  # Extract extras: list (top-level pages with no section, e.g. troubleshooting at docs/troubleshooting.md)
  local declared_extras
  declared_extras=$(awk '
    /^extras:/ { in_ex=1; next }
    in_ex && /^[a-zA-Z]/ && !/^  / && !/^[[:space:]]*-/ { in_ex=0 }
    in_ex && /^[[:space:]]*-[[:space:]]+/ {
      slug=$0; sub(/^[[:space:]]*-[[:space:]]+/, "", slug); sub(/[[:space:]]*$/, "", slug)
      gsub(/^["'\'']|["'\'']$/, "", slug)
      if (slug != "") print slug
    }
  ' "$manifest")

  # Check: each declared page exists on disk
  local missing=0 page section_id file_path
  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    section_id="${entry%/*}"
    page="${entry##*/}"
    file_path="${docs_dir}/${section_id}/${page}.md"
    if [[ -f "$file_path" ]]; then
      doc_add "docs" "pass" "$file_path" "declared page present"
    else
      doc_add "docs" "error" "$file_path" "page '${page}' declared in docs.yaml but file missing" \
        "create the file or remove the entry from docs.yaml" "judgment"
      missing=$((missing + 1))
    fi
  done <<< "$declared_pages"

  # Check: each declared extra exists at docs/<slug>.md (top-level, no section folder)
  local extra_slug extra_path
  while IFS= read -r extra_slug; do
    [[ -z "$extra_slug" ]] && continue
    extra_path="${docs_dir}/${extra_slug}.md"
    if [[ -f "$extra_path" ]]; then
      doc_add "docs" "pass" "$extra_path" "declared extra present"
    else
      doc_add "docs" "error" "$extra_path" "extra '${extra_slug}' declared in docs.yaml but file missing" \
        "create the file or remove the entry from docs.yaml extras:" "judgment"
    fi
  done <<< "$declared_extras"

  # Check: each .md file in docs/ subdirs is declared in docs.yaml sections
  shopt -s nullglob
  for section_dir in "$docs_dir"/*/; do
    local sec_id="${section_dir%/}"
    sec_id="${sec_id##*/}"
    [[ "$sec_id" == "."* ]] && continue
    for page_file in "$section_dir"*.md; do
      local page_slug
      page_slug=$(basename "$page_file" .md)
      if ! echo "$declared_pages" | grep -qxF "${sec_id}/${page_slug}"; then
        doc_add "docs" "warning" "$page_file" "page exists on disk but not declared in docs.yaml (orphan)" \
          "add to docs.yaml ${sec_id}.pages or delete the file" "judgment"
      fi
    done
  done
  # Check: top-level .md files (except index.md) are either in extras or warned as orphans
  for page_file in "$docs_dir"/*.md; do
    [[ -f "$page_file" ]] || continue
    local page_slug
    page_slug=$(basename "$page_file" .md)
    [[ "$page_slug" == "index" ]] && continue
    if ! echo "$declared_extras" | grep -qxF "$page_slug"; then
      doc_add "docs" "warning" "$page_file" "top-level page exists on disk but not in docs.yaml extras: (orphan)" \
        "add to docs.yaml extras: or move into a section folder" "judgment"
    fi
  done
  shopt -u nullglob

  # Per-page frontmatter validation
  local required_fields="title description section status updated"
  shopt -s nullglob
  for page_file in "$docs_dir"/*.md "$docs_dir"/*/*.md; do
    [[ -f "$page_file" ]] || continue
    if ! head -1 "$page_file" | grep -q '^---$'; then
      doc_add "docs" "error" "$page_file" "missing frontmatter delimiter" \
        "add proper frontmatter block (or run 'doctor docs --fix')" "mechanical"
      continue
    fi
    local fm
    fm=$(awk '/^---$/ { count++; if (count == 2) exit; next } count == 1' "$page_file")
    for field in $required_fields; do
      if ! echo "$fm" | grep -qE "^${field}:"; then
        doc_add "docs" "error" "$page_file" "missing required frontmatter field: ${field}" \
          "add '${field}:' to frontmatter (or run 'doctor docs --fix')" "mechanical"
      fi
    done
  done
  shopt -u nullglob
}

# ── doctor orchestrator ───────────────────────────────────────────────────────
doctor() {
  doctor_parse_args "$@"

  DOC_FINDINGS=""

  local areas_to_run
  if [[ -n "$DOC_OPT_AREA" ]]; then
    areas_to_run="$DOC_OPT_AREA"
  else
    areas_to_run="$DOC_AREAS"
  fi

  for area in $areas_to_run; do
    case "$area" in
      skill)       check_skill ;;
      workspace)   check_workspace ;;
      frontmatter) check_frontmatter ;;
      snapshots)   check_snapshots ;;
      links)       check_links ;;
      lifecycle)   check_lifecycle ;;
      kits)        check_kits ;;
      conventions) check_conventions ;;
      specs)       check_specs ;;
      docs)        check_docs ;;
    esac
  done

  # Apply mechanical fixes if --fix flag set
  if $DOC_OPT_FIX; then
    doctor_apply_mechanical_fixes
    # Re-run detection to refresh state
    DOC_FINDINGS=""
    for area in $areas_to_run; do
      case "$area" in
        skill)       check_skill ;;
        workspace)   check_workspace ;;
        frontmatter) check_frontmatter ;;
        snapshots)   check_snapshots ;;
        links)       check_links ;;
        lifecycle)   check_lifecycle ;;
        kits)        check_kits ;;
        conventions) check_conventions ;;
        specs)       check_specs ;;
        docs)        check_docs ;;
      esac
    done
  fi

  if [[ "$DOC_OPT_FORMAT" == "json" ]]; then
    doctor_emit_json
  else
    doctor_emit_text
  fi

  # Exit code
  if echo "$DOC_FINDINGS" | grep -q "|error|"; then
    exit 2
  elif echo "$DOC_FINDINGS" | grep -q "|warning|"; then
    exit 1
  fi
  exit 0
}

doctor_apply_mechanical_fixes() {
  local applied=0
  while IFS='|' read -r area sev file msg fix ftype; do
    [[ "$ftype" == "mechanical" ]] || continue
    case "$file" in
      *.gitignore*) ;;  # handled below
    esac

    # Docs frontmatter stub injection (from check_docs)
    # Either missing delimiter OR missing required field.
    if [[ "$area" == "docs" && "$file" == docs/*.md ]]; then
      if [[ "$msg" == *"missing frontmatter delimiter"* ]]; then
        # Prepend a minimal stub; don't try to infer title from H1, leave that to the user
        if [[ -f "$file" ]] && ! head -1 "$file" | grep -q '^---$'; then
          local section_id
          section_id="$(basename "$(dirname "$file")")"
          [[ "$section_id" == "docs" ]] && section_id=""
          local slug
          slug="$(basename "$file" .md)"
          local tmp="${file}.tmp.$$"
          {
            echo "---"
            echo "title: ${slug}"
            echo "description: TODO — one-sentence description"
            echo "section: ${section_id}"
            echo "status: draft"
            echo "updated: ${TODAY}"
            echo "---"
            echo ""
            cat "$file"
          } > "$tmp" && mv "$tmp" "$file"
          echo "  ✓ fixed [docs]: injected frontmatter stub into $file"
          applied=$((applied + 1))
        fi
        continue
      fi
      if [[ "$msg" == *"missing required frontmatter field:"* ]]; then
        # Extract the field name from the message
        local field
        field=$(echo "$msg" | sed -n 's/.*missing required frontmatter field: \([a-z]*\).*/\1/p')
        if [[ -n "$field" && -f "$file" ]]; then
          # Insert "<field>: TODO" after the opening --- line (right at top of frontmatter)
          # Skip if field somehow already present
          local fm
          fm=$(awk '/^---$/ { count++; if (count == 2) exit; next } count == 1' "$file")
          if ! echo "$fm" | grep -qE "^${field}:"; then
            local default_val="TODO"
            [[ "$field" == "status" ]] && default_val="draft"
            [[ "$field" == "updated" ]] && default_val="$TODAY"
            local tmp="${file}.tmp.$$"
            awk -v field="$field" -v val="$default_val" '
              BEGIN { inserted=0; count=0 }
              /^---$/ { count++; print; if (count == 1 && !inserted) { print field ": " val; inserted=1 }; next }
              { print }
            ' "$file" > "$tmp" && mv "$tmp" "$file"
            echo "  ✓ fixed [docs]: injected '${field}: ${default_val}' into $file"
            applied=$((applied + 1))
          fi
        fi
        continue
      fi
    fi

    # Pack-driven gitignore drift (from check_conventions in scaffold/enforce modes)
    # Findings have area=conventions and msg containing "requires gitignore entry: 'X'"
    if [[ "$area" == "conventions" && "$msg" == *"gitignore entry:"* ]]; then
      # Extract the entry between single quotes: ...entry: 'X' (...
      local entry
      entry=$(echo "$msg" | sed -n "s/.*gitignore entry: '\([^']*\)'.*/\1/p")
      if [[ -n "$entry" ]]; then
        [[ -f ".gitignore" ]] || touch .gitignore
        if ! grep -qF -- "$entry" .gitignore; then
          echo "$entry" >> .gitignore
          echo "  ✓ fixed [conventions]: appended $entry to .gitignore"
          applied=$((applied + 1))
        fi
      fi
      continue
    fi

    # gitignore append (workspace area — .spectacular.local/ baseline)
    if [[ "$file" == ".gitignore"* || "$msg" == *".gitignore"* ]]; then
      if [[ -f ".gitignore" ]]; then
        if ! grep -qF ".spectacular.local/" .gitignore; then
          echo ".spectacular.local/" >> .gitignore
          echo "  ✓ fixed [gitignore]: appended .spectacular.local/"
          applied=$((applied + 1))
        fi
      else
        echo ".spectacular.local/" > .gitignore
        echo "  ✓ fixed [gitignore]: created with .spectacular.local/"
        applied=$((applied + 1))
      fi
      continue
    fi

    # Missing dir
    if [[ "$file" == ".spectacular/requests/" || "$file" == ".spectacular/specs/" ]]; then
      mkdir -p "$file"
      [[ "$file" == ".spectacular/specs/" ]] && touch "${file}.gitkeep"
      echo "  ✓ fixed [workspace]: created $file"
      applied=$((applied + 1))
      continue
    fi

    # Legacy current/ → specs/ migration (specs area, mechanical)
    if [[ "$area" == "specs" && "$msg" == *"legacy current/ folder"* ]]; then
      if [[ -d ".spectacular/current" && ! -d ".spectacular/specs" ]]; then
        mv .spectacular/current .spectacular/specs
        echo "  ✓ fixed [specs]: renamed .spectacular/current/ → .spectacular/specs/"
        applied=$((applied + 1))
      fi
      continue
    fi

    # Dangling symlink
    if [[ "$sev" == "error" && "$file" == *".claude/skills/spectacular"* ]]; then
      local agents_dir
      agents_dir="$(agents_skill_dir)"
      if [[ -d "$agents_dir" ]]; then
        rm -f "$file"
        mkdir -p "$(dirname "$file")"
        ln -s "$agents_dir" "$file"
        echo "  ✓ fixed [skill]: recreated symlink $file → $agents_dir"
        applied=$((applied + 1))
      fi
      continue
    fi

    # Missing always-set file → re-scaffold using doc_<id>
    if [[ "$file" == ".spectacular/PRD.md" || "$file" == ".spectacular/SPEC.md" || "$file" == ".spectacular/config.yaml" || "$file" == ".spectacular/AGENTS.md" || "$file" == ".spectacular/CLAUDE.md" ]]; then
      local fname
      fname=$(basename "$file")
      local name="${OPT_NAME:-$(slug_from_dir)}"
      case "$fname" in
        PRD.md)        doc_prd "$name" "blank" ;;
        SPEC.md)       doc_spec "$name" ;;
        config.yaml)   doc_config "$name" "" "AGENTS.md" "blank" ;;
        AGENTS.md|CLAUDE.md) doc_agents "$name" "$fname" ;;
      esac
      echo "  ✓ fixed [workspace]: re-scaffolded $file"
      applied=$((applied + 1))
      continue
    fi
  done <<< "$DOC_FINDINGS"

  if [[ $applied -eq 0 ]]; then
    echo "  (no mechanical fixes applied)"
  fi
  echo ""
}

# ── text emitter ──────────────────────────────────────────────────────────────
doctor_emit_text() {
  echo "Spectacular doctor"
  echo ""

  local last_area="" errors=0 warnings=0 infos=0
  while IFS='|' read -r area sev file msg fix ftype; do
    [[ -z "$area" ]] && continue
    if [[ "$area" != "$last_area" ]]; then
      last_area="$area"
    fi
    case "$sev" in
      pass)    icon="✅" ;;
      warning) icon="⚠️ "; warnings=$((warnings + 1)) ;;
      error)   icon="❌"; errors=$((errors + 1)) ;;
      info)    icon="ℹ️ "; infos=$((infos + 1)) ;;
      *)       icon="?"  ;;
    esac
    printf "%-13s %s %s — %s\n" "$area" "$icon" "$file" "$msg"
    if [[ -n "$fix" && "$sev" != "pass" ]]; then
      local route="(mechanical — \`--fix\` applies)"
      [[ "$ftype" == "judgment" ]] && route="(judgment — \`/spectacular doctor --fix\`)"
      printf "%-13s    → %s %s\n" "" "$fix" "$route"
    fi
  done <<< "$DOC_FINDINGS"

  echo ""
  printf "%d error(s), %d warning(s), %d info\n" "$errors" "$warnings" "$infos"
  if [[ $errors -gt 0 || $warnings -gt 0 ]]; then
    echo ""
    echo "Run \`spectacular doctor --fix\` for mechanical repairs."
    echo "Run \`/spectacular doctor --fix\` (in your AI agent) for judgment repairs."
  fi
}

# ── json emitter ──────────────────────────────────────────────────────────────
doctor_emit_json() {
  local ran_at
  ran_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local workspace="$(pwd)"
  local errors=0 warnings=0 infos=0 first=true

  printf '{\n'
  printf '  "version": "0.3.0",\n'
  printf '  "ran_at": "%s",\n' "$ran_at"
  printf '  "workspace": "%s",\n' "$workspace"
  printf '  "findings": [\n'

  while IFS='|' read -r area sev file msg fix ftype; do
    [[ -z "$area" ]] && continue
    [[ "$sev" == "pass" ]] && continue  # pass entries omitted from json (signal-to-noise)
    case "$sev" in
      warning) warnings=$((warnings + 1)) ;;
      error)   errors=$((errors + 1)) ;;
      info)    infos=$((infos + 1)) ;;
    esac
    if ! $first; then printf ',\n'; fi
    first=false
    # JSON-escape strings (basic — escape quotes and backslashes)
    local esc_msg="${msg//\\/\\\\}"; esc_msg="${esc_msg//\"/\\\"}"
    local esc_fix="${fix//\\/\\\\}"; esc_fix="${esc_fix//\"/\\\"}"
    local esc_file="${file//\\/\\\\}"; esc_file="${esc_file//\"/\\\"}"
    printf '    {"area": "%s", "severity": "%s", "file": "%s", "message": "%s", "proposed_fix": "%s", "fix_type": "%s"}' \
      "$area" "$sev" "$esc_file" "$esc_msg" "$esc_fix" "$ftype"
  done <<< "$DOC_FINDINGS"

  printf '\n  ],\n'
  printf '  "summary": { "errors": %d, "warnings": %d, "info": %d }\n' "$errors" "$warnings" "$infos"
  printf '}\n'
}

# ────────────────────────────────────────────────────────────────────────────
# pack subcommand — convention-pack lifecycle (install / list / remove)
# ────────────────────────────────────────────────────────────────────────────

pack_usage() {
  cat <<EOF
Usage: spectacular pack <verb> [args]

Manage convention packs — repo-shape opinions (naming + taxonomy + gitignore
+ file-placement + project-types). Schema: skills/spectacular/references/packs-contract.md

Verbs:
  list                       Show installed packs across all scopes
  install <name> [--from <path>]
                             Install pack to ~/.spectacular/packs/<name>/.
                             --from <path> copies from a local folder (default:
                             searches bundled, then app-store at <repo>/packs/<name>).
  remove <name> [--force]    Remove user-scope pack at ~/.spectacular/packs/<name>/.
                             --force allows removing bundled/project-local packs.
  show <name>                Print pack.md frontmatter for the named pack.

Pack scopes (precedence: project-local > user > app-store > bundled):
  bundled        skills/spectacular/templates/packs/<name>/
  app-store      <repo-root>/packs/<name>/
  user           ~/.spectacular/packs/<name>/
  project-local  <project>/.spectacular/packs/<name>/

Examples:
  spectacular pack list
  spectacular pack install minimal
  spectacular pack install alex-default --from /path/to/pack
  spectacular pack show minimal
  spectacular pack remove old-pack
EOF
}

pack_user_dir() { echo "${HOME}/.spectacular/packs"; }

pack_bundled_dir() {
  local agents_dir
  agents_dir="$(agents_skill_dir)"
  echo "${agents_dir}/templates/packs"
}

pack_appstore_dir() {
  # Walk up from cli/ looking for a packs/ sibling (source repo layout)
  # Fallback: cwd/packs if present
  local candidate
  if [[ -d "${SCRIPT_DIR}/../packs" ]]; then
    candidate="$(cd "${SCRIPT_DIR}/.." && pwd)/packs"
    echo "$candidate"
  elif [[ -d "./packs" ]]; then
    echo "$(pwd)/packs"
  else
    echo ""
  fi
}

pack_projectlocal_dir() {
  if [[ -d "./.spectacular/packs" ]]; then
    echo "$(pwd)/.spectacular/packs"
  else
    echo ""
  fi
}

# Resolve a pack name to a source folder, applying precedence rules.
# Args: $1 = pack name, $2 = optional explicit source override (--from)
# Stdout: absolute path to the resolved pack folder, or empty if not found
pack_resolve() {
  local name="$1"
  local override="${2:-}"

  if [[ -n "$override" ]]; then
    [[ -d "$override" ]] && echo "$override" && return 0
    return 1
  fi

  # Precedence order for INSTALL source (read from): project-local → user → app-store → bundled
  local pl ud as bd
  pl="$(pack_projectlocal_dir)"
  ud="$(pack_user_dir)"
  as="$(pack_appstore_dir)"
  bd="$(pack_bundled_dir)"

  for dir in "$pl" "$ud" "$as" "$bd"; do
    [[ -z "$dir" ]] && continue
    if [[ -d "${dir}/${name}" && -f "${dir}/${name}/pack.md" ]]; then
      echo "${dir}/${name}"
      return 0
    fi
  done
  return 1
}

pack_scope_of() {
  local path="$1"
  local pl ud as bd
  pl="$(pack_projectlocal_dir)"
  ud="$(pack_user_dir)"
  as="$(pack_appstore_dir)"
  bd="$(pack_bundled_dir)"

  # Order matters: most-specific scope first. Empty scope dirs are skipped
  # (an empty $pl would otherwise expand the pattern to "/*" and match everything).
  [[ -n "$pl" && "$path" == "${pl}/"* ]] && echo "project-local" && return
  [[ -n "$ud" && "$path" == "${ud}/"* ]] && echo "user" && return
  [[ -n "$as" && "$path" == "${as}/"* ]] && echo "app-store" && return
  [[ -n "$bd" && "$path" == "${bd}/"* ]] && echo "bundled" && return
  echo "unknown"
}

pack_list() {
  echo "Convention packs:"
  echo ""
  local found=0
  for scope_pair in \
    "bundled|$(pack_bundled_dir)" \
    "app-store|$(pack_appstore_dir)" \
    "user|$(pack_user_dir)" \
    "project-local|$(pack_projectlocal_dir)"
  do
    local scope="${scope_pair%%|*}"
    local dir="${scope_pair##*|}"
    [[ -z "$dir" || ! -d "$dir" ]] && continue
    local entries=()
    for sub in "$dir"/*/; do
      [[ -d "$sub" ]] || continue
      local name
      name="$(basename "$sub")"
      [[ -f "${sub}pack.md" ]] || continue
      entries+=("$name")
      found=$((found + 1))
    done
    if [[ ${#entries[@]} -gt 0 ]]; then
      printf "  %-14s %s\n" "[${scope}]" "$dir"
      for e in "${entries[@]}"; do
        printf "    • %s\n" "$e"
      done
    fi
  done
  echo ""
  if [[ $found -eq 0 ]]; then
    echo "  (no packs found)"
  else
    echo "Install: spectacular pack install <name>"
    echo "Show:    spectacular pack show <name>"
  fi
}

pack_install() {
  local name="$1"
  local from_path="${2:-}"
  [[ -z "$name" ]] && die "pack install: missing pack name. Usage: spectacular pack install <name> [--from <path>]"

  local src
  if ! src="$(pack_resolve "$name" "$from_path")"; then
    if [[ -n "$from_path" ]]; then
      die "pack install: source path not found or not a pack folder: $from_path"
    fi
    die "pack install: pack '$name' not found. Run 'spectacular pack list' to see available packs."
  fi

  local user_dir
  user_dir="$(pack_user_dir)"
  mkdir -p "$user_dir"
  local dest="${user_dir}/${name}"

  if [[ -d "$dest" ]]; then
    die "pack install: '$name' already installed at $dest. Remove first: spectacular pack remove $name"
  fi

  # Copy via cp -R (POSIX-portable enough; preserves dotfiles like templates/.gitignore)
  cp -R "$src" "$dest"

  echo "✓ installed $name → $dest"
  echo "  source:  $src ($(pack_scope_of "$src"))"
  echo ""
  echo "Activate per-repo by adding to .spectacular/config.yaml:"
  echo "  convention_pack:"
  echo "    source: $name"
  echo "    mode: suggest    # or scaffold | enforce"
}

pack_remove() {
  local name="$1"
  local force="${2:-false}"
  [[ -z "$name" ]] && die "pack remove: missing pack name. Usage: spectacular pack remove <name> [--force]"

  local user_dir
  user_dir="$(pack_user_dir)"
  local target="${user_dir}/${name}"

  if [[ -d "$target" ]]; then
    rm -rf "$target"
    echo "✓ removed user-scope pack: $target"
    return 0
  fi

  # If not in user scope, check if it exists elsewhere — refuse without --force
  local found
  if found="$(pack_resolve "$name")"; then
    local scope
    scope="$(pack_scope_of "$found")"
    if [[ "$force" != "true" ]]; then
      die "pack remove: '$name' lives in $scope scope ($found). Use --force to remove."
    fi
    rm -rf "$found"
    echo "✓ removed $scope pack: $found"
    return 0
  fi

  die "pack remove: '$name' not installed in any scope."
}

pack_show() {
  local name="$1"
  [[ -z "$name" ]] && die "pack show: missing pack name. Usage: spectacular pack show <name>"

  local src
  if ! src="$(pack_resolve "$name")"; then
    die "pack show: '$name' not found in any scope."
  fi

  local manifest="${src}/pack.md"
  [[ -f "$manifest" ]] || die "pack show: $manifest missing"

  echo "pack:   $name"
  echo "scope:  $(pack_scope_of "$src")"
  echo "path:   $src"
  echo ""
  echo "── pack.md frontmatter ──"
  awk '/^---$/{c++; if(c==2) exit; if(c==1) next} c==1' "$manifest"
}

pack() {
  local verb="${1:-}"
  case "$verb" in
    ""|--help|-h) pack_usage; exit 0 ;;
    list)
      pack_list
      ;;
    install)
      shift
      local name="${1:-}"
      shift || true
      local from_path=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --from) from_path="$2"; shift 2 ;;
          *) die "pack install: unknown option: $1" ;;
        esac
      done
      pack_install "$name" "$from_path"
      ;;
    remove)
      shift
      local name="${1:-}"
      shift || true
      local force="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --force) force="true"; shift ;;
          *) die "pack remove: unknown option: $1" ;;
        esac
      done
      pack_remove "$name" "$force"
      ;;
    show)
      shift
      pack_show "${1:-}"
      ;;
    *)
      die "Unknown pack verb: '$verb'. Run 'spectacular pack --help' for usage."
      ;;
  esac
}

# ── docs subcommand (v0.6.0+) ─────────────────────────────────────────────────
# Mechanical scaffold for public-facing docs/ tree. Interactive doc-writing
# verbs (new, review, status) live in the skill — see docs-overrides.md.

docs_usage() {
  cat <<EOF
Usage: spectacular docs <verb> [options]

Verbs:
  init [--minimal]      Scaffold docs/ — docs.yaml + index.md + 3 default sections
                        (--minimal: docs.yaml + index.md only, no default sections)

Interactive verbs (run inside an AI agent with the spectacular skill):
  new <page>            Scaffold a new page with frontmatter stub
  new --section <name>  Declare a new section in docs.yaml
  review                Run the docs quality gate
  status                Briefing scoped to docs/

Options:
  -h, --help            Show this help

See: skills/spectacular/references/docs-contract.md for schema
     skills/spectacular/references/docs-overrides.md for engine rules
EOF
}

docs_init() {
  local minimal=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --minimal) minimal=true; shift ;;
      -h|--help) docs_usage; exit 0 ;;
      *) die "Unknown docs init option: '$1'" ;;
    esac
  done

  local project_name
  project_name="${OPT_NAME:-$(slug_from_dir)}"

  echo "Spectacular docs init"
  echo ""

  # docs/ root + manifest
  if [[ ! -d "docs" ]]; then
    mkdir -p docs
    created "docs/"
  else
    skip "docs/ (already exists)"
  fi

  write_if_missing "docs/docs.yaml" "site:
  name: ${project_name}
  tagline: \"\"
  # base_url: https://example.com   # optional — used by renderer adapters (v2)

sections:
  - id: getting-started
    title: Getting Started
    order: 1
    pages: [install, quickstart, concepts]

  - id: guides
    title: Guides
    order: 2
    pages: []

  - id: reference
    title: Reference
    order: 3
    pages: []

# Optional top-level entries with no section grouping
# extras:
#   - changelog       # symlinks to ../CHANGELOG.md
#   - troubleshooting
"

  write_if_missing "docs/index.md" "---
title: ${project_name}
description: User-facing documentation for ${project_name}.
section: \"\"
order: 0
status: draft
updated: ${TODAY}
---

# ${project_name}

Welcome to the documentation. Start here, then drill into the sections below.

## Sections

- **Getting Started** — install + quickstart + core concepts
- **Guides** — task-oriented walkthroughs
- **Reference** — CLI, configuration, schema details
"

  if $minimal; then
    echo ""
    echo "Docs initialized (minimal — no default sections)."
    return 0
  fi

  # Three default sections with placeholder pages
  for entry in "getting-started:install:Install:Get up and running in two minutes." \
               "getting-started:quickstart:Quickstart:A guided walk through the basics." \
               "getting-started:concepts:Concepts:Core ideas you need to know."; do
    local section page title desc
    IFS=':' read -r section page title desc <<< "$entry"
    [[ -d "docs/$section" ]] || { mkdir -p "docs/$section"; created "docs/$section/"; }
    write_if_missing "docs/${section}/${page}.md" "---
title: ${title}
description: ${desc}
section: ${section}
status: draft
updated: ${TODAY}
---

# ${title}

<First paragraph — what this page is for. One sentence is fine.>

## <First subhead>

<Content.>
"
  done

  # Empty guides/ and reference/ dirs (with .gitkeep so they survive git)
  for d in guides reference; do
    if [[ ! -d "docs/$d" ]]; then
      mkdir -p "docs/$d"
      touch "docs/$d/.gitkeep"
      created "docs/$d/"
    fi
  done

  echo ""
  echo "Docs initialized."
  echo ""
  echo "Next:"
  echo "  spectacular docs new <page>          # add a page (asks for section)"
  echo "  spectacular docs new --section <id>  # add a new section"
  echo "  spectacular docs review              # run quality gate"
}

docs() {
  local verb="${1:-}"
  if [[ -z "$verb" || "$verb" == "-h" || "$verb" == "--help" ]]; then
    docs_usage; exit 0
  fi
  shift
  case "$verb" in
    init) docs_init "$@" ;;
    new|review|status)
      die "'spectacular docs $verb' is a skill verb — run it inside your AI agent (Claude Code, Codex). The CLI only handles 'docs init' and 'doctor docs'."
      ;;
    *) die "Unknown docs verb: '$verb'. Run 'spectacular docs --help' for usage." ;;
  esac
}

main() {
  local subcmd="${1:-}"

  if [[ "$subcmd" == "--help" || "$subcmd" == "-h" ]]; then
    usage; exit 0
  fi

  if [[ "$subcmd" == "doctor" ]]; then
    shift
    doctor "$@"
    # doctor exits internally; this is unreachable
    exit 0
  fi

  if [[ "$subcmd" == "pack" ]]; then
    shift
    pack "$@"
    exit 0
  fi

  if [[ "$subcmd" == "docs" ]]; then
    shift
    docs "$@"
    exit 0
  fi

  if [[ "$subcmd" != "init" ]]; then
    die "Unknown command: '${subcmd}'. Did you mean 'spectacular init', 'spectacular doctor', 'spectacular pack', or 'spectacular docs'?"
  fi

  shift
  parse_args "$@"

  if $OPT_UPDATE; then
    update_skill
  fi

  if $OPT_INTERACTIVE; then
    run_interactive
  fi

  [[ -z "$OPT_NAME" ]] && OPT_NAME="$(slug_from_dir)"

  local agents_dir claude_dir lock_ref
  agents_dir="$(agents_skill_dir)"
  claude_dir="$(claude_skill_dir)"
  lock_ref="$(read_lock_ref)"

  echo "Spectacular init"
  echo ""

  # Interactive mode: show final summary, ask for confirmation before any writes
  if $OPT_INTERACTIVE; then
    local doc_set_preview
    doc_set_preview="$(resolve_doc_set)"
    echo "Ready to scaffold:"
    echo "  project:     $OPT_NAME"
    echo "  summary:     ${OPT_SUMMARY:-(none)}"
    echo "  agents-file: $OPT_AGENTS_FILE"
    echo "  kit:         $OPT_KIT"
    echo "  scope:       $($OPT_GLOBAL && echo global || echo project)"
    echo "  docs:        $doc_set_preview"
    echo ""
    printf "Proceed? [Y/n]: "
    local confirm
    read -r confirm
    case "${confirm:-y}" in
      y|Y|yes|YES) ;;
      *) echo "Aborted. No files written."; exit 0 ;;
    esac
    echo ""
  fi

  echo "Scaffold:"

  scaffold "$OPT_NAME" "$OPT_SUMMARY" "$OPT_AGENTS_FILE"

  echo ""
  echo "Skill:"

  INSTALLED_REF=""
  AGENTS_SKILL_INSTALLED=""
  CLAUDE_SKILL_INSTALLED=""

  if [[ -n "$lock_ref" && -d "$agents_dir" ]]; then
    skip "${agents_dir}  (${lock_ref}, already installed)"
    skip "${claude_dir}  → symlink"
  else
    install_skill
    info "  installed  ${AGENTS_SKILL_INSTALLED}  (${INSTALLED_REF})"
    info "  symlinked  ${CLAUDE_SKILL_INSTALLED}  → ${AGENTS_SKILL_INSTALLED}"
  fi

  print_summary
}

INSTALLED_REF=""
AGENTS_SKILL_INSTALLED=""
CLAUDE_SKILL_INSTALLED=""

main "$@"
