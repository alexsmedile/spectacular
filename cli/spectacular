#!/usr/bin/env bash
set -euo pipefail

# ── constants ────────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GITHUB_REPO="alexsmedile/spectacular"
GITHUB_RELEASES_API="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"
GITHUB_TAGS_API="https://api.github.com/repos/${GITHUB_REPO}/tags"
GITHUB_MAIN_TARBALL="https://github.com/${GITHUB_REPO}/archive/refs/heads/main.tar.gz"
SKILL_PATH_IN_TARBALL="skills/spectacular"
TODAY="$(date +%Y-%m-%d)"

# ── defaults ─────────────────────────────────────────────────────────────────
OPT_NAME=""
OPT_SUMMARY=""
OPT_AGENTS_FILE="AGENTS.md"
OPT_GLOBAL=false
OPT_UPDATE=false
OPT_INTERACTIVE=false
OPT_KIT="blank"
OPT_WITH=""
OPT_MINIMAL=false

# Always-set: scaffolded regardless of kit. The 6-file minimum.
#   PRD.md, SPEC.md, config.yaml, AGENTS.md (file name varies per --agents-file), requests/, specs/
ALWAYS_SET="prd spec config agents"

# Known doc IDs (kit triggers-docs entries and --with values must match these)
KNOWN_DOCS="prd spec principles architecture roadmap stack decisions agents config"

# Bundled kits (must exist as templates/prd/kits/<id>.md in installed skill)
KNOWN_KITS="blank coding content product research"

# ── helpers ──────────────────────────────────────────────────────────────────
die()  { echo "Error: $*" >&2; exit 1; }
info() { echo "$*"; }
skip() { echo "  ⊘  $*"; }
created() { echo "  ✓  $*"; }
filled() { echo "  ✓  $* (filled empty stub)"; }
diag()  { echo "  ⊘  $* (issues detected — run \`spectacular doctor frontmatter\` for details)"; }

# Returns 0 if file is "effectively empty" (0 bytes or only whitespace)
is_empty_file() {
  local path="$1"
  [[ ! -s "$path" ]] && return 0
  ! grep -q '[^[:space:]]' "$path" 2>/dev/null
}

# Returns 0 if `needle` (whitespace-trimmed) appears in space-separated `haystack`
# IFS is explicitly reset so callers using comma-IFS don't break the split.
in_list() {
  local needle="$1" haystack="$2"
  local IFS=$' \t\n'
  for item in $haystack; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

slug_from_dir() {
  basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//'
}

write_if_missing() {
  local path="$1"; shift
  if [[ -e "$path" ]]; then
    if is_empty_file "$path"; then
      printf '%s' "$*" > "$path"
      filled "$path"
    else
      # Cheap heuristic: file looks malformed if it has no frontmatter delimiter
      # and the doc is supposed to have frontmatter
      if [[ "$path" == *.md ]] && ! head -1 "$path" | grep -q '^---$'; then
        diag "$path"
      else
        skip "$path"
      fi
    fi
  else
    mkdir -p "$(dirname "$path")"
    printf '%s' "$*" > "$path"
    created "$path"
  fi
}

# ── usage ────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
Usage: spectacular init [options]

Bootstrap a new project with the Spectacular workspace scaffold.

Options:
  -i, --interactive         Prompt for all foundational settings (incl. kit + suggested docs)
      --name <slug>         Project name (default: current folder slug)
      --summary <text>      Project summary (default: empty)
      --agents-file <file>  Primary agents file (default: AGENTS.md)
      --kit <name>          Kit identity for the PRD + extra docs (default: blank)
                            One of: blank, coding, content, product, research
      --with <a,b,c>        Comma-separated extra root docs to scaffold beyond always-set
                            Doc IDs: principles, architecture, roadmap, stack, decisions
      --minimal             Scaffold the 6-file always-set only; ignore kit triggers-docs
      --global              Install skill to ~/.agents/skills/ and ~/.claude/skills/
      --update              Re-download latest skill release and update skills.lock
  -h, --help                Show this help

Always-set (scaffolded regardless of kit/flags):
  PRD.md, SPEC.md, config.yaml, <agents-file>, requests/, specs/

Examples:
  spectacular init                              # always-set + blank kit (no extras)
  spectacular init -i                           # interactive: pick kit + per-suggested-doc prompts
  spectacular init --kit coding                 # adds STACK + ARCHITECTURE (coding kit's always-docs)
  spectacular init --with principles,roadmap    # adds those two on top of always-set
  spectacular init --kit coding --minimal       # always-set only; kit identity recorded but no extras
  spectacular init --name my-app --agents-file CLAUDE.md
  spectacular init --global
  spectacular init --update
EOF
}

# ── arg parsing ───────────────────────────────────────────────────────────────
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      init) shift ;;
      -i|--interactive) OPT_INTERACTIVE=true; shift ;;
      --name) OPT_NAME="$2"; shift 2 ;;
      --summary) OPT_SUMMARY="$2"; shift 2 ;;
      --agents-file) OPT_AGENTS_FILE="$2"; shift 2 ;;
      --kit) OPT_KIT="$2"; shift 2 ;;
      --with) OPT_WITH="$2"; shift 2 ;;
      --minimal) OPT_MINIMAL=true; shift ;;
      --global) OPT_GLOBAL=true; shift ;;
      --update) OPT_UPDATE=true; shift ;;
      -h|--help) usage; exit 0 ;;
      *) die "Unknown option: $1. Run 'spectacular --help' for usage." ;;
    esac
  done

  # Validate --kit
  if ! in_list "$OPT_KIT" "$KNOWN_KITS"; then
    die "Unknown kit: '$OPT_KIT'. Known kits: $KNOWN_KITS"
  fi

  # Validate --with entries
  if [[ -n "$OPT_WITH" ]]; then
    local IFS=','
    for doc in $OPT_WITH; do
      doc="${doc// /}"  # strip whitespace
      [[ -z "$doc" ]] && continue
      if ! in_list "$doc" "$KNOWN_DOCS"; then
        die "Unknown doc ID in --with: '$doc'. Known doc IDs: $KNOWN_DOCS"
      fi
    done
  fi
}

# Resolve the final doc-set to scaffold, given kit + flags.
# Output: space-separated list of doc IDs (lowercase).
# Rules:
#   - always-set always included
#   - kit's triggers-docs.always included unless --minimal
#   - --with entries always included (additive over kit)
#   - duplicates collapsed
resolve_doc_set() {
  local resolved="$ALWAYS_SET"
  local kit_always=""

  if ! $OPT_MINIMAL; then
    kit_always="$(kit_triggers_always "$OPT_KIT")"
    for doc in $kit_always; do
      if ! in_list "$doc" "$resolved"; then
        resolved="$resolved $doc"
      fi
    done
  fi

  if [[ -n "$OPT_WITH" ]]; then
    local IFS=','
    for doc in $OPT_WITH; do
      doc="${doc// /}"
      [[ -z "$doc" ]] && continue
      if ! in_list "$doc" "$resolved"; then
        resolved="$resolved $doc"
      fi
    done
  fi

  echo "$resolved"
}

# Read kit frontmatter and extract triggers-docs.always entries.
# Naive YAML parser: looks for `always:` under `triggers-docs:` and lists trailing `  - <doc>` items.
# Falls back to empty if kit file not yet installed or parse fails.
kit_triggers_always() {
  local kit_id="$1"
  local kit_file
  kit_file="$(find_kit_file "$kit_id")"
  [[ -z "$kit_file" ]] && return 0

  awk '
    /^---$/ { fm = !fm; next }
    !fm { exit }
    /^triggers-docs:/ { in_td = 1; in_always = 0; next }
    in_td && /^  always:/ { in_always = 1; next }
    in_td && /^  suggested:/ { in_always = 0; next }
    in_td && /^[a-zA-Z]/ { in_td = 0; in_always = 0; next }
    in_always && /^    - / {
      gsub(/^    - /, "", $0)
      gsub(/[[:space:]]/, "", $0)
      print $0
    }
  ' "$kit_file" | tr '\n' ' '
}

# Same as kit_triggers_always but for suggested
kit_triggers_suggested() {
  local kit_id="$1"
  local kit_file
  kit_file="$(find_kit_file "$kit_id")"
  [[ -z "$kit_file" ]] && return 0

  awk '
    /^---$/ { fm = !fm; next }
    !fm { exit }
    /^triggers-docs:/ { in_td = 1; in_sugg = 0; next }
    in_td && /^  suggested:/ { in_sugg = 1; next }
    in_td && /^  always:/ { in_sugg = 0; next }
    in_td && /^[a-zA-Z]/ { in_td = 0; in_sugg = 0; next }
    in_sugg && /^    - / {
      gsub(/^    - /, "", $0)
      gsub(/[[:space:]]/, "", $0)
      print $0
    }
  ' "$kit_file" | tr '\n' ' '
}

# Locate a kit file. Prefer project-local override, then installed skill.
find_kit_file() {
  local kit_id="$1"
  local local_override="$(pwd)/.spectacular/templates/prd/kits/${kit_id}.md"
  if [[ -f "$local_override" ]]; then
    echo "$local_override"
    return 0
  fi
  local installed
  installed="$(agents_skill_dir)/templates/prd/kits/${kit_id}.md"
  if [[ -f "$installed" ]]; then
    echo "$installed"
    return 0
  fi
  # Skill may not be installed yet (happens on first init). Return empty.
  return 0
}

# ── interactive prompts ───────────────────────────────────────────────────────
run_interactive() {
  local default_name input
  default_name="$(slug_from_dir)"

  printf "Project name [%s]: " "$default_name"
  read -r input
  OPT_NAME="${input:-$default_name}"

  printf "Project summary (optional): "
  read -r input
  OPT_SUMMARY="${input:-}"

  printf "Primary agents file [AGENTS.md / CLAUDE.md] (default: AGENTS.md): "
  read -r input
  input="${input:-AGENTS.md}"
  if [[ "$input" != "AGENTS.md" && "$input" != "CLAUDE.md" ]]; then
    OPT_AGENTS_FILE="$input"
  else
    OPT_AGENTS_FILE="$input"
  fi

  printf "Install scope [project / global] (default: project): "
  read -r input
  if [[ "${input:-project}" == "global" ]]; then
    OPT_GLOBAL=true
  fi

  # Kit selection
  echo ""
  echo "Pick a kit (extends the base PRD with extra slots + suggests root docs):"
  echo "  1) blank     — no extras, pure 8-slot base PRD"
  echo "  2) coding    — adds Stack + Interfaces; triggers STACK + ARCHITECTURE"
  echo "  3) content   — adds Audience + Format + Distribution; triggers ROADMAP"
  echo "  4) product   — adds User stories + Metrics + Distribution; triggers ROADMAP"
  echo "  5) research  — adds Hypothesis + Method + Decision-being-informed"
  printf "Kit [1-5] (default: 1=blank): "
  read -r input
  case "${input:-1}" in
    1|blank)    OPT_KIT="blank" ;;
    2|coding)   OPT_KIT="coding" ;;
    3|content)  OPT_KIT="content" ;;
    4|product)  OPT_KIT="product" ;;
    5|research) OPT_KIT="research" ;;
    *) die "Invalid kit selection: $input" ;;
  esac
  echo ""
  echo "  → kit: $OPT_KIT"

  # Per-suggested-doc prompts. Only fires if the kit's frontmatter is parseable
  # (skill must be installed). On fresh init this is usually a no-op since skill
  # installs after scaffold; user can re-run with --with for finer control.
  local suggested
  suggested="$(kit_triggers_suggested "$OPT_KIT")"
  if [[ -n "$suggested" ]]; then
    echo ""
    echo "The '$OPT_KIT' kit suggests these additional root docs. Add each?"
    local extra_with=""
    for doc in $suggested; do
      printf "  Scaffold %s.md? [Y/n]: " "$(echo "$doc" | tr '[:lower:]' '[:upper:]')"
      read -r input
      case "${input:-y}" in
        y|Y|yes|YES) extra_with="${extra_with},${doc}" ;;
        *) ;;
      esac
    done
    # Strip leading comma and merge into OPT_WITH
    extra_with="${extra_with#,}"
    if [[ -n "$extra_with" ]]; then
      if [[ -n "$OPT_WITH" ]]; then
        OPT_WITH="${OPT_WITH},${extra_with}"
      else
        OPT_WITH="$extra_with"
      fi
    fi
  fi
}

# ── skill install paths ───────────────────────────────────────────────────────
agents_skill_dir() {
  if $OPT_GLOBAL; then
    echo "$HOME/.agents/skills/spectacular"
  else
    echo "$(pwd)/.agents/skills/spectacular"
  fi
}

claude_skill_dir() {
  if $OPT_GLOBAL; then
    echo "$HOME/.claude/skills/spectacular"
  else
    echo "$(pwd)/.claude/skills/spectacular"
  fi
}

skills_lock_path() {
  echo "$(pwd)/.spectacular/skills.lock"
}

# ── fetch latest release ──────────────────────────────────────────────────────
fetch_latest_ref() {
  local ref=""
  if command -v curl &>/dev/null; then
    # 1. try releases API
    ref="$(curl -fsSL "$GITHUB_RELEASES_API" 2>/dev/null | grep '"tag_name"' | head -1 | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')"
    # 2. try tags API
    if [[ -z "$ref" ]]; then
      ref="$(curl -fsSL "$GITHUB_TAGS_API" 2>/dev/null | grep '"name"' | head -1 | sed 's/.*"name": *"\([^"]*\)".*/\1/')"
    fi
  fi
  # 3. fall back to main
  if [[ -z "$ref" ]]; then
    ref="main"
  fi
  echo "$ref"
}

tarball_url_for_ref() {
  local ref="$1"
  if [[ "$ref" == "main" ]]; then
    echo "$GITHUB_MAIN_TARBALL"
  else
    echo "https://github.com/${GITHUB_REPO}/archive/refs/tags/${ref}.tar.gz"
  fi
}

# ── skill download + install ──────────────────────────────────────────────────
download_and_install_skill() {
  local target_dir="$1"
  local ref url tmpdir tarball sha

  ref="$(fetch_latest_ref)"
  url="$(tarball_url_for_ref "$ref")"

  tmpdir="$(mktemp -d)"
  tarball="${tmpdir}/spectacular.tar.gz"

  info "" >&2
  info "Fetching skill (${ref}) from GitHub..." >&2

  if command -v curl &>/dev/null; then
    curl -fsSL "$url" -o "$tarball" || die "Could not fetch skill from GitHub (no network or repo not found).\nInstall manually: https://github.com/${GITHUB_REPO}"
  elif command -v wget &>/dev/null; then
    wget -q "$url" -O "$tarball" || die "Could not fetch skill from GitHub (no network or repo not found).\nInstall manually: https://github.com/${GITHUB_REPO}"
  else
    die "Neither curl nor wget found. Install one to proceed."
  fi

  sha="$(shasum -a 256 "$tarball" 2>/dev/null | awk '{print $1}' || sha256sum "$tarball" 2>/dev/null | awk '{print $1}' || echo "unknown")"

  tar -xzf "$tarball" -C "$tmpdir"

  local extracted_skill
  extracted_skill="$(find "$tmpdir" -type d -name "spectacular" | grep "skills/spectacular$" | head -1)"
  [[ -z "$extracted_skill" ]] && die "Could not find skills/spectacular in downloaded tarball."

  mkdir -p "$(dirname "$target_dir")"
  rm -rf "$target_dir"
  cp -r "$extracted_skill" "$target_dir"
  rm -rf "$tmpdir"

  echo "$ref|$sha|$url"
}

write_skills_lock() {
  local ref="$1" sha="$2" url="$3"
  local lock_path
  lock_path="$(skills_lock_path)"
  mkdir -p "$(dirname "$lock_path")"
  cat > "$lock_path" <<EOF
spectacular:
  ref: ${ref}
  sha: ${sha}
  installed: ${TODAY}
  source: ${url}
EOF
  created "$lock_path"
}

read_lock_ref() {
  local lock_path
  lock_path="$(skills_lock_path)"
  if [[ -f "$lock_path" ]]; then
    grep '  ref:' "$lock_path" | sed 's/.*ref: *//'
  fi
}

install_skill() {
  local agents_dir claude_dir
  agents_dir="$(agents_skill_dir)"
  claude_dir="$(claude_skill_dir)"

  local result ref sha url
  result="$(download_and_install_skill "$agents_dir")"
  ref="$(echo "$result" | cut -d'|' -f1)"
  sha="$(echo "$result" | cut -d'|' -f2)"
  url="$(echo "$result" | cut -d'|' -f3)"

  # symlink .claude/skills/spectacular → .agents/skills/spectacular
  mkdir -p "$(dirname "$claude_dir")"
  rm -f "$claude_dir"
  ln -s "$agents_dir" "$claude_dir"

  write_skills_lock "$ref" "$sha" "$url"

  INSTALLED_REF="$ref"
  AGENTS_SKILL_INSTALLED="$agents_dir"
  CLAUDE_SKILL_INSTALLED="$claude_dir"
}

update_skill() {
  local lock_ref agents_dir claude_dir
  lock_ref="$(read_lock_ref)"
  agents_dir="$(agents_skill_dir)"
  claude_dir="$(claude_skill_dir)"

  local latest_ref
  latest_ref="$(fetch_latest_ref)"

  if [[ -n "$lock_ref" && "$lock_ref" == "$latest_ref" ]]; then
    info "Skill is already up to date (${latest_ref})."
    exit 0
  fi

  info "Updating skill: ${lock_ref:-unknown} → ${latest_ref}"

  local result ref sha url
  result="$(download_and_install_skill "$agents_dir")"
  ref="$(echo "$result" | cut -d'|' -f1)"
  sha="$(echo "$result" | cut -d'|' -f2)"
  url="$(echo "$result" | cut -d'|' -f3)"

  mkdir -p "$(dirname "$claude_dir")"
  rm -f "$claude_dir"
  ln -s "$agents_dir" "$claude_dir"

  write_skills_lock "$ref" "$sha" "$url"
  info "Skill updated to ${ref}."
  exit 0
}

# ── per-doc scaffolders ───────────────────────────────────────────────────────
# Each doc_<id>() takes positional args from scaffold() and writes one canonical file.
# Always-set is enforced by the orchestrator, not by individual writers.

doc_dirs() {
  # Report creation only when the dir genuinely didn't exist before
  if [[ ! -d ".spectacular/specs" ]]; then
    mkdir -p .spectacular/specs
    touch .spectacular/specs/.gitkeep
    created ".spectacular/specs/"
  fi
  [[ -d ".spectacular/requests" ]] || { mkdir -p .spectacular/requests; created ".spectacular/requests/"; }
}

doc_config() {
  local name="$1" summary="$2" agents_file="$3" kit_id="$4"
  write_if_missing ".spectacular/config.yaml" "project:
  name: ${name}
  summary: \"${summary}\"
  kit: ${kit_id}

naming:
  requests: kebab-case
  prefix: \"\"

required_files:
  requests:
    - PLAN.md
    - TASKS.md

agents:
  file: ${agents_file}             # override to CLAUDE.md for Claude-only teams
  tool_overrides:                  # per-tool agent files (read in addition to file: above)
    # claude: CLAUDE.md            # uncomment if AGENTS.md is primary but Claude also needs CLAUDE.md
  default_context:
    - PRD.md
    - STACK.md
    - DECISIONS.md

skills:
  symlink_on_init: []

# Convention pack — opt-in repo-shape opinions.
# Uncomment + set source to a pack name (run \`spectacular pack list\` to see options).
# convention_pack:
#   source: minimal           # pack name (resolved via scope precedence)
#   mode: suggest             # suggest | scaffold | enforce
#   overrides: []             # optional list of rule paths to skip (e.g. naming.forbidden-words)
"
}

# ── config.yaml parsers ───────────────────────────────────────────────────────
# Read convention_pack: stanza values from .spectacular/config.yaml
# Stdout: pack source name (empty if no convention_pack block or commented out)
config_pack_source() {
  local cfg=".spectacular/config.yaml"
  [[ -f "$cfg" ]] || return 0
  awk '
    /^convention_pack:/ { in_block=1; next }
    in_block && /^[^[:space:]]/ { in_block=0 }
    in_block && /^  source:/ { gsub(/^  source:[[:space:]]*/, ""); gsub(/[[:space:]]*$/, ""); print; exit }
  ' "$cfg"
}

# Stdout: pack mode (suggest|scaffold|enforce); default "suggest" if convention_pack present without mode
config_pack_mode() {
  local cfg=".spectacular/config.yaml"
  [[ -f "$cfg" ]] || return 0
  local src
  src="$(config_pack_source)"
  [[ -z "$src" ]] && return 0
  local mode
  mode=$(awk '
    /^convention_pack:/ { in_block=1; next }
    in_block && /^[^[:space:]]/ { in_block=0 }
    in_block && /^  mode:/ { gsub(/^  mode:[[:space:]]*/, ""); gsub(/[[:space:]]*$/, ""); print; exit }
  ' "$cfg")
  echo "${mode:-suggest}"
}

doc_prd() {
  # Init scaffolds a BASE 8-slot PRD with `kit:` recorded in frontmatter.
  # The kit's adds-slots / modifies-slots deltas are NOT applied here — the
  # doc-writer engine (grill flow) handles slot insertion when the user later
  # runs `spectacular prd grill`. Init only handles `triggers-docs` (which
  # sibling docs to scaffold). See references/kits-contract.md.
  local name="$1" kit_id="$2"
  write_if_missing ".spectacular/PRD.md" "---
version: 1.1
updated: ${TODAY}
summary: \"\"
kit: ${kit_id}
---

# ${name} — Product Requirements Document

## 1. Vision
<One paragraph — what this product is and why it exists. Higher abstraction OK.>

## 2. Problem
<One sentence — the concrete pain this solves. Who hurts, in what situation, how often.>

## 3. Target users
<One primary user. Not a list, not \"everyone\". A specific role + situation + constraint.>

## 4. Deliverable
<What ships at v1. Name the concrete artifacts a user can touch.>

## 5. Goals & success criteria
- <Measurable: number + verb + timeframe>

## 6. Non-goals
- <Explicit exclusion you'd push back on>

## 7. Constraints
- <What's fixed before starting — budget, tech, policy>

## 8. First milestone
<One concrete, demoable near-term outcome. Date-bound.>
"
}

doc_principles() {
  local name="$1"
  write_if_missing ".spectacular/PRINCIPLES.md" "---
version: 1.0
updated: ${TODAY}
summary: \"Operating principles for this project + runtime enforcement hooks\"
related:
  - PRD.md
  - ARCHITECTURE.md
---

# ${name} — Operating Principles

## 1. Context is the system
Load only what's needed, progressively, by task.

**How the skill enforces this:**
- <add hook>

## 2. Separate intent from truth
Strategic docs and operational docs are different files.

**How the skill enforces this:**
- <add hook>

## 3. Small files over giant documents
Prefer modular files; avoid monoliths.

**How the skill enforces this:**
- <add hook>

## 4. Humans and agents share the same workspace
Plain markdown, frontmatter as signal layer.

**How the skill enforces this:**
- <add hook>

## 5. Operational memory compounds
Preserve lessons across sessions and teams.

**How the skill enforces this:**
- <add hook>

## 6. Progressive disclosure
References load on demand, never upfront.

**How the skill enforces this:**
- <add hook>

## 7. Three layers: intent → execution → validation
Every unit of work passes through all three.

**How the skill enforces this:**
- <add hook>

## 8. Humans decide, agents propose
Irreversibles require confirmation.

**How the skill enforces this:**
- <add hook>
"
}

