# ── Detail verbs (singular noun + slug) ──────────────────────────────────────

# Generic skim helper: print frontmatter (key: value pairs) + outline (H2 headings).
_skim_file() {
  local file="$1"
  [[ -f "$file" ]] || { echo "(file not found: $file)"; return 1; }

  echo "── $file ──"
  echo ""
  echo "Frontmatter:"
  awk '/^---$/{c++; if(c==2)exit; next} c==1{print "  "$0}' "$file"
  echo ""
  echo "Outline:"
  grep -nE "^## " "$file" | sed 's/^/  /' || echo "  (no H2 headings)"
}

_skim_file_json() {
  local file="$1"
  [[ -f "$file" ]] || { echo "{}"; return 1; }
  local fm outline
  fm=$(awk '/^---$/{c++; if(c==2)exit; next} c==1{print}' "$file" | _json_escape "$(cat)")
  # Simpler: just include path + frontmatter raw + outline
  printf '{"path":"%s","frontmatter":"%s","outline":[' "$(_json_escape "$file")" \
    "$(awk '/^---$/{c++; if(c==2)exit; next} c==1{printf "%s\\n", $0}' "$file" | sed 's/"/\\"/g')"
  local first=true line
  while IFS= read -r line; do
    $first && first=false || printf ','
    printf '"%s"' "$(_json_escape "$line")"
  done < <(grep -E "^## " "$file" 2>/dev/null || true)
  printf ']}\n'
}

cmd_request() {
  local slug="" full=false json=false
  while (( $# > 0 )); do
    case "$1" in
      --full) full=true; shift ;;
      --json) json=true; shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular request <slug> [--full] [--json]

Show one request: frontmatter + PLAN.md outline + milestone progress.

Options:
  --full   Dump PLAN.md raw instead of skim view
  --json   JSON output ({path, frontmatter, outline, progress})
EOF
        exit 0 ;;
      -*) die "Unknown flag for request: $1" ;;
      *)
        [[ -n "$slug" ]] && die "request: only one <slug> argument allowed"
        slug="$1"; shift ;;
    esac
  done

  [[ -z "$slug" ]] && die "request: <slug> argument required"
  [[ -d ".spectacular" ]] || die "request: not inside a Spectacular workspace"

  local plan=".spectacular/requests/$slug/PLAN.md"
  local archive_plan=".spectacular/archive/$slug/PLAN.md"
  if [[ ! -f "$plan" ]]; then
    if [[ -f "$archive_plan" ]]; then
      plan="$archive_plan"
      info "(showing archived request)"
    else
      die "request: '$slug' not found in requests/ or archive/"
    fi
  fi

  if $full; then
    cat "$plan"
    return 0
  fi

  local tasks="${plan%/PLAN.md}/TASKS.md"

  if $json; then
    # JSON mode: include progress data
    printf '{"slug":"%s","path":"%s","frontmatter":{' \
      "$(_json_escape "$slug")" "$(_json_escape "$plan")"
    local first=true key val
    while IFS=':' read -r key val; do
      [[ -z "$key" ]] && continue
      key="${key// /}"
      val="${val# }"
      val="${val%\"}"
      val="${val#\"}"
      $first && first=false || printf ','
      printf '"%s":"%s"' "$(_json_escape "$key")" "$(_json_escape "$val")"
    done < <(awk '/^---$/{c++; if(c==2)exit; next} c==1 && /:/{print}' "$plan")
    printf '},"progress":'
    if [[ -f "$tasks" ]]; then
      _progress_json "$tasks"
    else
      printf 'null'
    fi
    printf '}\n'
    return 0
  fi

  _skim_file "$plan"
  if [[ -f "$tasks" ]]; then
    echo ""
    echo "Progress:"
    _progress_text "$tasks" | sed 's/^/  /'
  fi

  # Show cross-request links if any declared or computed
  local _dep _blk _rel _req_by _blk_by
  _dep=$(awk '
    /^---$/ { fm++; if (fm > 1) exit; next }
    fm == 1 && found && /^[a-zA-Z]/ { exit }
    fm == 1 && found && /^[[:space:]]*-[[:space:]]+/ {
      val = $0; sub(/^[[:space:]]*-[[:space:]]+/, "", val)
      gsub(/^"|"$/, "", val); gsub(/[[:space:]]+$/, "", val)
      if (val != "") print val
    }
    fm == 1 && /^depends-on:/ { found=1 }
  ' "$plan")
  _blk=$(awk '
    /^---$/ { fm++; if (fm > 1) exit; next }
    fm == 1 && found && /^[a-zA-Z]/ { exit }
    fm == 1 && found && /^[[:space:]]*-[[:space:]]+/ {
      val = $0; sub(/^[[:space:]]*-[[:space:]]+/, "", val)
      gsub(/^"|"$/, "", val); gsub(/[[:space:]]+$/, "", val)
      if (val != "") print val
    }
    fm == 1 && /^blocks:/ { found=1 }
  ' "$plan")
  # Filter related: to slug-only entries (no '/' or '.md') — file refs are
  # for human navigation, not the link graph.
  local _rel_raw
  _rel_raw=$(awk '
    /^---$/ { fm++; if (fm > 1) exit; next }
    fm == 1 && found && /^[a-zA-Z]/ { exit }
    fm == 1 && found && /^[[:space:]]*-[[:space:]]+/ {
      val = $0; sub(/^[[:space:]]*-[[:space:]]+/, "", val)
      gsub(/^"|"$/, "", val); gsub(/[[:space:]]+$/, "", val)
      if (val != "") print val
    }
    fm == 1 && /^related:/ { found=1 }
  ' "$plan")
  _rel=""
  if [[ -n "$_rel_raw" ]]; then
    while IFS= read -r _rr; do
      [[ "$_rr" == */* ]] && continue
      [[ "$_rr" == *.md ]] && continue
      _rel="${_rel:+$_rel$'\n'}$_rr"
    done <<< "$_rel_raw"
  fi

  # Compute inverses by scanning all other active requests
  _req_by=""
  _blk_by=""
  if [[ -d ".spectacular/requests" ]]; then
    shopt -s nullglob
    for _other_plan in .spectacular/requests/*/PLAN.md; do
      local _other_slug
      _other_slug=$(basename "$(dirname "$_other_plan")")
      [[ "$_other_slug" == "$slug" ]] && continue
      # Check if other blocks us (→ we are blocked-by other)
      local _other_blocks
      _other_blocks=$(awk '
        /^---$/ { fm++; if (fm > 1) exit; next }
        fm == 1 && found && /^[a-zA-Z]/ { exit }
        fm == 1 && found && /^[[:space:]]*-[[:space:]]+/ {
          val = $0; sub(/^[[:space:]]*-[[:space:]]+/, "", val)
          gsub(/^"|"$/, "", val); gsub(/[[:space:]]+$/, "", val)
          if (val != "") print val
        }
        fm == 1 && /^blocks:/ { found=1 }
      ' "$_other_plan")
      if echo "$_other_blocks" | grep -qx "$slug" 2>/dev/null; then
        _blk_by="${_blk_by:+$_blk_by$'\n'}$_other_slug"
      fi
      # Check if other depends-on us (→ we are required-by other)
      local _other_deps
      _other_deps=$(awk '
        /^---$/ { fm++; if (fm > 1) exit; next }
        fm == 1 && found && /^[a-zA-Z]/ { exit }
        fm == 1 && found && /^[[:space:]]*-[[:space:]]+/ {
          val = $0; sub(/^[[:space:]]*-[[:space:]]+/, "", val)
          gsub(/^"|"$/, "", val); gsub(/[[:space:]]+$/, "", val)
          if (val != "") print val
        }
        fm == 1 && /^depends-on:/ { found=1 }
      ' "$_other_plan")
      if echo "$_other_deps" | grep -qx "$slug" 2>/dev/null; then
        _req_by="${_req_by:+$_req_by$'\n'}$_other_slug"
      fi
    done
    shopt -u nullglob
  fi

  local _has_links=false
  [[ -n "$_dep"    ]] && _has_links=true
  [[ -n "$_blk"    ]] && _has_links=true
  [[ -n "$_rel"    ]] && _has_links=true
  [[ -n "$_req_by" ]] && _has_links=true
  [[ -n "$_blk_by" ]] && _has_links=true

  if $_has_links; then
    echo ""
    echo "Links:"
    if [[ -n "$_dep" ]]; then
      while IFS= read -r t; do
        [[ -z "$t" ]] && continue
        local _tst=""
        [[ -f ".spectacular/archive/$t/PLAN.md" ]] && _tst=" ✓ (shipped)"
        [[ ! -f ".spectacular/requests/$t/PLAN.md" ]] && [[ ! -f ".spectacular/archive/$t/PLAN.md" ]] && _tst=" ⚠ (not found)"
        printf "  depends-on:  %s%s\n" "$t" "$_tst"
      done <<< "$_dep"
    fi
    if [[ -n "$_blk" ]]; then
      while IFS= read -r t; do
        [[ -z "$t" ]] && continue
        local _tst=""
        [[ -f ".spectacular/archive/$t/PLAN.md" ]] && _tst=" ✓ (shipped)"
        [[ ! -f ".spectacular/requests/$t/PLAN.md" ]] && [[ ! -f ".spectacular/archive/$t/PLAN.md" ]] && _tst=" ⚠ (not found)"
        printf "  blocks:      %s%s\n" "$t" "$_tst"
      done <<< "$_blk"
    fi
    if [[ -n "$_rel" ]]; then
      while IFS= read -r t; do
        [[ -z "$t" ]] && continue
        local _tst=""
        [[ -f ".spectacular/archive/$t/PLAN.md" ]] && _tst=" ✓ (shipped)"
        [[ ! -f ".spectacular/requests/$t/PLAN.md" ]] && [[ ! -f ".spectacular/archive/$t/PLAN.md" ]] && _tst=" ⚠ (not found)"
        printf "  related:     %s%s\n" "$t" "$_tst"
      done <<< "$_rel"
    fi
    if [[ -n "$_req_by" ]]; then
      while IFS= read -r t; do
        [[ -z "$t" ]] && continue
        printf "  required-by: %s  (computed)\n" "$t"
      done <<< "$_req_by"
    fi
    if [[ -n "$_blk_by" ]]; then
      while IFS= read -r t; do
        [[ -z "$t" ]] && continue
        printf "  blocked-by:  %s  (computed)\n" "$t"
      done <<< "$_blk_by"
    fi
  fi
}

# ── cmd_links ─────────────────────────────────────────────────────────────────
# Build and display the cross-request link graph (v1.16.0+).
# Forward edges come from depends-on:/blocks:/related: in each PLAN.md.
# Inverse edges (required-by:, blocked-by:) are computed at read time — never
# stored. Use --all to include unlinked requests; default shows only those with
# at least one edge. Use <slug> to show one request's edges only.
cmd_links() {
  local slug="" json=false all=false
  while (( $# > 0 )); do
    case "$1" in
      --json) json=true; shift ;;
      --all)  all=true;  shift ;;
      --help|-h)
        cat <<EOF
Usage: spectacular links [<slug>] [--json] [--all]

Show the cross-request link graph.

  <slug>   Show edges for one request only
  --json   Machine-readable JSON output
  --all    Include requests with no edges (default: only linked requests)

Forward declarations live in each PLAN.md frontmatter:
  related:     touches (symmetric)
  depends-on:  A cannot ship before B  → B gains required-by: A
  blocks:      A must ship before B    → B gains blocked-by:  A
EOF
        exit 0 ;;
      -*) die "Unknown flag for links: $1" ;;
      *)
        [[ -n "$slug" ]] && die "links: only one <slug> argument allowed"
        slug="$1"; shift ;;
    esac
  done

  [[ -d ".spectacular" ]] || die "links: not inside a Spectacular workspace"

  # ── helper: parse a YAML list field from frontmatter ──────────────────────
  _links_parse_list() {
    local file="$1" field="$2"
    awk -v fld="$field" '
      /^---$/ { fm++; if (fm > 1) exit; next }
      fm != 1 { next }
      found && /^[a-zA-Z]/ { exit }
      found && /^[[:space:]]*-[[:space:]]+/ {
        val = $0; sub(/^[[:space:]]*-[[:space:]]+/, "", val)
        gsub(/^"|"$/, "", val)
        gsub(/[[:space:]]+$/, "", val)
        if (val != "") print val
      }
      $0 ~ "^"fld":" { found=1 }
    ' "$file"
  }

  # ── helper: slug → status label ───────────────────────────────────────────
  _links_status() {
    local t="$1"
    if [[ -f ".spectacular/requests/$t/PLAN.md" ]]; then
      fm_get ".spectacular/requests/$t/PLAN.md" "status"
    elif [[ -f ".spectacular/archive/$t/PLAN.md" ]]; then
      echo "archived"
    else
      echo "unknown"
    fi
  }

  # ── helper: suffix label for a target slug ────────────────────────────────
  _links_suffix() {
    local t="$1"
    if [[ ! -f ".spectacular/requests/$t/PLAN.md" ]]; then
      if [[ -f ".spectacular/archive/$t/PLAN.md" ]]; then
        echo " ✓ (shipped)"
      else
        echo " ⚠ (not found)"
      fi
    fi
  }

  # ── 1. Collect active slugs ────────────────────────────────────────────────
  local -a active_slugs=()
  shopt -s nullglob
  for _d in .spectacular/requests/*/; do
    active_slugs+=("$(basename "$_d")")
  done
  shopt -u nullglob

  # ── 2. Build graph via temp files (bash 3.2 compatible) ───────────────────
  # Temp dir: one file per edge type per slug: <dir>/slug.dep, slug.blk, slug.rel
  # related: entries that contain '/' or '.md' are file refs, not slug refs —
  # skip them (legacy field; depends-on: and blocks: carry the slug edges)
  local _graph_dir
  _graph_dir=$(mktemp -d)

  for _s in "${active_slugs[@]}"; do
    local _plan=".spectacular/requests/$_s/PLAN.md"
    [[ -f "$_plan" ]] || continue
    local _deps _blks _rels_raw
    _deps=$(_links_parse_list "$_plan" "depends-on")
    _blks=$(_links_parse_list "$_plan" "blocks")
    _rels_raw=$(_links_parse_list "$_plan" "related")
    # Filter related: to slug-only entries (no '/' and not ending in .md)
    local _rels=""
    if [[ -n "$_rels_raw" ]]; then
      while IFS= read -r _r; do
        [[ "$_r" == */* ]] && continue
        [[ "$_r" == *.md ]] && continue
        _rels="${_rels:+$_rels$'\n'}$_r"
      done <<< "$_rels_raw"
    fi
    [[ -n "$_deps" ]] && printf '%s\n' "$_deps" > "$_graph_dir/$_s.dep"
    [[ -n "$_blks" ]] && printf '%s\n' "$_blks" > "$_graph_dir/$_s.blk"
    [[ -n "$_rels" ]] && printf '%s\n' "$_rels" > "$_graph_dir/$_s.rel"
  done

  # ── 3. Compute inverses ────────────────────────────────────────────────────
  # For each A deps-on B → append A to B.req_by
  # For each A blocks B → append A to B.blk_by
  for _s in "${active_slugs[@]}"; do
    if [[ -f "$_graph_dir/$_s.dep" ]]; then
      while IFS= read -r _t; do
        [[ -z "$_t" ]] && continue
        echo "$_s" >> "$_graph_dir/$_t.req_by"
      done < "$_graph_dir/$_s.dep"
    fi
    if [[ -f "$_graph_dir/$_s.blk" ]]; then
      while IFS= read -r _t; do
        [[ -z "$_t" ]] && continue
        echo "$_s" >> "$_graph_dir/$_t.blk_by"
      done < "$_graph_dir/$_s.blk"
    fi
  done

  # ── 4. Helper: does slug have any edges? ──────────────────────────────────
  _links_has_edges() {
    local t="$1"
    [[ -f "$_graph_dir/$t.dep"    ]] && return 0
    [[ -f "$_graph_dir/$t.blk"    ]] && return 0
    [[ -f "$_graph_dir/$t.rel"    ]] && return 0
    [[ -f "$_graph_dir/$t.req_by" ]] && return 0
    [[ -f "$_graph_dir/$t.blk_by" ]] && return 0
    return 1
  }

  # ── 5. Scoped to one slug if provided ─────────────────────────────────────
  local -a render_slugs=()
  if [[ -n "$slug" ]]; then
    if [[ ! -f ".spectacular/requests/$slug/PLAN.md" ]] && \
       [[ ! -f ".spectacular/archive/$slug/PLAN.md" ]]; then
      rm -rf "$_graph_dir"
      die "links: '$slug' not found in requests/ or archive/"
    fi
    render_slugs=("$slug")
  else
    for _s in "${active_slugs[@]}"; do
      if $all || _links_has_edges "$_s"; then
        render_slugs+=("$_s")
      fi
    done
  fi

  # ── 6. JSON output ─────────────────────────────────────────────────────────
  if $json; then
    printf '{"graph":['
    local _first_node=true
    for _s in "${render_slugs[@]}"; do
      $_first_node && _first_node=false || printf ','
      printf '{"slug":"%s"' "$(_json_escape "$_s")"

      local _field _ftype
      for _ftype in dep blk rel; do
        case "$_ftype" in
          dep) _field="depends_on" ;;
          blk) _field="blocks"     ;;
          rel) _field="related"    ;;
        esac
        printf ',"%s":[' "$_field"
        local _fe=true
        if [[ -f "$_graph_dir/$_s.$_ftype" ]]; then
          while IFS= read -r _t; do
            [[ -z "$_t" ]] && continue
            local _st; _st=$(_links_status "$_t")
            $_fe && _fe=false || printf ','
            printf '{"slug":"%s","status":"%s"}' "$(_json_escape "$_t")" "$(_json_escape "$_st")"
          done < "$_graph_dir/$_s.$_ftype"
        fi
        printf ']'
      done

      for _ftype in req_by blk_by; do
        case "$_ftype" in
          req_by) _field="required_by" ;;
          blk_by) _field="blocked_by"  ;;
        esac
        printf ',"%s":[' "$_field"
        local _fe=true
        if [[ -f "$_graph_dir/$_s.$_ftype" ]]; then
          while IFS= read -r _t; do
            [[ -z "$_t" ]] && continue
            $_fe && _fe=false || printf ','
            printf '"%s"' "$(_json_escape "$_t")"
          done < "$_graph_dir/$_s.$_ftype"
        fi
        printf ']'
      done
      printf '}'
    done
    printf ']}\n'
    rm -rf "$_graph_dir"
    return 0
  fi

  # ── 7. Text output ─────────────────────────────────────────────────────────
  if [[ ${#render_slugs[@]} -eq 0 ]]; then
    info "No cross-request links declared yet. Add depends-on:/blocks:/related: to a PLAN.md."
    rm -rf "$_graph_dir"
    return 0
  fi

  for _s in "${render_slugs[@]}"; do
    local _st; _st=$(_links_status "$_s")
    printf "%-30s  [%s]\n" "$_s" "$_st"

    if [[ -f "$_graph_dir/$_s.dep" ]]; then
      while IFS= read -r _t; do
        [[ -z "$_t" ]] && continue
        printf "  depends-on:  %s%s\n" "$_t" "$(_links_suffix "$_t")"
      done < "$_graph_dir/$_s.dep"
    fi
    if [[ -f "$_graph_dir/$_s.blk" ]]; then
      while IFS= read -r _t; do
        [[ -z "$_t" ]] && continue
        printf "  blocks:      %s%s\n" "$_t" "$(_links_suffix "$_t")"
      done < "$_graph_dir/$_s.blk"
    fi
    if [[ -f "$_graph_dir/$_s.rel" ]]; then
      while IFS= read -r _t; do
        [[ -z "$_t" ]] && continue
        printf "  related:     %s%s\n" "$_t" "$(_links_suffix "$_t")"
      done < "$_graph_dir/$_s.rel"
    fi
    if [[ -f "$_graph_dir/$_s.req_by" ]]; then
      while IFS= read -r _t; do
        [[ -z "$_t" ]] && continue
        printf "  required-by: %s  (computed)\n" "$_t"
      done < "$_graph_dir/$_s.req_by"
    fi
    if [[ -f "$_graph_dir/$_s.blk_by" ]]; then
      while IFS= read -r _t; do
        [[ -z "$_t" ]] && continue
        printf "  blocked-by:  %s  (computed)\n" "$_t"
      done < "$_graph_dir/$_s.blk_by"
    fi
  done
  rm -rf "$_graph_dir"
}

